---
---

<div
    id="cmd-overlay"
    class="fixed inset-0 z-[9999] hidden"
    role="dialog"
    aria-modal="true"
    aria-label="Command Palette"
>
    <div id="cmd-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

    <div class="relative flex justify-center pt-[12vh] px-4 pointer-events-none">
        <div
            id="cmd-panel"
            class="pointer-events-auto w-full max-w-xl rounded-2xl border border-main-border/15 bg-main-bg shadow-[0_32px_80px_-12px_rgba(0,0,0,0.35)] overflow-hidden"
        >
            <!-- Input row -->
            <div class="flex items-center gap-3 px-4 py-3.5 border-b border-main-border/10">
                <svg class="w-4 h-4 text-main/40 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                </svg>
                <input
                    id="cmd-input"
                    type="text"
                    placeholder="Search commands, pages, actions…"
                    autocomplete="off"
                    spellcheck="false"
                    class="flex-1 bg-transparent text-main text-sm outline-none placeholder:text-main/35"
                />
                <kbd class="hidden sm:flex items-center px-1.5 py-0.5 rounded-md border border-main-border/20 text-[10px] text-main/30 font-mono">esc</kbd>
            </div>

            <!-- Results -->
            <div id="cmd-results" class="overflow-y-auto max-h-[380px] py-2 cmd-scrollbar"></div>

            <!-- Footer -->
            <div class="flex items-center justify-between px-4 py-2 border-t border-main-border/10 text-[10px] text-main/30 font-mono">
                <div class="flex items-center gap-4">
                    <span>↑↓ navigate</span>
                    <span>↵ open</span>
                    <span>esc close</span>
                </div>
                <span>⌘K</span>
            </div>
        </div>
    </div>
</div>

<style>
    .cmd-scrollbar::-webkit-scrollbar { width: 3px; }
    .cmd-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .cmd-scrollbar::-webkit-scrollbar-thumb { background: rgba(var(--text-main-rgb, 23,23,23), 0.15); border-radius: 2px; }

    #cmd-overlay.cmd-open { display: block; }

    #cmd-panel {
        transform: translateY(-10px) scale(0.97);
        opacity: 0;
        transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.15s ease;
    }
    #cmd-overlay.cmd-open #cmd-panel {
        transform: translateY(0) scale(1);
        opacity: 1;
    }
</style>

<script>
    let cmdAbortController: AbortController | null = null;

    function initCommandPalette() {
        if (cmdAbortController) cmdAbortController.abort();
        cmdAbortController = new AbortController();
        const { signal } = cmdAbortController;

        const overlay  = document.getElementById('cmd-overlay');
        const backdrop = document.getElementById('cmd-backdrop');
        const input    = document.getElementById('cmd-input') as HTMLInputElement | null;
        const results  = document.getElementById('cmd-results');
        if (!overlay || !input || !results) return;

        let selectedIndex = 0;
        let filteredItems: { category: string; label: string; hint: string; icon: string; action: () => void }[] = [];

        const icon = (path: string) =>
            `<svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">${path}</svg>`;

        const commands = [
            // ── Navigate ──────────────────────────────────────────
            { category: 'Navigate', label: 'Home',        hint: '/',            icon: icon('<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>'),                                           action: () => goto('/') },
            { category: 'Navigate', label: 'Experience',  hint: '/experience',  icon: icon('<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>'),                                          action: () => goto('/experience') },
            { category: 'Navigate', label: 'Education',   hint: '/education',   icon: icon('<path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>'),                                                                    action: () => goto('/education') },
            { category: 'Navigate', label: 'Projects',    hint: '/projects',    icon: icon('<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>'),                                                                       action: () => goto('/projects') },
            { category: 'Navigate', label: 'Blog',        hint: '/blog',        icon: icon('<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>'), action: () => goto('/blog') },
            { category: 'Navigate', label: 'Contact',     hint: '/contact',     icon: icon('<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>'),                                                                      action: () => goto('/contact') },
            { category: 'Navigate', label: 'Stack',       hint: '/stack',       icon: icon('<path d="M2 17L12 22L22 17"/><path d="M2 12L12 17L22 12"/><path d="M12 2L2 7L12 12L22 7L12 2Z"/>'),                                                   action: () => goto('/stack') },
            { category: 'Navigate', label: 'Now',         hint: '/now',         icon: icon('<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>'),                                                                             action: () => goto('/now') },
            { category: 'Navigate', label: 'Nexus',       hint: '/knowledge-graph', icon: icon('<circle cx="12" cy="12" r="2"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>'), action: () => goto('/knowledge-graph') },
            // ── Actions ───────────────────────────────────────────
            { category: 'Actions',  label: 'Toggle Theme',        hint: '⇧T',    icon: icon('<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>'), action: () => { toggleTheme(); close(); } },
            { category: 'Actions',  label: 'Download Resume',     hint: '↓ PDF', icon: icon('<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>'),              action: () => { window.open('/Navneet-Resume.pdf', '_blank'); close(); } },
            { category: 'Actions',  label: 'Copy Email',          hint: '📋',    icon: icon('<rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>'),                          action: () => { navigator.clipboard?.writeText('aroranavneetsingh.de@gmail.com'); toast('Email copied!'); close(); } },
            { category: 'Actions',  label: 'Open GitHub',         hint: '↗',     icon: icon('<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>'), action: () => { window.open('https://github.com/NavneetSinghArora', '_blank'); close(); } },
            { category: 'Actions',  label: 'Open LinkedIn',       hint: '↗',     icon: icon('<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>'), action: () => { window.open('https://www.linkedin.com/in/navneet-singh-arora', '_blank'); close(); } },
        ];

        function goto(href: string) { window.location.href = href; close(); }

        function toggleTheme() {
            const isDark = document.documentElement.classList.toggle('dark');
            localStorage.theme = isDark ? 'dark' : 'light';
        }

        function toast(msg: string) {
            const el = document.createElement('div');
            el.className = 'fixed bottom-6 left-1/2 -translate-x-1/2 z-[99999] px-4 py-2 rounded-xl bg-main text-main-bg text-sm font-medium shadow-2xl';
            el.style.cssText = 'transition: opacity 0.3s; pointer-events: none;';
            el.textContent = msg;
            document.body.appendChild(el);
            setTimeout(() => { el.style.opacity = '0'; setTimeout(() => el.remove(), 350); }, 2000);
        }

        function open() {
            overlay!.classList.add('cmd-open');
            input!.value = '';
            render('');
            requestAnimationFrame(() => input!.focus());
        }

        function close() {
            overlay!.classList.remove('cmd-open');
            input!.blur();
        }

        function render(query: string) {
            const q = query.toLowerCase().trim();
            filteredItems = q
                ? commands.filter(c => c.label.toLowerCase().includes(q) || c.category.toLowerCase().includes(q))
                : commands;
            selectedIndex = 0;

            if (!filteredItems.length) {
                results!.innerHTML = `<p class="px-4 py-10 text-center text-sm text-main/40">No results for <em>"${query}"</em></p>`;
                return;
            }

            const cats = [...new Set(filteredItems.map(c => c.category))];
            results!.innerHTML = cats.map(cat => {
                const items = filteredItems.filter(c => c.category === cat);
                return `<div class="px-4 pt-3 pb-1 text-[10px] font-mono uppercase tracking-[0.15em] text-main/35">${cat}</div>` +
                    items.map(item => {
                        const idx = filteredItems.indexOf(item);
                        return `<button class="cmd-item flex w-full items-center gap-3 px-3 py-2.5 mx-1 rounded-lg text-left transition-colors duration-75 ${idx === 0 ? 'bg-main/6 selected' : 'hover:bg-main/5'}" data-idx="${idx}">
                            <span class="text-main/45 shrink-0">${item.icon}</span>
                            <span class="flex-1 text-sm text-main">${item.label}</span>
                            <span class="text-[11px] font-mono text-main/30 shrink-0">${item.hint}</span>
                        </button>`;
                    }).join('');
            }).join('');

            results!.querySelectorAll<HTMLButtonElement>('.cmd-item').forEach(el => {
                el.addEventListener('click', () => {
                    filteredItems[parseInt(el.dataset.idx!)]?.action();
                    close();
                });
            });
        }

        function select(idx: number) {
            const els = results!.querySelectorAll<HTMLElement>('.cmd-item');
            els.forEach(el => { el.classList.remove('bg-main/6', 'selected'); el.classList.add('hover:bg-main/5'); });
            selectedIndex = Math.max(0, Math.min(filteredItems.length - 1, idx));
            const el = els[selectedIndex];
            if (el) { el.classList.add('bg-main/6', 'selected'); el.scrollIntoView({ block: 'nearest' }); }
        }

        // Global keyboard
        document.addEventListener('keydown', (e) => {
            if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
                e.preventDefault();
                overlay!.classList.contains('cmd-open') ? close() : open();
                return;
            }
            if (!overlay!.classList.contains('cmd-open')) return;
            if (e.key === 'Escape')    { close(); return; }
            if (e.key === 'ArrowDown') { e.preventDefault(); select(selectedIndex + 1); }
            if (e.key === 'ArrowUp')   { e.preventDefault(); select(selectedIndex - 1); }
            if (e.key === 'Enter')     { e.preventDefault(); filteredItems[selectedIndex]?.action(); close(); }
        }, { signal });

        backdrop!.addEventListener('click', close, { signal });
        input!.addEventListener('input', e => render((e.target as HTMLInputElement).value), { signal });
    }

    document.addEventListener('astro:page-load', initCommandPalette);
</script>
