---
interface Props {
    username: string;
}

const { username } = Astro.props;
---

<section class="mb-16 sm:mb-24">
    <div class="mb-12 sm:mb-16">
        <h2 class="mb-4 font-serif text-xl sm:text-2xl">Contributions</h2>
        <p class="max-w-2xl text-sm opacity-80 sm:text-base">
            My activity and contributions over the last year.
        </p>
    </div>

    <div 
        id="github-contributions"
        data-username={username}
        class="spotlight-card group/card relative overflow-hidden rounded-2xl border border-main-border/20 bg-main-bg/10 p-6 transition-all hover:bg-main-bg/20 backdrop-blur-md shadow-sm"
    >
        <!-- Skeleton Loading Sketch -->
        <div id="contributions-loading" class="flex flex-col gap-[18px] h-[200px] w-full p-2 opacity-20">
            <div class="h-4 w-32 bg-main-border/20 rounded-md animate-pulse"></div>
            <div class="flex gap-[3px]">
                {Array.from({ length: 52 }).map(() => (
                    <div class="flex flex-col gap-[3px]">
                        {Array.from({ length: 7 }).map(() => (
                            <div class="h-[10px] w-[10px] rounded-[2px] bg-main-border/20 animate-pulse"></div>
                        ))}
                    </div>
                ))}
            </div>
            <div class="flex justify-between">
                <div class="h-4 w-24 bg-main-border/20 rounded-md animate-pulse"></div>
                <div class="h-4 w-32 bg-main-border/20 rounded-md animate-pulse"></div>
            </div>
        </div>
        
        <div id="contributions-error" class="hidden flex h-[200px] items-center justify-center text-sm opacity-50">
            Failed to load contributions.
        </div>

        <div id="contributions-content" class="hidden min-h-[200px]">
            <div class="overflow-x-auto pb-4 custom-scrollbar">
                <div id="contributions-grid" class="flex gap-[3px] min-w-max">
                    <!-- Columns will be injected here -->
                </div>
            </div>
            
            <div class="mt-6 flex flex-wrap items-center justify-between gap-4 border-t border-main-border/5 pt-6">
                <div class="flex items-center gap-6">
                    <div class="flex flex-col">
                        <span id="total-contributions" class="text-xl font-medium tracking-tight">0</span>
                        <span class="text-[10px] uppercase tracking-wider opacity-50">Total Contributions</span>
                    </div>
                </div>
                
                <div class="flex items-center gap-2">
                    <span class="text-[10px] uppercase tracking-wider opacity-50">Less</span>
                    <div class="flex gap-[3px]">
                        <div class="h-[10px] w-[10px] rounded-[2px] level-0"></div>
                        <div class="h-[10px] w-[10px] rounded-[2px] level-1"></div>
                        <div class="h-[10px] w-[10px] rounded-[2px] level-2"></div>
                        <div class="h-[10px] w-[10px] rounded-[2px] level-3"></div>
                        <div class="h-[10px] w-[10px] rounded-[2px] level-4"></div>
                    </div>
                    <span class="text-[10px] uppercase tracking-wider opacity-50">More</span>
                </div>
            </div>
        </div>

        <!-- Spotlight Layers -->
        <div class="spotlight-glow absolute inset-0 -z-10 opacity-0 transition-opacity duration-500 group-hover/card:opacity-100" />
        <div class="spotlight-border absolute inset-0 -z-10 rounded-2xl opacity-0 transition-opacity duration-500 group-hover/card:opacity-100" />
    </div>

    <!-- Premium Sliding Tooltip -->
    <div id="github-tooltip" class="pointer-events-none fixed z-50 will-change-[transform,left,top,opacity]" style="opacity: 0; visibility: hidden;">
        <div class="relative flex flex-col items-center drop-shadow-xl">
            <div class="rounded-md px-3 py-1.5 text-[11px] font-medium tracking-wide whitespace-nowrap bg-main text-main-bg">
                <span id="github-tooltip-text"></span>
            </div>
            <svg class="w-3 h-1.5 -mt-[1px] text-main" viewBox="0 0 12 6" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4.69701 5.30299C5.41843 6.02441 6.58157 6.02441 7.30299 5.30299L12 0.605988L0 0.605988L4.69701 5.30299Z" fill="currentColor"/>
            </svg>
        </div>
    </div>
</section>

<style>
    .custom-scrollbar::-webkit-scrollbar {
        height: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(var(--text-main-rgb, 23, 23, 23), 0.1);
        border-radius: 10px;
    }
    :global(.dark) .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
    }

    .spotlight-glow {
        background: radial-gradient(
            600px circle at var(--mx, 0px) var(--my, 0px),
            var(--spotlight-color, rgba(56, 189, 248, 0.15)),
            transparent 80%
        );
    }

    .spotlight-border {
        padding: 1px;
        background: radial-gradient(
            300px circle at var(--mx, 0px) var(--my, 0px),
            rgba(56, 189, 248, 0.4),
            transparent 80%
        );
        mask: linear-gradient(#fff, #fff) content-box, linear-gradient(#fff, #fff);
        mask-composite: exclude;
        -webkit-mask: linear-gradient(#fff, #fff) content-box, linear-gradient(#fff, #fff);
        -webkit-mask-composite: xor;
        pointer-events: none;
    }
</style>

<style is:global>
    /* Contribution square colors for dynamically injected DOM */
    .level-0 { background-color: rgba(var(--text-main-rgb, 23, 23, 23), 0.05); }
    .level-1 { background-color: rgba(var(--text-main-rgb, 23, 23, 23), 0.2); }
    .level-2 { background-color: rgba(var(--text-main-rgb, 23, 23, 23), 0.4); }
    .level-3 { background-color: rgba(var(--text-main-rgb, 23, 23, 23), 0.6); }
    .level-4 { background-color: rgba(var(--text-main-rgb, 23, 23, 23), 0.9); }

    html.dark .level-0, .dark .level-0 { background-color: rgba(255, 255, 255, 0.05); }
    html.dark .level-1, .dark .level-1 { background-color: rgba(255, 255, 255, 0.2); }
    html.dark .level-2, .dark .level-2 { background-color: rgba(255, 255, 255, 0.4); }
    html.dark .level-3, .dark .level-3 { background-color: rgba(255, 255, 255, 0.6); }
    html.dark .level-4, .dark .level-4 { background-color: rgba(255, 255, 255, 0.9); }
</style>

<script>
    async function initGithubContributions() {
        const container = document.getElementById('github-contributions');
        if (!container) return;

        const usernames = container.dataset.username?.split(',').map(u => u.trim()) || [];
        const grid = document.getElementById('contributions-grid');
        const loading = document.getElementById('contributions-loading');
        const error = document.getElementById('contributions-error');
        const content = document.getElementById('contributions-content');
        const totalEl = document.getElementById('total-contributions');

        if (!usernames.length || !grid || !loading || !error || !content || !totalEl) return;

        try {
            const fetchPromises = usernames.map(u => 
                fetch(`https://github-contributions-api.jogruber.de/v4/${u}?y=last`).then(res => {
                    if (!res.ok) throw new Error('Failed to fetch');
                    return res.json();
                })
            );
            
            const allData = await Promise.all(fetchPromises);
            
            let totalLastYear = 0;
            const contributionsMap = new Map();

            allData.forEach(data => {
                totalLastYear += data.total?.lastYear || 0;
                
                data.contributions?.forEach((day: any) => {
                    if (contributionsMap.has(day.date)) {
                        const existing = contributionsMap.get(day.date);
                        existing.count += day.count;
                    } else {
                        contributionsMap.set(day.date, { date: day.date, count: day.count });
                    }
                });
            });

            const getLevel = (count: number) => {
                if (count === 0) return 0;
                if (count <= 2) return 1;
                if (count <= 5) return 2;
                if (count <= 9) return 3;
                return 4;
            };

            const contributions = Array.from(contributionsMap.values())
                .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime())
                .map(day => ({
                    ...day,
                    level: getLevel(day.count)
                }));
            
            totalEl.innerText = totalLastYear.toLocaleString();

            // Padding the beginning so the first day aligns correctly with the day of the week (0 = Sunday)
            const firstDateStr = contributions[0].date;
            const firstPadding = new Date(firstDateStr).getDay();
            const paddedContributions = [];
            
            for (let i = 0; i < firstPadding; i++) {
                paddedContributions.push({ empty: true });
            }
            paddedContributions.push(...contributions);

            // Group by week
            const weeks: any[][] = [];
            let currentWeek: any[] = [];
            
            paddedContributions.forEach((day, index) => {
                currentWeek.push(day);
                if (currentWeek.length === 7 || index === paddedContributions.length - 1) {
                    weeks.push(currentWeek);
                    currentWeek = [];
                }
            });

            // Render grid
            let monthLabels = '';
            let currentMonth = -1;
            
            const weeksHTML = weeks.map((week, weekIndex) => {
                // Determine month of first non-empty day in the week
                const firstRealDay = week.find(d => !d.empty);
                if (firstRealDay) {
                    const firstDayDate = new Date(firstRealDay.date);
                    const month = firstDayDate.getMonth();
                    
                    if (month !== currentMonth && weekIndex < weeks.length - 2) {
                        currentMonth = month;
                        const monthName = firstDayDate.toLocaleString('default', { month: 'short' });
                        monthLabels += `<div class="absolute" style="left: ${weekIndex * 13}px">${monthName}</div>`;
                    }
                }

                return `
                    <div class="flex flex-col gap-[3px]">
                        ${week.map(day => day.empty ? `
                            <div class="h-[10px] w-[10px] rounded-[2px] bg-transparent"></div>
                        ` : `
                            <div 
                                class="github-square h-[10px] w-[10px] rounded-[2px] level-${day.level} transition-all hover:scale-125 hover:z-10" 
                                data-date="${day.date}"
                                data-count="${day.count}"
                            ></div>
                        `).join('')}
                    </div>
                `;
            }).join('');

            grid.innerHTML = `
                <div class="flex gap-2 w-full">
                    <!-- Left Axis for Days -->
                    <div class="flex flex-col gap-[3px] text-[9px] text-main/50 font-medium pt-[18px]">
                        <div style="height: 10px;"></div>
                        <div style="height: 10px; line-height: 10px;">Mon</div>
                        <div style="height: 10px;"></div>
                        <div style="height: 10px; line-height: 10px;">Wed</div>
                        <div style="height: 10px;"></div>
                        <div style="height: 10px; line-height: 10px;">Fri</div>
                        <div style="height: 10px;"></div>
                    </div>
                    
                    <!-- Chart Area -->
                    <div class="flex flex-col gap-[3px]">
                        <!-- Top Axis for Months -->
                        <div class="relative h-[15px] text-[9px] text-main/50 font-medium">
                            ${monthLabels}
                        </div>
                        
                        <!-- Grid Matrix -->
                        <div class="flex gap-[3px]">
                            ${weeksHTML}
                        </div>
                    </div>
                </div>
            `;

            loading.classList.add('hidden');
            content.classList.remove('hidden');

            const tooltip = document.getElementById('github-tooltip');
            const tooltipText = document.getElementById('github-tooltip-text');

            if (tooltip && tooltipText) {
                let isTooltipVisible = false;
                let hideTimeout: number;

                grid.addEventListener('mouseover', (e) => {
                    const target = e.target as HTMLElement;
                    const square = target.closest('.github-square');
                    if (!square) return;

                    clearTimeout(hideTimeout);

                    const count = parseInt(square.getAttribute('data-count') || '0');
                    const dateStr = square.getAttribute('data-date');
                    if (!dateStr) return;
                    
                    const date = new Date(dateStr);
                    const formattedDate = date.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
                    
                    const text = count === 0 
                        ? `${formattedDate} — Rest day 🪴` 
                        : `${formattedDate} — ${count} contribution${count > 1 ? 's' : ''}`;
                    
                    tooltipText.innerText = text;
                    
                    const rect = square.getBoundingClientRect();
                    const left = rect.left + rect.width / 2;
                    const top = rect.top - 8;

                    if (!isTooltipVisible) {
                        // Snap into position instantly
                        tooltip.style.transition = 'none';
                        tooltip.style.left = `${left}px`;
                        tooltip.style.top = `${top}px`;
                        tooltip.style.transform = `translate(-50%, -100%) translateY(4px) scale(0.95)`;
                        
                        // Force reflow
                        void tooltip.offsetHeight;
                        
                        // Add entrance transitions
                        tooltip.style.transition = 'all 0.2s cubic-bezier(0.16, 1, 0.3, 1)';
                        isTooltipVisible = true;
                    }

                    // Animate to position & scale up
                    tooltip.style.opacity = '1';
                    tooltip.style.visibility = 'visible';
                    tooltip.style.left = `${left}px`;
                    tooltip.style.top = `${top}px`;
                    tooltip.style.transform = `translate(-50%, -100%) translateY(0) scale(1)`;
                });

                grid.addEventListener('mouseout', (e) => {
                    const target = e.target as HTMLElement;
                    const square = target.closest('.github-square');
                    if (!square) return;

                    // Delay to allow smooth transition between squares
                    hideTimeout = window.setTimeout(() => {
                        tooltip.style.opacity = '0';
                        tooltip.style.transform = `translate(-50%, -100%) translateY(4px) scale(0.95)`;
                        isTooltipVisible = false;
                        
                        window.setTimeout(() => { 
                            if (!isTooltipVisible) tooltip.style.visibility = 'hidden'; 
                        }, 200);
                    }, 50);
                });
            }
        } catch (err) {
            console.error(err);
            loading.classList.add('hidden');
            error.classList.remove('hidden');
        }

        // Spotlight interaction
        container.addEventListener('mousemove', (e: MouseEvent) => {
            const rect = container.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            container.style.setProperty('--mx', `${x}px`);
            container.style.setProperty('--my', `${y}px`);
        });
    }

    // Run on initial load and view transitions
    initGithubContributions();
    document.addEventListener('astro:page-load', initGithubContributions);
</script>
