---
import siteConfig from '../data/site-config';
import QuickConnect from './QuickConnect.astro';

// Dynamically import all logos from src/assets/icons to ensure they are bundled correctly
const logos = import.meta.glob<{ default: ImageMetadata }>('/src/assets/icons/*.{svg,png,webp,jpg,jpeg}', { eager: true });

function resolveIcon(name: string | undefined) {
    if (!name) return '';
    if (name.startsWith('http')) return name;
    
    // Handle special cases
    let searchName = name;
    if (name.toLowerCase() === 'n8n creator') {
        searchName = 'n8n';
    }
    
    const extensions = ['.svg', '.png', '.webp', '.jpg', '.jpeg'];
    for (const ext of extensions) {
        const path = `/src/assets/icons/${searchName}${ext}`;
        const asset = logos[path];
        if (asset) {
            return (asset.default as any)?.src || asset.default || asset;
        }
    }
    return '';
}

const socialLinks = siteConfig.socialLinks ?? [];
const navLinks = siteConfig.footerNavLinks ?? [];
const currentYear = new Date().getFullYear();
---

<footer class="mx-auto w-full max-w-3xl pt-12 pb-10 sm:pt-24 sm:pb-14">
    {
        navLinks.length > 0 && (
            <nav class="mb-4 flex flex-wrap gap-x-6 gap-y-1" aria-label="Footer navigation">
                {navLinks.map((link) => (
                    <a class="font-serif" href={link.href} target={link.target}>
                        <span class="premium-line-hover">{link.text}</span>
                    </a>
                ))}
            </nav>
        )
    }
    <div
        class:list={[
            'flex flex-col gap-8 border-t border-main-border/10 pt-8',
            { 'sm:flex-row-reverse sm:items-center sm:justify-between': socialLinks.length > 0 }
        ]}
    >
        {
            socialLinks.length > 0 && (
                <div class="flex flex-wrap items-center gap-1.5">
                    {socialLinks.map((link) => {
                        const iconName = link.text.toLowerCase();
                        const iconPath = resolveIcon(iconName);
                        const isGithub = iconName === 'github';
                        const isResume = iconName === 'resume';
                        const resumeIcon = 'https://img.icons8.com/color/48/parse-from-clipboard.png';

                        return (
                            <a
                                class="group/social premium-tooltip relative flex h-8 w-8 items-center justify-center transition-all duration-300 hover:scale-115"
                                href={link.href}
                                target="_blank"
                                rel="noopener noreferrer"
                                data-tooltip={link.text}
                            >
                                <div class="absolute inset-0 rounded-xl bg-main/5 opacity-0 transition-all duration-300 group-hover/social:opacity-100 group-hover/social:scale-110 group-hover/social:bg-main/10 ring-1 ring-main/10" />
                                {isGithub ? (
                                    <>
                                        <img src={resolveIcon('github-dark')} alt="" class="relative z-10 h-3.5 w-3.5 opacity-90 transition-all dark:hidden" />
                                        <img src={resolveIcon('github-light')} alt="" class="relative z-10 hidden h-3.5 w-3.5 opacity-90 transition-all dark:block" />
                                    </>
                                ) : isResume ? (
                                    <img src={resumeIcon} alt="" class="relative z-10 h-3.5 w-3.5 opacity-90 transition-all" />
                                ) : (
                                    <img src={iconPath} alt="" class="relative z-10 h-3.5 w-3.5 opacity-90 transition-all" />
                                )}
                            </a>
                        );
                    })}
                    <div class="flex items-center">
                        <QuickConnect />
                    </div>
                </div>
            )
        }
        <p class="text-sm opacity-60">
            &copy; {currentYear}
            <a href="/"><span class="premium-line-hover">{siteConfig.title}</span></a>. All rights reserved.
        </p>
    </div>
</footer>
