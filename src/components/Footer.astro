---
import siteConfig from '../data/site-config';
import QuickConnect from './QuickConnect.astro';
import IconButton from './IconButton.astro';
import SocialIcon from './SocialIcon.astro';
import { resolveIcon } from '../utils/data-utils';

type KnownIcon = 'github' | 'npm' | 'medium' | 'kaggle' | 'n8n';
const knownIcons: KnownIcon[] = ['github', 'npm', 'medium', 'kaggle', 'n8n'];

const socialLinks = siteConfig.socialLinks ?? [];
const navLinks = siteConfig.footerNavLinks ?? [];
const currentYear = new Date().getFullYear();

const resumeIcon = 'https://img.icons8.com/color/48/parse-from-clipboard.png';
---

<footer class="mx-auto w-full max-w-4xl pb-6 px-4 sm:pb-10">
    <div class="relative rounded-2xl border border-main-border/10 bg-main-bg/40 backdrop-blur-xl shadow-lg p-1.5 ring-1 ring-white/5 dark:ring-white/10 flex flex-col gap-3">

        <!-- Row 1: Split Layout -->
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 px-4 py-2">
            <!-- Left: Navigation Links -->
            {
                navLinks.length > 0 && (
                    <nav class="flex flex-wrap items-center gap-x-5 gap-y-2 order-2 sm:order-1" aria-label="Footer navigation">
                        {navLinks.map((link) => (
                            <a class="font-serif text-sm font-medium text-main/60 transition-colors hover:text-main" href={link.href} target={link.target}>
                                <span class="premium-line-hover">{link.text}</span>
                            </a>
                        ))}
                    </nav>
                )
            }

            <!-- Right: Socials & QuickConnect -->
            {
                socialLinks.length > 0 && (
                    <div class="flex flex-wrap items-center gap-1.5 order-1 sm:order-2">
                        {socialLinks.map((link) => {
                            let iconName = link.text.toLowerCase();
                            if (iconName === 'n8n creator') iconName = 'n8n';

                            const isKnown = knownIcons.includes(iconName as KnownIcon);
                            const isResume = iconName === 'resume';

                            return (
                                <IconButton
                                    href={link.href}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    size="sm"
                                    tooltip={link.text}
                                >
                                    {isKnown ? (
                                        <SocialIcon name={iconName as KnownIcon} />
                                    ) : isResume ? (
                                        <img src={resumeIcon} alt={link.text} class="h-3.5 w-3.5" />
                                    ) : (
                                        <img src={resolveIcon(iconName)} alt={link.text} class="h-3.5 w-3.5" />
                                    )}
                                </IconButton>
                            );
                        })}
                        <div class="w-px h-4 bg-main-border/10 mx-1"></div>
                        <div class="flex items-center pl-1">
                            <QuickConnect />
                        </div>
                    </div>
                )
            }
        </div>

        <!-- Divider -->
        <div class="w-full h-px bg-main-border/5"></div>

        <!-- Row 2: Copyright -->
        <div class="text-center pb-2 px-4">
            <p class="text-[11px] font-bold tracking-[0.1em] uppercase text-main/30">
                &copy; {currentYear}
                <a href="/"><span class="premium-line-hover text-main/40">{siteConfig.title}</span></a>.
                All rights reserved.
            </p>
        </div>
    </div>
</footer>
