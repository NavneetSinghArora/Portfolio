---
import siteConfig from '../data/site-config';
import QuickConnect from './QuickConnect.astro';

// Dynamically import all logos from src/assets/icons to ensure they are bundled correctly
const logos = import.meta.glob<{ default: ImageMetadata }>('/src/assets/icons/*.{svg,png,webp,jpg,jpeg}', { eager: true });

function resolveIcon(name: string | undefined) {
    if (!name) return '';
    if (name.startsWith('http')) return name;
    
    // Handle special cases
    let searchName = name;
    if (name.toLowerCase() === 'n8n creator') {
        searchName = 'n8n';
    }
    
    const extensions = ['.svg', '.png', '.webp', '.jpg', '.jpeg'];
    for (const ext of extensions) {
        const path = `/src/assets/icons/${searchName}${ext}`;
        const asset = logos[path];
        if (asset) {
            return (asset.default as any)?.src || asset.default || asset;
        }
    }
    return '';
}

const socialLinks = siteConfig.socialLinks ?? [];
const navLinks = siteConfig.footerNavLinks ?? [];
const currentYear = new Date().getFullYear();
---

<footer class="mx-auto w-full max-w-3xl pt-12 pb-10 sm:pt-24 sm:pb-14">
    {
        navLinks.length > 0 && (
            <nav class="mb-4 flex flex-wrap gap-x-6 gap-y-1" aria-label="Footer navigation">
                {navLinks.map((link) => (
                    <a class="font-serif hover:underline hover:underline-offset-2" href={link.href} target={link.target}>
                        {link.text}
                    </a>
                ))}
            </nav>
        )
    }
    <div
        class:list={[
            'border-main-border flex flex-col gap-8 border-t border-dashed pt-8',
            { 'sm:flex-row-reverse sm:items-center sm:justify-between': socialLinks.length > 0 }
        ]}
    >
        {
            socialLinks.length > 0 && (
                <div class="flex flex-wrap gap-5">
                    {socialLinks.map((link) => {
                        const iconName = link.text.toLowerCase();
                        const iconPath = resolveIcon(iconName);
                        const isGithub = iconName === 'github';
                        const isResume = iconName === 'resume';
                        const resumeIcon = 'https://img.icons8.com/color/48/parse-from-clipboard.png';

                        return (
                            <a
                                class="group/social relative flex items-center justify-center transition-all duration-300 hover:-translate-y-0.5"
                                href={link.href}
                                target="_blank"
                                rel="noopener noreferrer"
                                title={link.text}
                            >
                                <div class="absolute -inset-2 rounded-full bg-main-bg/5 opacity-0 transition-opacity group-hover/social:opacity-100" />
                                {isGithub ? (
                                    <>
                                        <img src={resolveIcon('github-dark')} alt="" class="h-5 w-5 opacity-50 transition-opacity group-hover/social:opacity-100 dark:hidden" />
                                        <img src={resolveIcon('github-light')} alt="" class="hidden h-5 w-5 opacity-50 transition-opacity group-hover/social:opacity-100 dark:block" />
                                    </>
                                ) : isResume ? (
                                    <img src={resumeIcon} alt="" class="h-6 w-6 opacity-70 transition-opacity group-hover/social:opacity-100" />
                                ) : (
                                    <img src={iconPath} alt="" class="h-5 w-5 opacity-50 transition-opacity group-hover/social:opacity-100" />
                                )}
                            </a>
                        );
                    })}
                    <QuickConnect />
                </div>
            )
        }
        <p class="text-sm opacity-60">
            &copy; {currentYear}
            <a class="hover:underline hover:underline-offset-2" href="/">{siteConfig.title}</a>. All rights reserved.
        </p>
    </div>
</footer>
