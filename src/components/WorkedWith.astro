---
import { Image } from 'astro:assets';
import repathImg    from '../assets/images/repath.jpeg';
import omdenaImg   from '../assets/images/omdena.png';
import niceImg     from '../assets/images/nice.jpeg';
import cognizantImg from '../assets/images/cognizant.png';
import uhhImg      from '../assets/images/uhh.jpeg';

const companies = [
    {
        name: 'Repath',
        img: repathImg,
        href: 'https://www.repath.ai/',
        role: 'ML & Full Stack Engineer',
        period: 'Dec 2021 — Present',
    },
    {
        name: 'Omdena',
        img: omdenaImg,
        href: 'https://omdena.com/',
        role: 'Chapter Lead',
        period: 'Jun 2021 — Present',
    },
    {
        name: 'NICE Ltd.',
        img: niceImg,
        href: 'https://www.nice.com/',
        role: 'Tech Lead → Engineer',
        period: 'Jan 2018 — Oct 2020',
    },
    {
        name: 'Cognizant',
        img: cognizantImg,
        href: 'https://www.cognizant.com/',
        role: 'Program Analyst',
        period: 'Jul 2015 — Jan 2018',
    },
    {
        name: 'Universität Hamburg',
        img: uhhImg,
        href: 'https://www.uni-hamburg.de/en.html',
        role: 'Student Tutor',
        period: 'Oct 2021 — Mar 2022',
    },
];
---

<div class="mb-16 sm:mb-24" data-nn-layer="worked-with">
    <p class="mb-6 text-[11px] font-mono uppercase tracking-[0.2em] text-main/35">Worked with</p>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
        {companies.map(c => (
            <a
                href={c.href}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex flex-col gap-3 p-4 rounded-2xl border border-main-border/10 bg-main-bg/20 backdrop-blur-sm transition-all duration-300 hover:border-main-border/30 hover:bg-main-bg/30 hover:-translate-y-0.5 hover:shadow-lg"
                aria-label={c.name}
            >
                <div class="flex h-10 w-10 rounded-xl overflow-hidden border border-main-border/15 flex-shrink-0">
                    <Image
                        src={c.img}
                        alt={c.name}
                        width={40}
                        height={40}
                        class="h-full w-full object-cover"
                    />
                </div>
                <div class="min-w-0">
                    <p class="text-sm font-semibold text-main truncate">{c.name}</p>
                    <p class="text-[10px] text-main/50 truncate mt-0.5">{c.role}</p>
                    <p class="text-[9px] text-main/30 font-mono mt-0.5">{c.period}</p>
                </div>
            </a>
        ))}
    </div>
</div>
