            </svg>
        </div>
        
        <div class="flex flex-col">
            <p class="text-[10px] sm:text-[11px] font-mono tracking-[0.2em] font-semibold text-main/40 uppercase mb-1">
                GitHub Blueprint
            </p>
            <div class="flex items-baseline gap-2 leading-none">
                <h3 class="text-3xl sm:text-4xl font-bold tracking-tight text-white/90">
                    {totalLoc.toLocaleString()}
                </h3>
            </div>
            <p class="text-[11px] sm:text-xs font-medium text-main/50 mt-2">
                approx. lines of code written
            </p>
        </div>
    </div>

    <!-- Divider -->
    <div class="my-5 h-[1px] w-full bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

    <div class="grid grid-cols-3 gap-4 pb-2">
        <div class="flex flex-col text-center sm:text-left gap-1">
            <span class="text-[14px] sm:text-[15px] font-semibold text-white/90 leading-tight">
                {top3Languages[0]}<br/><span class="text-xs text-white/70">{top3Languages[1]} • {top3Languages[2]}</span>
            </span>
            <span class="text-[9px] sm:text-[10px] tracking-[0.1em] font-mono uppercase text-main/40 mt-1">Top Stack</span>
        </div>
        <div class="flex flex-col text-center gap-1 border-x border-white/5 mx-2 px-2">
            <span class="text-[14px] sm:text-[15px] font-semibold text-white/90">~{estimatedHours.toLocaleString()}h</span>
            <span class="text-[9px] sm:text-[10px] tracking-[0.1em] font-mono uppercase text-main/40 mt-1">Est. Hours</span>
        </div>
        <div class="flex flex-col text-center sm:text-right gap-1">
            <span class="text-[14px] sm:text-[15px] font-semibold text-white/90">{totalRepos}</span>
            <span class="text-[9px] sm:text-[10px] tracking-[0.1em] font-mono uppercase text-main/40 mt-1">Total Repos</span>
        </div>
    </div>
</div>
