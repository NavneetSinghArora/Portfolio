---
// LiveCodingBadge.astro
// Queries GitHub API for Navneet's and Repath's open source metrics.

const accounts = ['NavneetSinghArora', 'Navneet-Repath'];
let totalRepos = 0;
let totalSizeKb = 0;
let languageWeights: Record<string, number> = {};

try {
    for (const account of accounts) {
        // Fetch up to 100 repositories sequentially for each account
        const res = await fetch(`https://api.github.com/users/${account}/repos?per_page=100`, {
            headers: { 'User-Agent': 'Astro-Portfolio-Builder' }
        });
        
        if (res.ok) {
            const repos = await res.json();
            totalRepos += repos.length;
            
            repos.forEach((repo: any) => {
                const size = repo.size || 0;
                totalSizeKb += size;
                
                if (repo.language) {
                    // We weight by repository count instead of absolute byte size
                    // because large dataset repos (like YoloV3) can drastically skew the metric.
                    languageWeights[repo.language] = (languageWeights[repo.language] || 0) + 1;
                }
            });
        }
    }
} catch (e) {
    console.error("Failed to fetch Github Stats", e);
}

// Heuristics:
// 1 KB of repository size is roughly ~12 lines of code (conservative estimate accounting for assets)
// Let's assume an average coding speed of 80 lines of code per hour.
const totalLoc = totalSizeKb * 12;
const estimatedHours = Math.floor(totalLoc / 80);

// Compute top 3 languages
const top3Languages = Object.entries(languageWeights)
    .sort((a, b) => b[1] - a[1])
    .map(([lang]) => lang === 'Jupyter Notebook' ? 'Jupyter' : lang)
    .slice(0, 3);
---

<div class="relative w-full max-w-md rounded-[24px] border border-white/10 bg-[#121212]/80 backdrop-blur-xl p-6 shadow-2xl transition-all duration-300 hover:border-white/20 mt-8 mb-4 group">
    <div class="flex items-start gap-4 mb-2">
        <!-- Purple GitHub Icon -->
        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-[#241b38] border border-[#3b2a5a] shadow-inner drop-shadow-md transition-transform group-hover:scale-105">
            <svg class="h-6 w-6 text-[#9f7aea]" fill="currentColor" viewBox="0 0 24 24">
