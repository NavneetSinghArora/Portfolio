---
const testimonials = [
    {
        quote: "Navneet is the type of developer we like working with. He knows his stuff, is responsive, and communicable. When an error or issue popes up as is to be expected, he is quick to work towards a resolution.",
        name: "Upwork Client",
        title: "Data Scraping Application",
        initials: "UP",
        color: "from-[#14a800] to-[#0e7c00]",
    },
    {
        quote: "Navneet was responsible for creating some test programming for us in Python and Java for internal use. He was very easy to work with, and responsive. Clear and concise communication is important to our organization.",
        name: "Upwork Client",
        title: "Python & Java Web Development",
        initials: "UP",
        color: "from-[#14a800] to-[#0e7c00]",
    },
    {
        quote: "Navneet brings an exceptional blend of technical expertise and reliable execution. His work on data structuring and backend systems has consistently proven invaluable.",
        name: "LinkedIn Colleague",
        title: "Professional Connection",
        initials: "IN",
        color: "from-[#0a66c2] to-[#004182]",
    },
];
---

<div class="mb-16 sm:mb-24" data-nn-layer="testimonials">
    <div class="mb-10 flex items-baseline justify-between">
        <div>
            <p class="mb-2 text-[11px] font-mono uppercase tracking-[0.2em] text-main/35">03 ——</p>
            <h2 class="font-serif text-2xl sm:text-3xl font-bold">What Colleagues Say</h2>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-3">
        {testimonials.map(t => (
            <div class="spotlight-card group relative flex flex-col gap-5 p-6">
                <div class="spotlight-glow"></div>

                <!-- Quote mark -->
                <svg class="w-6 h-6 text-main/15" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.338-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.338-3.996 5.849h3.983v10h-9.983z"/>
                </svg>

                <p class="flex-1 text-sm leading-relaxed text-main/75 font-serif italic">"{t.quote}"</p>

                <div class="flex items-center gap-3 pt-1 border-t border-main-border/10">
                    <div class={`flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-gradient-to-br ${t.color} text-[11px] font-bold text-white`}>
                        {t.initials}
                    </div>
                    <div>
                        <p class="text-sm font-semibold text-main">{t.name}</p>
                        <p class="text-[11px] text-main/45">{t.title}</p>
                    </div>
                </div>
            </div>
        ))}
    </div>
</div>
