---
import { Image } from "astro:assets";
import anupamImage from "../assets/images/anupam-awal.jpeg";
import sameerImage from "../assets/images/sameer-makadia.jpeg";
import shilpaImage from "../assets/images/shilpa-banchor.jpeg";

const testimonials = [
    {
        quote: "Navneet works as a Full Stack Developer and leads most of the development activities in the team. He is really good at his work and takes on new challenges and roles positively. A quick learner and brilliant at managing tasks at hand — he assumed the role of Scrum Master as well, and proactively worked with other teams when required. It is a pleasant experience to work with Navneet.",
        name: "Anupam Awal",
        title: "Associate Manager @ Numerator",
        source: "LinkedIn",
        initials: "AA",
        color: "from-blue-500 to-indigo-600",
        image: anupamImage,
    },
    {
        quote: "Navneet is a full stack developer who works on multiple technologies and completes tasks with full ownership and responsibility. He is one of the quickest learners and excels from rookie to specialist very quickly. A great thinker who develops out-of-the-box solutions. He goes out of his way to help the team. Happiest to work with Navneet.",
        name: "Sameer Makadia",
        title: "Tech Manager @ Nice Ltd.",
        source: "LinkedIn",
        initials: "SM",
        color: "from-violet-500 to-purple-600",
        image: sameerImage,
    },
    {
        quote: "Navneet worked as a full stack developer and really impressed team the way he took responsibilities. In this short span of time he managed to work as a scrum master as well. He helped us  a lot. Thank you Navneet for your great support.",
        name: "Shilpa Banchhor",
        title: "AVP @ Barclays",
        source: "LinkedIn",
        initials: "SB",
        color: "from-emerald-500 to-teal-600",
        image: shilpaImage,
    },
    {
        quote: "Navneet is the type of developer we like working with. He knows his stuff, is responsive, and communicable. When an error or issue pops up — as is to be expected — he is quick to work towards a resolution.",
        name: "Upwork Client",
        title: "Python Automation Project · ★★★★★",
        source: "Upwork",
        initials: "★",
        color: "from-amber-500 to-orange-500",
    },
    {
        quote: "This is not our first time working with Navneet. We had hired him for some coding work previously and were happy to hire him once again to complete additional tasks. He is easy to work with and we appreciate his coding skills.",
        name: "Upwork Client",
        title: "Web Development Project · ★★★★★",
        source: "Upwork",
        initials: "★",
        color: "from-emerald-500 to-teal-600",
    },
];
---

<div class="mb-16 sm:mb-24" data-nn-layer="testimonials">
    <div class="mb-10 flex items-baseline justify-between">
        <div>
            <p class="mb-2 text-[11px] font-mono uppercase tracking-[0.2em] text-main/35">03 ——</p>
            <h2 class="font-serif text-2xl sm:text-3xl font-bold">What Colleagues Say</h2>
        </div>
        <div class="flex items-center gap-2">
            <span class="flex h-2 w-2 rounded-full bg-emerald-400 animate-pulse"></span>
            <span class="text-[10px] font-mono text-main/40 uppercase tracking-widest">Verified</span>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
        {testimonials.map(t => (
            <div class="spotlight-card group relative flex flex-col gap-5 p-6">
                <div class="spotlight-glow"></div>

                <div class="flex items-start justify-between">
                    <svg class="w-6 h-6 text-main/15" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.338-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.338-3.996 5.849h3.983v10h-9.983z"/>
                    </svg>
                    <span class={`text-[9px] font-mono uppercase tracking-widest px-2 py-0.5 rounded-full border ${t.source === 'LinkedIn' ? 'border-blue-500/20 text-blue-400/70 bg-blue-500/5' : 'border-amber-500/20 text-amber-400/70 bg-amber-500/5'}`}>
                        {t.source}
                    </span>
                </div>

                <p class="flex-1 text-sm leading-relaxed text-main/75 font-serif italic">"{t.quote}"</p>

                <div class="flex items-center gap-3 pt-3 border-t border-main-border/10">
                    {t.image ? (
                        <Image src={t.image} alt={t.name} class="h-9 w-9 shrink-0 rounded-full object-cover" width={36} height={36} />
                    ) : (
                        <div class={`flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-gradient-to-br ${t.color} text-[12px] font-bold text-white`}>
                            {t.initials}
                        </div>
                    )}
                    <div>
                        <p class="text-sm font-semibold text-main">{t.name}</p>
                        <p class="text-[11px] text-main/45">{t.title}</p>
                    </div>
                </div>
            </div>
        ))}
    </div>
</div>
