---
import siteConfig from '../data/site-config';
import CustomImage from './CustomImage.astro';
import QuickConnect from './QuickConnect.astro';

// Dynamically import all logos from src/assets/icons to ensure they are bundled correctly
const logos = import.meta.glob<{ default: ImageMetadata }>('/src/assets/icons/*.{svg,png,webp,jpg,jpeg}', { eager: true });

function resolveIcon(name: string | undefined) {
    if (!name) return '';
    if (name.startsWith('http')) return name;
    
    const extensions = ['.svg', '.png', '.webp', '.jpg', '.jpeg'];
    for (const ext of extensions) {
        const path = `/src/assets/icons/${name}${ext}`;
        const asset = logos[path];
        if (asset) {
            return (asset.default as any)?.src || asset.default || asset;
        }
    }
    return '';
}

const titleClass = 'text-theme-foreground font-serif text-3xl leading-tight font-medium sm:text-4xl lg:text-5xl';
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '/index.html';
---

<header class={`relative mx-auto flex w-full max-w-3xl flex-col items-center text-center gap-6 ${isHome ? 'min-h-[calc(100vh-8rem)] justify-center mb-8' : 'mb-12 sm:mb-16'}`}>
    {
        siteConfig.avatar?.src && (
            <a href="/" class="mb-2">
                <CustomImage
                    class="aspect-square w-32 rounded-full object-cover sm:w-40 shadow-xl ring-2 ring-main-border/10 transition-transform duration-500 hover:scale-105"
                    {...siteConfig.avatar}
                    loading="eager"
                    fetchpriority="high"
                    width={160}
                    height={160}
                    widths={[160, 320]}
                    sizes="160px"
                />
            </a>
        )
    }
    <div class="flex flex-col items-center w-full">
        {
            siteConfig.avatar?.src ? (
                <p class={titleClass}>{siteConfig.title}</p>
            ) : (
                <a class={titleClass} href="/">
                    {siteConfig.title}
                </a>
            )
        }
        <div class="flex flex-col items-center gap-3 mb-6">
            <p id="header-subtitle" class="text-base sm:text-lg leading-tight opacity-70 font-medium" aria-label={siteConfig.subtitle}>
                <span id="typewriter-text">{siteConfig.subtitle}</span><span id="typewriter-cursor" class="inline-block w-[2px] h-[1.1em] bg-current align-middle ml-[2px] opacity-70" aria-hidden="true"></span>
            </p>
            <div class="flex items-center gap-1.5 text-main/90 font-medium text-xs tracking-wide">
                <svg class="w-3.5 h-3.5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                <span>Hamburg, Germany</span>
            </div>
        </div>
        
        <div class="flex flex-wrap justify-center items-center gap-3">
            {siteConfig.socialLinks?.map((link) => {
                let iconName = link.text.toLowerCase();
                
                // Custom mapping for icons
                if (iconName === 'n8n creator') iconName = 'n8n';
                
                const iconPath = resolveIcon(iconName);
                
                // Handle GitHub dual icons
                const isGithub = iconName === 'github';
                const isResume = iconName === 'resume';
                const resumeIcon = 'https://img.icons8.com/color/48/parse-from-clipboard.png';
                
                return (
                    <a 
                        href={link.href} 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="group/social premium-tooltip relative flex h-10 w-10 sm:h-12 sm:w-12 items-center justify-center transition-all duration-300 hover:scale-115"
                        data-tooltip={link.text}
                    >
                        <div class="absolute inset-0 rounded-xl bg-main/5 opacity-0 transition-all duration-300 group-hover/social:opacity-100 group-hover/social:scale-110 group-hover/social:bg-main/10 ring-1 ring-main/10"></div>
                        
                        {isGithub ? (
                            <>
                                <img src={resolveIcon('github-dark')} alt="" width="24" height="24" class="relative z-10 h-6 w-6 sm:h-7 sm:w-7 opacity-90 transition-all dark:hidden" />
                                <img src={resolveIcon('github-light')} alt="" width="24" height="24" class="relative z-10 hidden h-6 w-6 sm:h-7 sm:w-7 opacity-90 transition-all dark:block" />
                            </>
                        ) : isResume ? (
                            <img src={resumeIcon} alt="" width="24" height="24" class="relative z-10 h-6 w-6 sm:h-7 sm:w-7 opacity-90 transition-all" />
                        ) : (
                            <img src={iconPath} alt="" width="24" height="24" class="relative z-10 h-6 w-6 sm:h-7 sm:w-7 opacity-90 transition-all" />
                        )}
                    </a>
                )
            })}
            <div class="flex items-center ml-2">
                <QuickConnect />
            </div>
        </div>
    </div>
    
    {isHome && (
        <div id="scroll-indicator" class="absolute bottom-4 left-1/2 -translate-x-1/2 animate-bounce flex flex-col items-center gap-2 opacity-50 transition-opacity duration-500 hover:opacity-100">
            <span class="text-[10px] sm:text-xs uppercase tracking-[0.2em] font-medium opacity-70">Explore More</span>
            <svg class="w-5 h-5 text-main/80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
        </div>
    )}
</header>

<script>
    function sleep(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }

    async function initTypewriter() {
        const textEl = document.getElementById('typewriter-text');
        const cursor = document.getElementById('typewriter-cursor');
        if (!textEl || !cursor) return;

        const phrases = [
            'Machine Learning & Full Stack Engineer',
            'AI Systems Architect',
            'n8n Creator & Workflow Automator',
            'Climate Tech Builder',
            'Backend Systems Engineer',
        ];

        // Ensure blink uses CSS for perfect hardware-accelerated timing
        cursor.style.animation = 'blink 1s step-end infinite';
        
        // Add the keyframes if they don't exist
        if (!document.getElementById('typewriter-style')) {
            const style = document.createElement('style');
            style.id = 'typewriter-style';
            style.innerHTML = `
                @keyframes blink {
                    0%, 100% { opacity: 1; }
                    50% { opacity: 0; }
                }
            `;
            document.head.appendChild(style);
        }

        let phraseIdx = 0;
        let isRunning = true;

        // Cleanup handler for Astro view transitions
        document.addEventListener('astro:before-swap', () => { isRunning = false; }, { once: true });

        // Initial hold
        await sleep(3000);

        while (isRunning) {
            const current = phrases[phraseIdx];
            
            // Delete current word
            while (textEl.textContent?.length !== 0 && isRunning) {
                textEl.textContent = current.slice(0, textEl.textContent.length - 1);
                await sleep(30); // Fast delete
            }
            
            if (!isRunning) break;
            
            // Move to next word
            phraseIdx = (phraseIdx + 1) % phrases.length;
            const next = phrases[phraseIdx];
            
            // Type next word
            for (let i = 1; i <= next.length && isRunning; i++) {
                textEl.textContent = next.slice(0, i);
                await sleep(60); // Natural typing speed
            }
            
            if (!isRunning) break;
            
            // Hold the word
            await sleep(3000);
        }
    }

    initTypewriter();
    document.addEventListener('astro:page-load', initTypewriter);

    function scrollHandler() {
        const indicator = document.getElementById('scroll-indicator');
        if (!indicator) return;
        
        if (window.scrollY > 50) {
            indicator.style.opacity = '0';
            indicator.style.pointerEvents = 'none';
        } else {
            indicator.style.opacity = '0.5';
            indicator.style.pointerEvents = 'auto';
        }
    }
    
    // Attach listener
    window.addEventListener('scroll', scrollHandler, { passive: true });
    
    // Check initial state
    scrollHandler();
</script>
