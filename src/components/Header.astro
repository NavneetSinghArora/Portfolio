---
import siteConfig from '../data/site-config';
import CustomImage from './CustomImage.astro';

// Dynamically import all logos from src/assets/icons to ensure they are bundled correctly
const logos = import.meta.glob<{ default: ImageMetadata }>('/src/assets/icons/*.{svg,png,webp,jpg,jpeg}', { eager: true });

function resolveIcon(name: string | undefined) {
    if (!name) return '';
    if (name.startsWith('http')) return name;
    
    const extensions = ['.svg', '.png', '.webp', '.jpg', '.jpeg'];
    for (const ext of extensions) {
        const path = `/src/assets/icons/${name}${ext}`;
        const asset = logos[path];
        if (asset) {
            return (asset.default as any)?.src || asset.default || asset;
        }
    }
    return '';
}

const titleClass = 'text-theme-foreground font-serif text-2xl leading-tight font-medium sm:text-3xl';
---

<header class="mx-auto mb-12 flex w-full max-w-3xl items-center gap-4 sm:mb-16">
    {
        siteConfig.avatar?.src && (
            <a href="/">
                <CustomImage
                    class="aspect-square w-16 rounded-full object-cover sm:w-20"
                    {...siteConfig.avatar}
                    loading="eager"
                    fetchpriority="high"
                    width={80}
                    height={80}
                    widths={[80, 160]}
                    sizes="80px"
                />
            </a>
        )
    }
    <div class="grow">
        {
            siteConfig.avatar?.src ? (
                <p class={titleClass}>{siteConfig.title}</p>
            ) : (
                <a class={titleClass} href="/">
                    {siteConfig.title}
                </a>
            )
        }
        {siteConfig.subtitle && <p class="text-sm leading-tight opacity-70 mb-3">{siteConfig.subtitle}</p>}
        
        <div class="flex gap-4">
            {siteConfig.socialLinks?.map((link) => {
                const iconName = link.text.toLowerCase();
                const iconPath = resolveIcon(iconName);
                
                // Handle GitHub dual icons
                const isGithub = iconName === 'github';
                const isResume = iconName === 'resume';
                const resumeIcon = 'https://img.icons8.com/color/48/parse-from-clipboard.png';
                
                return (
                    <a 
                        href={link.href} 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="group/social relative flex items-center justify-center transition-all duration-300 hover:-translate-y-0.5"
                        title={link.text}
                    >
                        <div class="absolute -inset-2 rounded-full bg-main-bg/5 opacity-0 transition-opacity group-hover/social:opacity-100"></div>
                        
                        {isGithub ? (
                            <>
                                <img src={resolveIcon('github-dark')} alt="" width="20" height="20" class="h-5 w-5 opacity-60 transition-opacity group-hover/social:opacity-100 dark:hidden" />
                                <img src={resolveIcon('github-light')} alt="" width="20" height="20" class="hidden h-5 w-5 opacity-60 transition-opacity group-hover/social:opacity-100 dark:block" />
                            </>
                        ) : isResume ? (
                            <img src={resumeIcon} alt="" width="24" height="24" class="h-6 w-6 opacity-80 transition-opacity group-hover/social:opacity-100" />
                        ) : (
                            <img src={iconPath} alt="" width="20" height="20" class="h-5 w-5 opacity-60 transition-opacity group-hover/social:opacity-100" />
                        )}
                    </a>
                )
            })}
        </div>
    </div>
</header>
