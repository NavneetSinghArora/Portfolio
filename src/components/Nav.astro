---
import NavLink from './NavLink.astro';
import ThemeToggle from './ThemeToggle.astro';
import siteConfig from '../data/site-config';

const navLinks = siteConfig.headerNavLinks ?? [];
---

<nav id="main-nav" class="fixed top-6 left-1/2 -translate-x-1/2 z-[999] w-fit px-4 pointer-events-none" aria-label="Primary navigation">
    <div id="nav-container" class="relative rounded-2xl border border-main-border/10 bg-main-bg/40 backdrop-blur-xl shadow-lg transition-all duration-500 overflow-hidden flex items-center gap-2 p-1.5 ring-1 ring-white/5 dark:ring-white/10 pointer-events-auto">
        <!-- Desktop Nav -->
        <ul class="hidden md:flex items-center gap-1">
            {navLinks.map((link) => (
                <li>
                    <NavLink
                        class="px-5 py-2.5 rounded-xl text-sm font-medium text-main transition-all duration-300 block hover:bg-main-bg/10"
                        href={link.href}
                        target={link.target}
                    >
                        {link.text}
                    </NavLink>
                </li>
            ))}
        </ul>

        <!-- Mobile Toggle Wrapper -->
        <div class="md:hidden flex items-center">
            <button
                class="menu-toggle relative z-30 flex h-9 w-9 cursor-pointer items-center justify-center rounded-xl hover:bg-main-bg/10 transition-colors"
                aria-label="Open Menu"
                aria-expanded="false"
                aria-controls="menu-items"
            >
                <span class="menu-toggle-icon relative h-px w-5 bg-current" />
            </button>
        </div>

        <div class="w-px h-5 bg-main-border/10 mx-1"></div>

        <!-- Theme Toggle Wrapper -->
        <div class="flex items-center px-1">
            <ThemeToggle />
        </div>
    </div>

    <!-- Mobile Menu (Floating Panel) -->
    <ul
        id="menu-items"
        class="menu mt-3 invisible opacity-0 scale-95 translate-y-2 flex flex-col gap-1 p-2 rounded-2xl border border-main-border/10 bg-main-bg/80 backdrop-blur-xl shadow-2xl transition-all duration-300 origin-top pointer-events-none"
    >
        {navLinks.map((link) => (
            <li>
                <NavLink
                    class="px-4 py-3 rounded-xl text-base font-medium text-main/70 hover:text-main hover:bg-main-bg/10 transition-all duration-300 block"
                    href={link.href}
                    target={link.target}
                >
                    {link.text}
                </NavLink>
            </li>
        ))}
    </ul>
</nav>

<style>
    @reference "tailwindcss";

    .menu.is-visible {
        @apply visible opacity-100 scale-100 translate-y-0 pointer-events-auto;
    }

    .menu-toggle-icon {
        transition: width 0.15s ease-out;
    }
    
    .menu-toggle.is-active .menu-toggle-icon {
        @apply w-0;
    }
    
    .menu-toggle-icon:before,
    .menu-toggle-icon:after {
        @apply absolute left-1/2 h-px w-5 origin-center -translate-x-1/2 bg-current;
        content: '';
        transition: transform 0.3s ease, margin 0.3s ease;
    }
    
    .menu-toggle-icon:before {
        @apply -mt-1.5;
    }
    
    .menu-toggle-icon:after {
        @apply mt-1.5;
    }
    
    .menu-toggle.is-active .menu-toggle-icon:before {
        @apply mt-0 rotate-45;
    }
    
    .menu-toggle.is-active .menu-toggle-icon:after {
        @apply mt-0 -rotate-45;
    }
</style>

<script>
    function initNav() {
        const menu = document.getElementById('menu-items');
        const menuToggleBtn = document.querySelector('.menu-toggle');

        menuToggleBtn?.addEventListener('click', () => {
            const isMenuExpanded = menuToggleBtn.getAttribute('aria-expanded') === 'true';
            menuToggleBtn.classList.toggle('is-active');
            menuToggleBtn.setAttribute('aria-expanded', isMenuExpanded ? 'false' : 'true');
            menuToggleBtn.setAttribute('aria-label', isMenuExpanded ? 'Open Menu' : 'Close Menu');
            menu?.classList.toggle('is-visible');
        });

        // Close menu on click outside
        document.addEventListener('click', (e) => {
            if (menu?.classList.contains('is-visible') && !menu.contains(e.target as Node) && !menuToggleBtn?.contains(e.target as Node)) {
                menuToggleBtn?.classList.remove('is-active');
                menuToggleBtn?.setAttribute('aria-expanded', 'false');
                menu?.classList.remove('is-visible');
            }
        });
    }

    initNav();
    document.addEventListener('astro:after-swap', initNav);
</script>
