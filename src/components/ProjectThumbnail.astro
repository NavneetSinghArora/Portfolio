---
import { type CollectionEntry } from 'astro:content';
import CustomImage from './CustomImage.astro';

type Props = { project: CollectionEntry<'projects'>; class?: string };

const { project, class: className } = Astro.props;
const { title, description, seo } = project.data;
const image = seo?.image;
const npmPackageName = project.data.npm
    ? project.data.npm.split('/package/')[1]?.split('/')[0]
    : null;
---

<div class:list={['project-card spotlight-card group block relative flex flex-col p-4', className]}>
    <div class="spotlight-glow"></div>
    <!-- Base Link Overlay -->
    <a href={`/projects/${project.id}/`} class="absolute inset-0 z-10" aria-label={`View ${title}`}></a>

    <div class="relative z-1 aspect-video w-full overflow-hidden rounded-xl border border-main-border/5 bg-main-bg/10 mb-4">
        {image ? (
            <CustomImage
                src={image.src}
                alt={image.alt || title}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                width={600}
                height={337}
            />
        ) : npmPackageName ? (
            <div class="flex h-full w-full flex-col items-center justify-center gap-3 bg-[#0f0f1a] px-4 py-6">
                <span class="inline-flex items-center gap-1.5 rounded-full border border-[#CB3837]/40 bg-[#CB3837]/10 px-3 py-1 text-[10px] font-mono font-bold text-[#CB3837] tracking-widest uppercase">
                    <img src="https://cdn.simpleicons.org/npm/CB3837" class="h-3 w-3" alt="" />
                    npm
                </span>
                <span class="font-mono text-lg font-bold text-white/90 tracking-tight">{npmPackageName}</span>
                <span class="font-mono text-[11px] text-emerald-400/80 bg-white/5 rounded-lg px-3 py-1.5 border border-white/5">
                    <span class="text-white/30">$ </span>npm i {npmPackageName}
                </span>
            </div>
        ) : (
            <div class="flex h-full w-full items-center justify-center text-main/55 text-xs">No preview</div>
        )}
    </div>
    
    <div class="relative z-1 flex-grow">
        <h3 class="font-serif text-base font-bold leading-tight line-clamp-2 py-0.5 mb-2 text-main">
            <span class="premium-line-hover">{title}</span>
        </h3>
        {description && <p class="text-xs text-main/90 line-clamp-2 mb-3 leading-relaxed font-sans">{description}</p>}
        {project.data.tags && project.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-1 mb-3">
                {project.data.tags.slice(0, 3).map((tag: string) => (
                    <span class="px-2 py-0.5 text-[9px] font-mono font-medium rounded-full border border-main-border/20 bg-main/5 text-main/50 tracking-wide">{tag}</span>
                ))}
            </div>
        )}
    </div>
    
    <!-- Card Meta -->
    <div class="relative z-10 mt-auto flex items-center justify-between pt-3 border-t border-main-border/5">
        <div class="flex items-center gap-3">
            {project.data.github && (
                <a href={project.data.github} target="_blank" rel="noopener noreferrer" class="group/icon premium-tooltip relative z-20 flex h-7 w-7 items-center justify-center transition-all duration-300 hover:scale-115" data-tooltip="GitHub Repository">
                    <div class="absolute inset-0 rounded-lg bg-main/10 ring-1 ring-main/20 transition-all duration-300 group-hover/icon:scale-110 group-hover/icon:bg-main/15 group-hover/icon:ring-main/30"></div>
                    <img src="https://cdn.simpleicons.org/github" class="h-3.5 w-3.5 dark:hidden relative z-10 opacity-70 group-hover/icon:opacity-100" alt="GitHub" />
                    <img src="https://cdn.simpleicons.org/github/white" class="h-3.5 w-3.5 hidden dark:block relative z-10 opacity-70 group-hover/icon:opacity-100" alt="GitHub" />
                </a>
            )}
            {project.data.npm && (
                <a href={project.data.npm} target="_blank" rel="noopener noreferrer" class="group/icon premium-tooltip relative z-20 flex h-7 w-7 items-center justify-center transition-all duration-300 hover:scale-115" data-tooltip="npm Package">
                    <div class="absolute inset-0 rounded-lg bg-main/10 ring-1 ring-main/20 transition-all duration-300 group-hover/icon:scale-110 group-hover/icon:bg-main/15 group-hover/icon:ring-main/30"></div>
                    <img src="https://cdn.simpleicons.org/npm/CB3837" class="h-3 w-3 relative z-10 opacity-70 group-hover/icon:opacity-100" alt="npm" />
                </a>
            )}
            {project.data.paper && (
                <a href={project.data.paper} target="_blank" rel="noopener noreferrer" class="group/icon premium-tooltip relative z-20 flex h-7 w-7 items-center justify-center transition-all duration-300 hover:scale-115" data-tooltip={project.data.paper.includes('kaggle.com') ? "Kaggle Competition" : "Research/Project Document"}>
                    <div class="absolute inset-0 rounded-lg bg-main/10 ring-1 ring-main/20 transition-all duration-300 group-hover/icon:scale-110 group-hover/icon:bg-main/15 group-hover/icon:ring-main/30"></div>
                    {project.data.paper.includes('kaggle.com') ? (
                        <div class="flex items-center relative z-10 opacity-70 group-hover/icon:opacity-100">
                            <img src="https://cdn.simpleicons.org/kaggle" class="h-3.5 w-3.5 dark:hidden" alt="Kaggle" />
                            <img src="https://cdn.simpleicons.org/kaggle/white" class="h-3.5 w-3.5 hidden dark:block" alt="Kaggle" />
                        </div>
                    ) : (
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5 relative z-10 opacity-70 group-hover/icon:opacity-100"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                    )}
                </a>
            )}
            {project.data.demo && (
                <a href={project.data.demo} target="_blank" rel="noopener noreferrer" class="group/icon premium-tooltip relative z-20 flex h-7 w-7 items-center justify-center transition-all duration-300 hover:scale-115" data-tooltip="Live Demo">
                    <div class="absolute inset-0 rounded-lg bg-main/10 ring-1 ring-main/20 transition-all duration-300 group-hover/icon:scale-110 group-hover/icon:bg-main/15 group-hover/icon:ring-main/30"></div>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5 relative z-10 opacity-70 group-hover/icon:opacity-100"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                </a>
            )}
            {project.data.external && (
                <a href={project.data.external} target="_blank" rel="noopener noreferrer" class="group/icon premium-tooltip relative z-20 flex h-7 w-7 items-center justify-center transition-all duration-300 hover:scale-115" data-tooltip={project.data.tags?.includes('n8n') ? "View n8n Workflow" : "External Link"}>
                    <div class="absolute inset-0 rounded-lg bg-main/10 ring-1 ring-main/20 transition-all duration-300 group-hover/icon:scale-110 group-hover/icon:bg-main/15 group-hover/icon:ring-main/30"></div>
                    {project.data.tags?.includes('n8n') ? (
                        <div class="flex items-center relative z-10 opacity-70 group-hover/icon:opacity-100">
                            <img src="https://cdn.simpleicons.org/n8n" class="h-3.5 w-3.5 dark:hidden" alt="n8n" />
                            <img src="https://cdn.simpleicons.org/n8n/white" class="h-3.5 w-3.5 hidden dark:block" alt="n8n" />
                        </div>
                    ) : (
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5 relative z-10 opacity-70 group-hover/icon:opacity-100"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                    )}
                </a>
            )}
        </div>
        <span class="text-[10px] font-bold uppercase tracking-widest text-main/40 pointer-events-none">{project.data.publishDate.getFullYear()}</span>
    </div>
</div>
