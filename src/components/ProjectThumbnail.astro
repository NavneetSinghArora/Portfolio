---
import { type CollectionEntry } from 'astro:content';
import CustomImage from './CustomImage.astro';

type Props = { project: CollectionEntry<'projects'>; class?: string };

const { project, class: className } = Astro.props;
const { title, description, seo } = project.data;
const image = seo?.image;
---

<a class:list={['group block overflow-hidden rounded-2xl border border-main-border/10 bg-main-bg/5 transition-all duration-500 hover:border-main-border/20 hover:bg-main-bg/10', className]} href={`/projects/${project.id}/`}>
    <div class="aspect-video w-full overflow-hidden">
        {image ? (
            <CustomImage 
                src={image.src} 
                alt={image.alt || title} 
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                width={600}
                height={337}
            />
        ) : (
            <div class="flex h-full w-full items-center justify-center bg-main-bg/10 text-main/40 italic text-sm">
                No preview available
            </div>
        )}
    </div>
    <div class="p-4">
        <h3 class="font-serif text-lg font-medium leading-tight group-hover:underline group-hover:decoration-dashed group-hover:decoration-1 group-hover:underline-offset-4">
            {title}
        </h3>
        {description && <p class="mt-2 text-sm text-main/60 line-clamp-2 leading-relaxed">{description}</p>}
    </div>
</a>
