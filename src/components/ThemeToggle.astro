<button id="theme-toggle" class="relative group h-9 w-9 flex items-center justify-center rounded-xl border border-main-border/20 bg-main-bg/20 backdrop-blur-md hover:border-main-border/40 hover:bg-main-bg/40 transition-all duration-300 shadow-sm" aria-label="Toggle color scheme">
    <div class="relative h-5 w-5">
        <!-- Sun Icon -->
        <svg 
            xmlns="http://www.w3.org/2000/svg" 
            viewBox="0 0 24 24" 
            fill="none" 
            stroke="currentColor" 
            stroke-width="2" 
            stroke-linecap="round" 
            stroke-linejoin="round" 
            class="sun-icon absolute inset-0 transition-all duration-500 transform rotate-0 scale-100 dark:-rotate-90 dark:opacity-0 dark:scale-0 text-amber-600 group-hover:text-amber-700"
        >
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2"></path>
            <path d="M12 20v2"></path>
            <path d="m4.93 4.93 1.41 1.41"></path>
            <path d="m17.66 17.66 1.41 1.41"></path>
            <path d="M2 12h2"></path>
            <path d="M20 12h2"></path>
            <path d="m6.34 17.66-1.41 1.41"></path>
            <path d="m19.07 4.93-1.41 1.41"></path>
        </svg>
        <!-- Moon Icon -->
        <svg 
            xmlns="http://www.w3.org/2000/svg" 
            viewBox="0 0 24 24" 
            fill="none" 
            stroke="currentColor" 
            stroke-width="2" 
            stroke-linecap="round" 
            stroke-linejoin="round" 
            class="moon-icon absolute inset-0 transition-all duration-500 transform rotate-90 opacity-0 scale-0 dark:rotate-0 dark:opacity-100 dark:scale-100 text-indigo-300/90 group-hover:text-indigo-400"
        >
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
        </svg>
    </div>
</button>
