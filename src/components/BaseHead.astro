---
import { getImage } from 'astro:assets';
import siteConfig from '../data/site-config';
import type { ImageInput } from '../types';

import '../styles/global.css';

export type Props = {
    title?: string;
    description?: string;
    image?: ImageInput | undefined;
    pageType?: 'website' | 'article';
    publishDate?: Date | string;
};

const { description = '', pageType = 'website' } = Astro.props;
const title = [Astro.props.title, siteConfig.title].filter(Boolean).join(' | ');
const image = Astro.props.image ?? siteConfig.image;
let resolvedImage: { src: string; alt?: string } | undefined;

if (image?.src) {
    if (typeof image.src === 'string') {
        resolvedImage = {
            src: new URL(image.src, Astro.site).toString(),
            alt: image.alt || title
        };
    } else {
        const optimizedImage = await getImage({
            src: image.src as ImageMetadata,
            width: 1200,
            height: 630,
            format: 'jpeg',
            fit: 'cover'
        });
        resolvedImage = {
            src: new URL(optimizedImage.src, Astro.site).toString(),
            alt: image.alt || title
        };
    }
}
const canonicalURL = new URL(Astro.request.url, Astro.site);
const publishDate = (Astro.props as any).publishDate;

/**
 * Enforce some standard canonical URL formatting across the site.
 */
function formatCanonicalURL(url: string | URL) {
    const path = url.toString();
    const hasQueryParams = path.includes('?');
    if (hasQueryParams) {
        return path.replace(/\/?$/, '');
    }
    return path.replace(/\/?$/, '/');
}

const isProject = Astro.url.pathname.startsWith('/projects/') && Astro.url.pathname !== '/projects/';
const isBlog = Astro.url.pathname.startsWith('/blog/') && Astro.url.pathname !== '/blog/';
---

<!-- High Priority Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{title}</title>
<meta name="generator" content={Astro.generator} />
<meta name="author" content={siteConfig.title} />
{siteConfig.keywords && <meta name="keywords" content={siteConfig.keywords.join(', ')} />}
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<meta name="theme-color" content="#f0f7ff" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#171717" media="(prefers-color-scheme: dark)" />

<!-- Fonts — load stylesheet directly (avoids render-blocking @import in CSS) -->
<link rel="preconnect" href="https://api.fontshare.com" crossorigin />
<link rel="dns-prefetch" href="https://api.fontshare.com" />
<link rel="stylesheet" href="https://api.fontshare.com/v2/css?f[]=satoshi@700,500,400&display=swap" />

<!-- Icons -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" href="/rss.xml" title="RSS" />

<!-- Page Metadata -->
<link rel="canonical" href={formatCanonicalURL(canonicalURL)} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={isBlog ? 'article' : 'website'} />
<meta property="og:url" content={formatCanonicalURL(canonicalURL)} />
<meta property="og:title" content={title} />
<meta property="og:site_name" content={siteConfig.title} />
<meta property="og:locale" content="en_US" />
{description && <meta property="og:description" content={description} />}
{resolvedImage?.src && <meta property="og:image" content={resolvedImage.src} />}
{resolvedImage?.alt && <meta property="og:image:alt" content={resolvedImage.alt} />}

<!-- X/Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@navneet_singh" />
<meta name="twitter:creator" content="@navneet_singh" />
<meta name="twitter:url" content={formatCanonicalURL(canonicalURL)} />
<meta name="twitter:title" content={title} />
{description && <meta name="twitter:description" content={description} />}
{resolvedImage?.src && <meta name="twitter:image" content={resolvedImage.src} />}

<!-- JSON-LD Structured Data - Extensive Engineering Schema -->
<script is:inline type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${siteConfig.website}#person`,
      "name": siteConfig.title,
      "url": siteConfig.website,
      "image": resolvedImage?.src,
      "jobTitle": siteConfig.subtitle,
      "description": siteConfig.description,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Hamburg",
        "addressCountry": "Germany"
      },
      "knowsAbout": siteConfig.keywords,
      "sameAs": siteConfig.socialLinks?.map(link => link.href) || []
    },
    {
      "@type": "ProfessionalService",
      "@id": `${siteConfig.website}#service`,
      "name": `${siteConfig.title} - AI & Full Stack Engineering`,
      "image": resolvedImage?.src,
      "description": "Architecting high-performance intelligent automation and machine learning solutions.",
      "url": siteConfig.website,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Hamburg",
        "addressCountry": "Germany"
      },
      "priceRange": "$$$"
    },
    {
      "@type": "WebSite",
      "@id": `${siteConfig.website}#website`,
      "url": siteConfig.website,
      "name": siteConfig.title,
      "publisher": { "@id": `${siteConfig.website}#person` },
      "potentialAction": {
        "@type": "SearchAction",
        "target": `${siteConfig.website}/search?q={search_term_string}`,
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": isBlog ? "BlogPosting" : isProject ? "CreativeWork" : "WebPage",
      "@id": `${formatCanonicalURL(canonicalURL)}#webpage`,
      "url": formatCanonicalURL(canonicalURL),
      "name": title,
      "description": description,
      "isPartOf": { "@id": `${siteConfig.website}#website` },
      "primaryImageOfPage": resolvedImage ? { "@type": "ImageObject", "url": resolvedImage.src } : undefined,
      "breadcrumb": { "@id": `${formatCanonicalURL(canonicalURL)}#breadcrumb` },
      ...(isBlog || isProject ? {
        "headline": Astro.props.title,
        "datePublished": publishDate,
        "author": { "@id": `${siteConfig.website}#person` },
        "publisher": { "@id": `${siteConfig.website}#person` }
      } : {})
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${formatCanonicalURL(canonicalURL)}#breadcrumb`,
      "itemListElement": [
        {
           "@type": "ListItem",
           "position": 1,
           "name": "Home",
           "item": siteConfig.website
        },
        ...Astro.url.pathname.split('/').filter(Boolean).map((path, index, arr) => ({
          "@type": "ListItem",
          "position": index + 2,
          "name": path.charAt(0).toUpperCase() + path.slice(1),
          "item": new URL('/' + arr.slice(0, index + 1).join('/'), siteConfig.website).toString()
        }))
      ]
    }
  ]
})} />
