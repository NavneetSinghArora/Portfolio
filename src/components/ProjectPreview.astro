---
import { type CollectionEntry } from 'astro:content';
import IconButton from './IconButton.astro';
import SocialIcon from './SocialIcon.astro';

type Props = { project: CollectionEntry<'projects'>; class?: string; headingLevel?: 'h2' | 'h3' };

const { project, class: className, headingLevel = 'h2' } = Astro.props;
const { title, description } = project.data;
const TitleTag = headingLevel;
---

<div class:list={['project-card spotlight-card group relative flex flex-col sm:flex-row sm:items-stretch gap-6 p-6', className]}>
    <div class="spotlight-glow"></div>
    <!-- Base Link Overlay -->
    <a href={`/projects/${project.id}/`} class="absolute inset-0 z-10" aria-label={`View ${title}`}></a>

    {/* Content Section */}
    <div class="flex-1 min-w-0">
        <a href={`/projects/${project.id}/`} class="block">
            <TitleTag class="font-serif text-xl leading-tight font-bold sm:text-2xl text-main">
                <span class="premium-line-hover">{title}</span>
            </TitleTag>
            {description && <div class="mt-2 text-sm leading-relaxed text-main/90 font-sans max-w-2xl">{description}</div>}
        </a>
    </div>

    {/* Metadata Section */}
    <div class="flex flex-row sm:flex-col justify-between sm:items-end gap-4 shrink-0 pt-1 sm:border-l sm:border-main-border/10 sm:pl-8">
        <div class="text-[11px] font-bold tracking-[0.2em] text-main/40 uppercase font-sans">
            YEAR {project.data.publishDate.getFullYear()}
        </div>

        <div class="flex items-center gap-1.5 px-1 sm:px-0 z-20">
            {project.data.github && (
                <IconButton href={project.data.github} target="_blank" rel="noopener noreferrer" size="md" tooltip="GitHub">
                    <SocialIcon name="github" />
                </IconButton>
            )}
            {project.data.npm && (
                <IconButton href={project.data.npm} target="_blank" rel="noopener noreferrer" size="md" tooltip="npm Package">
                    <SocialIcon name="npm" />
                </IconButton>
            )}
            {project.data.paper && (
                <IconButton href={project.data.paper} target="_blank" rel="noopener noreferrer" size="md" tooltip={project.data.paper.includes('kaggle.com') ? 'Kaggle Competition' : 'Research/Project Document'}>
                    <SocialIcon name={project.data.paper.includes('kaggle.com') ? 'kaggle' : 'paper'} />
                </IconButton>
            )}
            {project.data.demo && (
                <IconButton href={project.data.demo} target="_blank" rel="noopener noreferrer" size="md" tooltip="Live Demo">
                    <SocialIcon name="demo" />
                </IconButton>
            )}
            {project.data.external && (
                <IconButton href={project.data.external} target="_blank" rel="noopener noreferrer" size="md" tooltip={project.data.tags.includes('n8n') ? 'n8n Workflows' : 'External Link'}>
                    <SocialIcon name={project.data.tags.includes('n8n') ? 'n8n' : 'external'} />
                </IconButton>
            )}
        </div>
    </div>
</div>
