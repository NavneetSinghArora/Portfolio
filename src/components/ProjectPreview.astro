---
import { type CollectionEntry } from 'astro:content';
import ArrowRight from '../assets/icons/arrow-right.svg';

type Props = { project: CollectionEntry<'projects'>; class?: string; headingLevel?: 'h2' | 'h3' };

const { project, class: className, headingLevel = 'h2' } = Astro.props;
const { title, description } = project.data;
const TitleTag = headingLevel;

---

<div class:list={['project-card spotlight-card group relative flex flex-col sm:flex-row sm:items-stretch gap-6 p-6', className]}>
    <div class="spotlight-glow"></div>
    <!-- Base Link Overlay -->
    <a href={`/projects/${project.id}/`} class="absolute inset-0 z-10" aria-label={`View ${title}`}></a>
    
    {/* Content Section */}
    <div class="flex-1 min-w-0">
        <a href={`/projects/${project.id}/`} class="block">
            <TitleTag
                class="font-serif text-xl leading-tight font-bold sm:text-2xl text-main"
            >
                <span class="premium-line-hover">{title}</span>
            </TitleTag>
            {description && <div class="mt-2 text-sm leading-relaxed text-main/90 font-sans max-w-2xl">{description}</div>}
        </a>
    </div>

    {/* Metadata Section */}
    <div class="flex flex-row sm:flex-col justify-between sm:items-end gap-4 shrink-0 pt-1 sm:border-l sm:border-main-border/10 sm:pl-8">
        <div class="text-[11px] font-bold tracking-[0.2em] text-main/40 uppercase font-sans">
            YEAR {project.data.publishDate.getFullYear()}
        </div>
        
        <div class="flex items-center gap-1.5 px-1 sm:px-0">
            {project.data.github && (
                <a 
                    href={project.data.github} 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="group/icon premium-tooltip relative z-20 flex h-8 w-8 items-center justify-center transition-all duration-300 hover:scale-115" 
                    data-tooltip="GitHub"
                >
                    <div class="absolute inset-0 rounded-xl bg-main/5 opacity-0 transition-all duration-300 group-hover/icon:opacity-100 group-hover/icon:scale-110 group-hover/icon:bg-main/10 ring-1 ring-main/10"></div>
                    <img src="https://cdn.simpleicons.org/github" class="h-3.5 w-3.5 dark:hidden opacity-70 group-hover:opacity-100 transition-all relative z-10" alt="GitHub" />
                    <img src="https://cdn.simpleicons.org/github/white" class="h-3.5 w-3.5 hidden dark:block opacity-70 group-hover:opacity-100 transition-all relative z-10" alt="GitHub" />
                </a>
            )}
            {project.data.paper && (
                <a 
                    href={project.data.paper} 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="group/icon premium-tooltip relative z-20 flex h-8 w-8 items-center justify-center transition-all duration-300 hover:scale-115" 
                    data-tooltip={project.data.paper.includes('kaggle.com') ? "Kaggle Competition" : "Research/Project Document"}
                >
                    <div class="absolute inset-0 rounded-xl bg-main/5 opacity-0 transition-all duration-300 group-hover/icon:opacity-100 group-hover/icon:scale-110 group-hover/icon:bg-main/10 ring-1 ring-main/10"></div>
                    {project.data.paper.includes('kaggle.com') ? (
                        <>
                            <img src="https://cdn.simpleicons.org/kaggle" class="relative z-10 h-5 w-5 dark:hidden" alt="Kaggle" />
                            <img src="https://cdn.simpleicons.org/kaggle/white" class="relative z-10 h-5 w-5 hidden dark:block" alt="Kaggle" />
                        </>
                    ) : (
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5 opacity-70 group-hover:opacity-100 transition-all relative z-10"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                    )}
                </a>
            )}
            {project.data.demo && (
                <a 
                    href={project.data.demo} 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="group/icon premium-tooltip relative z-20 flex h-8 w-8 items-center justify-center transition-all duration-300 hover:scale-115" 
                    data-tooltip="Live Demo"
                >
                    <div class="absolute inset-0 rounded-xl bg-main/5 opacity-0 transition-all duration-300 group-hover/icon:opacity-100 group-hover/icon:scale-110 group-hover/icon:bg-main/10 ring-1 ring-main/10"></div>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5 opacity-70 group-hover:opacity-100 transition-all relative z-10"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                </a>
            )}
            {project.data.external && (
                <a 
                    href={project.data.external} 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="group/icon premium-tooltip relative z-20 flex h-8 w-8 items-center justify-center transition-all duration-300 hover:scale-115" 
                    data-tooltip={project.data.tags.includes('n8n') ? "n8n Workflows" : "External Link"}
                >
                    <div class="absolute inset-0 rounded-xl bg-main/5 opacity-0 transition-all duration-300 group-hover/icon:opacity-100 group-hover/icon:scale-110 group-hover/icon:bg-main/10 ring-1 ring-main/10"></div>
                    {project.data.tags.includes('n8n') ? (
                        <>
                            <img src="https://cdn.simpleicons.org/n8n" class="relative z-10 h-5 w-5 dark:hidden" alt="n8n" />
                            <img src="https://cdn.simpleicons.org/n8n/white" class="relative z-10 h-5 w-5 hidden dark:block" alt="n8n" />
                        </>
                    ) : (
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5 opacity-70 group-hover:opacity-100 transition-all relative z-10"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                    )}
                </a>
            )}
        </div>
    </div>
</div>
