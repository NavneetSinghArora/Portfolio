---
import { type CollectionEntry } from 'astro:content';
import CustomImage from './CustomImage.astro';
import FormattedDate from './FormattedDate.astro';

type Props = { post: CollectionEntry<'blog'>; class?: string };

const { post, class: className } = Astro.props;
const { title, excerpt, publishDate, seo } = post.data;
const image = seo?.image;
---

<a class:list={['group block overflow-hidden rounded-2xl border border-main/10 bg-main/5 transition-all duration-500 hover:border-main/20 hover:bg-main/10', className]} href={`/blog/${post.id}/`}>
    <div class="aspect-[16/10] w-full overflow-hidden">
        {image ? (
            <CustomImage 
                src={image.src} 
                alt={image.alt || title} 
                class="h-full w-full object-cover grayscale transition-all duration-500 group-hover:scale-105 group-hover:grayscale-0"
                width={600}
                height={375}
            />
        ) : (
            <div class="flex h-full w-full items-center justify-center bg-main/10 text-main/40 italic text-sm">
                No preview available
            </div>
        )}
    </div>
    <div class="p-4">
        <div class="mb-2 text-[10px] uppercase tracking-widest font-bold text-main/40">
            <FormattedDate date={publishDate} />
        </div>
        <h3 class="font-serif text-lg font-medium leading-tight group-hover:underline group-hover:decoration-dashed group-hover:decoration-1 group-hover:underline-offset-4">
            {title}
        </h3>
        {excerpt && <p class="mt-3 text-sm text-main/60 line-clamp-3 leading-relaxed">{excerpt}</p>}
    </div>
</a>
