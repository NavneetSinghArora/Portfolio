---
import { getCollection } from 'astro:content';
import Button from '../components/Button.astro';
import Hero from '../components/Hero.astro';
import TechStack from '../components/TechStack.astro';
import SkillRadar from '../components/SkillRadar.astro';
import ProjectThumbnail from '../components/ProjectThumbnail.astro';
import PostThumbnail from '../components/PostThumbnail.astro';
import GithubContributions from '../components/GithubContributions.astro';
import StatsCounter from '../components/StatsCounter.astro';
import WorkedWith from '../components/WorkedWith.astro';
import Testimonials from '../components/Testimonials.astro';
import siteConfig from '../data/site-config';
import BaseLayout from '../layouts/BaseLayout.astro';
import { sortItemsByDateDesc } from '../utils/data-utils';

const posts = (await getCollection('blog')).sort(sortItemsByDateDesc);
const displayPosts = posts.slice(0, 3);

const projects = (await getCollection('projects')).sort(sortItemsByDateDesc);
const featuredProjects = projects.filter(({ data }) => data.isFeatured);
const nonFeaturedProjects = projects.filter(({ data }) => !data.isFeatured);
const displayProjects = [...featuredProjects, ...nonFeaturedProjects].slice(0, 3);
---

<BaseLayout description={siteConfig.description} showHeader={true}>
    <Hero {...siteConfig.hero} />

    <!-- Stats -->
    <StatsCounter />

    <!-- Worked With -->
    <WorkedWith />

    <!-- 01 — Tech Stack -->
    <div data-nn-layer="1">
        <div class="mb-2 flex items-center gap-3">
            <span class="text-[10px] font-mono uppercase tracking-[0.22em] text-main/30">01 ——</span>
        </div>
        {siteConfig.stack && <TechStack {...siteConfig.stack} />}
    </div>

    <!-- Skill Radar -->
    <SkillRadar />

    <!-- 02 — Contributions -->
    <div data-nn-layer="2">
        <div class="mb-2 flex items-center gap-3">
            <span class="text-[10px] font-mono uppercase tracking-[0.22em] text-main/30">02 ——</span>
        </div>
        {siteConfig.github && <GithubContributions username={siteConfig.github} />}
    </div>

    <!-- 03 — Testimonials -->
    <Testimonials />

    <!-- 04 — Featured Projects -->
    <div class="mb-16 sm:mb-24" data-nn-layer="3">
        <div class="mb-10 flex items-baseline justify-between">
            <div>
                <p class="mb-2 text-[10px] font-mono uppercase tracking-[0.22em] text-main/30">04 ——</p>
                <h2 class="font-serif text-2xl sm:text-3xl font-bold">Featured Projects</h2>
            </div>
            <a href="/projects" class="text-sm font-medium text-main/60 hover:text-main transition-colors shrink-0">
                See all →
            </a>
        </div>

        {displayProjects.length > 0 ? (
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-3">
                {displayProjects.map((project) => (
                    <ProjectThumbnail project={project} />
                ))}
            </div>
        ) : (
            <p class="text-main/60 font-serif">Project details will be updated soon.</p>
        )}
    </div>

    <!-- 05 — Recent Writing -->
    <div class="mb-16 sm:mb-24" data-nn-layer="4">
        <div class="mb-10 flex items-baseline justify-between">
            <div>
                <p class="mb-2 text-[10px] font-mono uppercase tracking-[0.22em] text-main/30">05 ——</p>
                <h2 class="font-serif text-2xl sm:text-3xl font-bold">Recent Writing</h2>
            </div>
            <a href="/blog" class="text-sm font-medium text-main/60 hover:text-main transition-colors shrink-0">
                See all →
            </a>
        </div>

        {displayPosts.length > 0 ? (
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-3">
                {displayPosts.map((post) => (
                    <PostThumbnail post={post} />
                ))}
            </div>
        ) : (
            <p class="text-main/60 font-serif">Writing will be updated soon.</p>
        )}
    </div>

    <!-- Explore — Discovery Hub -->
    <div class="mb-16 sm:mb-24" data-nn-layer="5">
        <p class="mb-6 text-[10px] font-mono uppercase tracking-[0.22em] text-main/30">Explore ——</p>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            <!-- Nexus Card -->
            <a href="/knowledge-graph" class="spotlight-card group relative block p-8 overflow-hidden rounded-2xl h-full translate-y-0 hover:-translate-y-1 transition-all duration-300">
                <div class="spotlight-glow"></div>
                <div class="flex items-center gap-3 mb-3">
                    <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-violet-500/10 text-violet-500 flex-shrink-0">
                        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <circle cx="12" cy="12" r="3"/><circle cx="4" cy="6" r="2"/><circle cx="20" cy="6" r="2"/><circle cx="4" cy="18" r="2"/><circle cx="20" cy="18" r="2"/>
                            <path d="M6 6.5l4 3.5M18 6.5l-4 3.5M6 17.5l4-3.5M18 17.5l-4-3.5" stroke-linecap="round"/>
                        </svg>
                    </div>
                    <h3 class="font-serif text-lg font-bold text-main">Nexus</h3>
                </div>
                <p class="text-sm text-main/55 leading-relaxed mb-4">A force-directed graph connecting my projects, blog posts, and technical domains into one browsable map.</p>
                <span class="inline-flex items-center gap-1.5 text-[11px] font-mono text-main/35 group-hover:text-main/60 transition-colors uppercase tracking-widest">Launch Graph →</span>
            </a>

            <!-- Stack Card -->
            <a href="/stack" class="spotlight-card group relative block p-8 overflow-hidden rounded-2xl h-full translate-y-0 hover:-translate-y-1 transition-all duration-300">
                <div class="spotlight-glow"></div>
                <div class="flex items-center gap-3 mb-3">
                    <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-blue-500/10 text-blue-500 flex-shrink-0">
                        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <path d="M2 17L12 22L22 17"/><path d="M2 12L12 17L22 12"/><path d="M12 2L2 7L12 12L22 7L12 2Z"/>
                        </svg>
                    </div>
                    <h3 class="font-serif text-lg font-bold text-main">Stack</h3>
                </div>
                <p class="text-sm text-main/55 leading-relaxed mb-4">The high-performance hardware and software ecosystem powering my daily AI research and engineering workflow.</p>
                <span class="inline-flex items-center gap-1.5 text-[11px] font-mono text-main/35 group-hover:text-main/60 transition-colors uppercase tracking-widest">View Gear →</span>
            </a>

            <!-- Now Card -->
            <a href="/now" class="spotlight-card group relative block p-8 overflow-hidden rounded-2xl h-full translate-y-0 hover:-translate-y-1 transition-all duration-300">
                <div class="spotlight-glow"></div>
                <div class="flex items-center gap-3 mb-3">
                    <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-500 flex-shrink-0">
                        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                        </svg>
                    </div>
                    <h3 class="font-serif text-lg font-bold text-main">Now</h3>
                </div>
                <p class="text-sm text-main/55 leading-relaxed mb-4">An active telemetry feed of my current projects, technical focus, and life trajectory in Hamburg.</p>
                <span class="inline-flex items-center gap-1.5 text-[11px] font-mono text-main/35 group-hover:text-main/60 transition-colors uppercase tracking-widest">Check Status →</span>
            </a>
        </div>
    </div>
</BaseLayout>
