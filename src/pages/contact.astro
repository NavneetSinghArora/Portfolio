---
import siteConfig from '../data/site-config';
import BaseLayout from '../layouts/BaseLayout.astro';

// We can reuse the resolveIcon logic from Footer/Education to grab platform icons locally
const logos = import.meta.glob<{ default: ImageMetadata }>('/src/assets/icons/*.{svg,png,webp,jpg,jpeg}', { eager: true });

function resolveIcon(name: string) {
    const extensions = ['.svg', '.png', '.webp', '.jpg', '.jpeg'];
    for (const ext of extensions) {
        const path = `/src/assets/icons/${name}${ext}`;
        const asset = logos[path];
        if (asset) {
            return (asset.default as any)?.src || asset.default || asset;
        }
    }
    return '';
}

const contactMethods = [
    {
        title: "Email",
        subtitle: "Direct Message",
        link: "mailto:aroranavneetsingh.de@gmail.com",
        display: "aroranavneetsingh.de@gmail.com",
        icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>'
    },
    {
        title: "LinkedIn",
        subtitle: "Professional Network",
        link: "https://www.linkedin.com/in/navneet-singh-arora",
        display: "linkedin.com/in/navneet-singh-arora",
        iconPath: "linkedin"
    },
    {
        title: "GitHub",
        subtitle: "Code & Contributions",
        link: "https://github.com/NavneetSinghArora",
        display: "github.com/NavneetSinghArora",
        iconPath: "github-dark" // Assuming dark mode priority for the premium card layout
    },
    {
        title: "Xing",
        subtitle: "DACH Network",
        link: "https://www.xing.com/profile/NavneetSingh_Arora",
        display: "xing.com/profile/NavneetSingh_Arora",
        iconPath: "xing"
    }
];
---

<BaseLayout 
    title={`Contact - ${siteConfig.title}`} 
    description="Get in touch with Navneet Singh Arora for Machine Learning and Full Stack development opportunities."
>
    <!-- Header -->
    <div class="mb-12 sm:mb-16">
        <h1 class="font-serif text-3xl leading-tight font-medium sm:text-4xl mb-4">Get in touch</h1>
        <p class="text-main/80 max-w-2xl leading-relaxed text-sm sm:text-base">
            Whether you have a project in mind, a question about my AI research, or just want to connect, I'm always open to interesting conversations. Feel free to reach out through any of the platforms below.
        </p>
    </div>

    <!-- Contact Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-6 mb-16">
        {contactMethods.map((method) => (
            <a 
                href={method.link}
                target={method.link.startsWith('http') ? "_blank" : "_self"}
                rel={method.link.startsWith('http') ? "noopener noreferrer" : ""}
                class="group relative overflow-hidden rounded-2xl border border-main-border/10 bg-main-bg/5 p-6 transition-all duration-300 hover:border-main-border/30 hover:bg-main-bg/10 hover:-translate-y-1 block"
            >
                <!-- Subtle Gradient Hover Layer -->
                <div class="absolute inset-0 bg-gradient-to-br from-main/5 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100 pointer-events-none" />
                
                <div class="relative flex items-center justify-between gap-4">
                    <div class="flex items-center gap-4">
                        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-main/5 text-main ring-1 ring-main/10 transition-colors group-hover:bg-main/10 group-hover:ring-main/20">
                            {method.icon && (
                                <div set:html={method.icon} />
                            )}
                            {method.iconPath && (
                                <>
                                    {method.iconPath === 'github-dark' ? (
                                        <>
                                            <img src={resolveIcon('github-dark')} alt="GitHub" class="h-6 w-6 dark:hidden opacity-80" />
                                            <img src={resolveIcon('github-light')} alt="GitHub" class="h-6 w-6 hidden dark:block opacity-80" />
                                        </>
                                    ) : (
                                        <img src={resolveIcon(method.iconPath)} alt={method.title} class="h-6 w-6 opacity-80" />
                                    )}
                                </>
                            )}
                        </div>
                        <div>
                            <h2 class="font-serif text-lg font-medium tracking-wide">{method.title}</h2>
                            <p class="text-[10px] uppercase tracking-widest font-bold text-main/50 mt-0.5">{method.subtitle}</p>
                        </div>
                    </div>
                    
                    <!-- Arrow Icon -->
                    <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-main/5 opacity-0 transition-all duration-300 group-hover:opacity-100 group-hover:bg-main/10 -translate-x-2 group-hover:translate-x-0">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-main">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </div>
                </div>
            </a>
        ))}
    </div>

    <!-- Submit Form Section -->
    <div class="mt-16 sm:mt-24 bg-main-bg/5 border border-main-border/10 rounded-3xl p-6 sm:p-10 relative overflow-hidden">
        <!-- Background glows -->
        <div class="absolute -top-24 -right-24 h-64 w-64 rounded-full bg-main/5 blur-3xl" />
        <div class="absolute -bottom-24 -left-24 h-64 w-64 rounded-full bg-main/5 blur-3xl" />
        
        <div class="relative z-10">
            <h2 class="font-serif text-2xl sm:text-3xl mb-2">Send a Message</h2>
            <p class="text-sm text-main/60 mb-8 max-w-lg">Prefer to message me directly from here? Fill out the form below and it will be sent straight to my inbox.</p>
            
            <form action="https://api.web3forms.com/submit" method="POST" class="max-w-xl space-y-5" id="contact-form">
                <!-- Replace 'YOUR_ACCESS_KEY_HERE' with your actual free access key from https://web3forms.com/ -->
                <input type="hidden" name="access_key" value="76a2dbca-274c-417a-9bf2-eee418e235f8">
                <input type="hidden" name="subject" value="New Contact Submission from Portfolio">
                <!-- Honeypot Spam Protection -->
                <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                    <div class="space-y-1.5">
                        <label for="name" class="block text-xs font-bold uppercase tracking-widest text-main/60">Name</label>
                        <input type="text" name="name" id="name" required class="w-full rounded-xl border border-main-border/10 bg-main-bg/30 px-4 py-3 text-sm text-main placeholder:text-main/20 focus:border-main/50 focus:outline-none focus:ring-1 focus:ring-main/50 transition-all backdrop-blur-sm" placeholder="John Doe">
                    </div>
                    
                    <div class="space-y-1.5">
                        <label for="email" class="block text-xs font-bold uppercase tracking-widest text-main/60">Email</label>
                        <input type="email" name="email" id="email" required class="w-full rounded-xl border border-main-border/10 bg-main-bg/30 px-4 py-3 text-sm text-main placeholder:text-main/20 focus:border-main/50 focus:outline-none focus:ring-1 focus:ring-main/50 transition-all backdrop-blur-sm" placeholder="john@example.com">
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label for="phone" class="block text-xs font-bold uppercase tracking-widest text-main/60 flex items-center gap-2">
                        Phone Number 
                        <span class="text-[9px] text-main/30 bg-main/5 px-2 py-0.5 rounded-full">Optional</span>
                    </label>
                    <input type="tel" name="phone" id="phone" class="w-full rounded-xl border border-main-border/10 bg-main-bg/30 px-4 py-3 text-sm text-main placeholder:text-main/20 focus:border-main/50 focus:outline-none focus:ring-1 focus:ring-main/50 transition-all backdrop-blur-sm" placeholder="+49 123 4567890">
                </div>

                <div class="space-y-1.5">
                    <label for="message" class="block text-xs font-bold uppercase tracking-widest text-main/60">Message</label>
                    <textarea name="message" id="message" required rows="5" class="w-full rounded-xl border border-main-border/10 bg-main-bg/30 px-4 py-3 text-sm text-main placeholder:text-main/20 focus:border-main/50 focus:outline-none focus:ring-1 focus:ring-main/50 transition-all resize-none backdrop-blur-sm" placeholder="How can we help?"></textarea>
                </div>

                <div class="pt-2 flex flex-col sm:flex-row items-center gap-4">
                    <button type="submit" id="submit-btn" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-xl bg-main px-8 py-3 text-sm font-bold text-main-bg tracking-wide transition-transform duration-300 hover:scale-[1.02] active:scale-[0.98]">
                        <span>Send Message</span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="22" y1="2" x2="11" y2="13"></line>
                            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                        </svg>
                    </button>
                </div>
                <!-- Inline Result Message -->
                <div id="form-result" class="empty:hidden"></div>
            </form>
        </div>
    </div>
</BaseLayout>

<script>
    document.addEventListener('astro:page-load', () => {
        const form = document.getElementById('contact-form') as HTMLFormElement;
        const result = document.getElementById('form-result');
        const submitBtn = document.getElementById('submit-btn');

        if (!form) return;

        form.addEventListener('submit', async function(e) {
            e.preventDefault();
            
            if (submitBtn) {
                const btnText = submitBtn.querySelector('span');
                if (btnText) btnText.innerText = 'Sending...';
                submitBtn.classList.add('opacity-70', 'cursor-not-allowed');
                submitBtn.setAttribute('disabled', 'true');
            }

            const formData = new FormData(form);
            const object = Object.fromEntries(formData);
            const json = JSON.stringify(object);

            try {
                const response = await fetch('https://api.web3forms.com/submit', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: json
                });
                const data = await response.json();

                if (response.status === 200) {
                    form.reset();
                    if (result) {
                        result.innerHTML = `
                            <div class="flex items-center gap-3 text-green-600 bg-green-500/10 px-4 py-3 rounded-lg border border-green-500/20 mt-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                                <span class="text-sm font-medium">Message sent successfully! I'll be in touch soon.</span>
                            </div>
                        `;
                    }
                } else {
                    console.log(data);
                    if (result) {
                        result.innerHTML = `<span class="text-sm text-red-500 mt-2 block">${data.message}</span>`;
                    }
                }
            } catch (error) {
                console.log(error);
                if (result) {
                    result.innerHTML = `<span class="text-sm text-red-500 mt-2 block">Something went wrong! Please try sending a direct email.</span>`;
                }
            } finally {
                if (submitBtn) {
                    const btnText = submitBtn.querySelector('span');
                    if (btnText) btnText.innerText = 'Send Message';
                    submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
                    submitBtn.removeAttribute('disabled');
                }
            }
        });
    });
</script>
