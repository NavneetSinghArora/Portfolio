---
import { getEntry, getCollection, render } from 'astro:content';
import ProjectPreview from '../../components/ProjectPreview.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortItemsByDateDesc } from '../../utils/data-utils';

const { id } = Astro.params;
const project = await getEntry('projects', id as string);

if (!project) {
    return Astro.redirect('/404');
}

const projects = (await getCollection('projects')).sort(sortItemsByDateDesc);
const projectIndex = projects.findIndex((p) => p.id === project.id);
const prevProject = projectIndex + 1 !== projects.length ? projects[projectIndex + 1] : null;
const nextProject = projectIndex !== 0 ? projects[projectIndex - 1] : null;

const { title, description, seo, publishDate } = project.data;
const { Content } = await render(project);
---

<BaseLayout title={seo?.title ?? title} description={seo?.description ?? description} image={seo?.image} publishDate={publishDate} showHeader={false}>
    <article class="mb-16 sm:mb-24">
        <header class="mb-12">
            <h1 class="font-serif text-3xl leading-tight font-medium sm:text-5xl sm:leading-tight mb-8">{title}</h1>
            
            <!-- Featured Image from Frontmatter -->
            {seo?.image && (
                <div class="w-full flex justify-center mb-12">
                    <div class="overflow-hidden rounded-3xl bg-main-bg/5 shadow-2xl shadow-main-bg/20">
                        <img 
                            src={seo.image.src.src} 
                            alt={seo.image.alt || title}
                            class="max-w-full h-auto max-h-[70vh] object-contain block"
                        />
                    </div>
                </div>
            )}

            <!-- Automated Resource Header (Now below thumbnail) -->
            {(project.data.github || project.data.paper || project.data.demo || project.data.external) && (
                <div class="not-prose p-6 rounded-2xl border border-main-border/10 bg-main-bg/5 flex flex-col md:flex-row items-center justify-between gap-6 transition-colors hover:border-main-border/20">
                    <div class="space-y-1 text-center md:text-left">
                        <h4 class="text-[10px] font-bold uppercase tracking-[0.2em] text-main/40 italic">Resource Directory</h4>
                        <p class="text-xs text-main/60 font-medium font-serif italic">Technical implementation and research artifacts associated with this project.</p>
                    </div>
                    <div class="flex items-center gap-6">
                        {project.data.github && (
                            <a href={project.data.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub Repository" title="GitHub Repository" class="group transition-transform hover:-translate-y-1">
                                <img src="https://cdn.simpleicons.org/github" alt="" class="h-6 w-6 opacity-40 group-hover:opacity-100 transition-opacity dark:hidden" />
                                <img src="https://cdn.simpleicons.org/github/white" alt="" class="h-6 w-6 opacity-40 group-hover:opacity-100 transition-opacity hidden dark:block" />
                            </a>
                        )}
                        {project.data.paper && (
                            <a href={project.data.paper} target="_blank" rel="noopener noreferrer" aria-label="Research Paper" title={project.data.paper.includes('kaggle.com') ? "Kaggle Competition" : "Research Paper"} class="group transition-transform hover:-translate-y-1">
                                {project.data.paper.includes('kaggle.com') ? (
                                    <div class="flex items-center">
                                        <img src="https://cdn.simpleicons.org/kaggle" class="h-7 w-7 opacity-40 group-hover:opacity-100 transition-opacity dark:hidden" alt="Kaggle" />
                                        <img src="https://cdn.simpleicons.org/kaggle/white" class="h-7 w-7 opacity-40 group-hover:opacity-100 transition-opacity hidden dark:block" alt="Kaggle" />
                                    </div>
                                ) : (
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-6 w-6 opacity-40 group-hover:opacity-100 transition-opacity"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                                )}
                            </a>
                        )}
                        {project.data.demo && (
                            <a href={project.data.demo} target="_blank" rel="noopener noreferrer" aria-label="Live Demo" title="Live Demo" class="group transition-transform hover:-translate-y-1">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-6 w-6 opacity-40 group-hover:opacity-100 transition-opacity"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                            </a>
                        )}
                        {project.data.external && (
                            <a href={project.data.external} target="_blank" rel="noopener noreferrer" aria-label="External Link" title="External Link" class="group transition-transform hover:-translate-y-1">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-6 w-6 opacity-40 group-hover:opacity-100 transition-opacity"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                            </a>
                        )}
                    </div>
                </div>
            )}
        </header>

        <div class="prose sm:prose-lg max-w-none">
            <Content />
        </div>
    </article>
    {
        (prevProject || nextProject) && (
            <div class="my-16 sm:my-24">
                <h2 class="mb-12 font-serif text-xl italic sm:mb-16 sm:text-2xl">View Next</h2>
                {nextProject && <ProjectPreview project={nextProject} class="mb-10 sm:mb-12" headingLevel="h3" />}
                {prevProject && <ProjectPreview project={prevProject} class="mb-10 sm:mb-12" headingLevel="h3" />}
            </div>
        )
    }
</BaseLayout>
