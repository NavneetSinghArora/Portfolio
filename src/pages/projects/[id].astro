---
import { getEntry, getCollection, render } from 'astro:content';
import ProjectPreview from '../../components/ProjectPreview.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import IconButton from '../../components/IconButton.astro';
import SocialIcon from '../../components/SocialIcon.astro';
import { sortItemsByDateDesc } from '../../utils/data-utils';

export async function getStaticPaths() {
    const projects = await getCollection('projects');
    return projects.map((project) => ({
        params: { id: project.id },
        props: { project }
    }));
}

const { project } = Astro.props;

if (!project) {
    return Astro.redirect('/404');
}

const projects = (await getCollection('projects')).sort(sortItemsByDateDesc);
const projectIndex = projects.findIndex((p) => p.id === project.id);
const prevProject = projectIndex + 1 !== projects.length ? projects[projectIndex + 1] : null;
const nextProject = projectIndex !== 0 ? projects[projectIndex - 1] : null;

const { title, description, seo, publishDate } = project.data;
const { Content } = await render(project);
---

<BaseLayout title={seo?.title ?? title} description={seo?.description ?? description} image={seo?.image} publishDate={publishDate}>
    <article class="mb-16 sm:mb-24">
        <header class="mb-12">
            <h1 class="font-serif text-3xl leading-tight font-medium sm:text-5xl sm:leading-tight mb-8">{title}</h1>
            
            <!-- Featured Image from Frontmatter -->
            {seo?.image ? (
                <div class="w-full flex justify-center mb-12">
                    <div class="overflow-hidden rounded-3xl bg-main-bg/5 shadow-2xl shadow-main-bg/20">
                        <img
                            src={seo.image.src.src}
                            alt={seo.image.alt || title}
                            class="max-w-full h-auto max-h-[70vh] object-contain block"
                        />
                    </div>
                </div>
            ) : project.data.npm && (() => {
                const pkg = project.data.npm.split('/package/')[1]?.split('/')[0];
                return (
                    <div class="w-full flex justify-center mb-12">
                        <div class="overflow-hidden rounded-3xl shadow-2xl shadow-black/30 w-full max-w-2xl">
                            <div class="flex flex-col items-center justify-center gap-5 bg-[#0f0f1a] px-8 py-14">
                                <span class="inline-flex items-center gap-2 rounded-full border border-[#CB3837]/40 bg-[#CB3837]/10 px-4 py-1.5 text-[11px] font-mono font-bold text-[#CB3837] tracking-widest uppercase">
                                    <img src="https://cdn.simpleicons.org/npm/CB3837" class="h-3.5 w-3.5" alt="" />
                                    npm package
                                </span>
                                <span class="font-mono text-3xl font-bold text-white/95 tracking-tight">{pkg}</span>
                                <span class="font-mono text-sm text-emerald-400/80 bg-white/5 rounded-xl px-5 py-2.5 border border-white/5">
                                    <span class="text-white/30">$ </span>npm install {pkg}
                                </span>
                            </div>
                        </div>
                    </div>
                );
            })()}

            <!-- Automated Resource Header (Now below thumbnail) -->
            {(project.data.github || project.data.npm || project.data.paper || project.data.demo || project.data.external) && (
                <div class="not-prose p-6 rounded-2xl border border-main-border/10 bg-main-bg/5 flex flex-col md:flex-row items-center justify-between gap-6 transition-colors hover:border-main-border/20">
                    <div class="space-y-1.5 text-center md:text-left">
                        <h4 class="text-xs font-bold uppercase tracking-[0.2em] text-main/55">Resource Directory</h4>
                        <p class="text-sm text-main/70 font-medium font-serif">Technical implementation and research artifacts associated with this project.</p>
                    </div>
                    <div class="flex items-center gap-3">
                        {project.data.github && (
                            <IconButton href={project.data.github} target="_blank" rel="noopener noreferrer" size="lg" tooltip="GitHub Repository">
                                <SocialIcon name="github" size="md" />
                            </IconButton>
                        )}
                        {project.data.npm && (
                            <IconButton href={project.data.npm} target="_blank" rel="noopener noreferrer" size="lg" tooltip="npm Package">
                                <SocialIcon name="npm" size="md" />
                            </IconButton>
                        )}
                        {project.data.paper && (
                            <IconButton href={project.data.paper} target="_blank" rel="noopener noreferrer" size="lg" tooltip={project.data.paper.includes('kaggle.com') ? 'Kaggle Competition' : 'Research Paper'}>
                                <SocialIcon name={project.data.paper.includes('kaggle.com') ? 'kaggle' : 'paper'} size="md" />
                            </IconButton>
                        )}
                        {project.data.demo && (
                            <IconButton href={project.data.demo} target="_blank" rel="noopener noreferrer" size="lg" tooltip="Live Demo">
                                <SocialIcon name="demo" size="md" />
                            </IconButton>
                        )}
                        {project.data.external && (
                            <IconButton href={project.data.external} target="_blank" rel="noopener noreferrer" size="lg" tooltip={project.data.tags.includes('n8n') ? 'Official n8n Workflow' : 'External Link'}>
                                <SocialIcon name={project.data.tags.includes('n8n') ? 'n8n' : 'external'} size="md" />
                            </IconButton>
                        )}
                    </div>
                </div>
            )}
        </header>

        <div class="prose sm:prose-lg max-w-none">
            <Content />
        </div>
    </article>
    {
        (prevProject || nextProject) && (
            <div class="my-16 sm:my-24">
                <h2 class="mb-12 font-serif text-xl sm:mb-16 sm:text-2xl">View Next</h2>
                {nextProject && <ProjectPreview project={nextProject} class="mb-10 sm:mb-12" headingLevel="h3" />}
                {prevProject && <ProjectPreview project={prevProject} class="mb-10 sm:mb-12" headingLevel="h3" />}
            </div>
        )
    }
</BaseLayout>
