---
import { getEntry, getCollection, render } from 'astro:content';
import ProjectPreview from '../../components/ProjectPreview.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortItemsByDateDesc } from '../../utils/data-utils';

export async function getStaticPaths() {
    const projects = await getCollection('projects');
    return projects.map((project) => ({
        params: { id: project.id },
        props: { project }
    }));
}

const { project } = Astro.props;

if (!project) {
    return Astro.redirect('/404');
}

const projects = (await getCollection('projects')).sort(sortItemsByDateDesc);
const projectIndex = projects.findIndex((p) => p.id === project.id);
const prevProject = projectIndex + 1 !== projects.length ? projects[projectIndex + 1] : null;
const nextProject = projectIndex !== 0 ? projects[projectIndex - 1] : null;

const { title, description, seo, publishDate } = project.data;
const { Content } = await render(project);
---

<BaseLayout title={seo?.title ?? title} description={seo?.description ?? description} image={seo?.image} publishDate={publishDate}>
    <article class="mb-16 sm:mb-24">
        <header class="mb-12">
            <h1 class="font-serif text-3xl leading-tight font-medium sm:text-5xl sm:leading-tight mb-8">{title}</h1>
            
            <!-- Featured Image from Frontmatter -->
            {seo?.image ? (
                <div class="w-full flex justify-center mb-12">
                    <div class="overflow-hidden rounded-3xl bg-main-bg/5 shadow-2xl shadow-main-bg/20">
                        <img
                            src={seo.image.src.src}
                            alt={seo.image.alt || title}
                            class="max-w-full h-auto max-h-[70vh] object-contain block"
                        />
                    </div>
                </div>
            ) : project.data.npm && (() => {
                const pkg = project.data.npm.split('/package/')[1]?.split('/')[0];
                return (
                    <div class="w-full flex justify-center mb-12">
                        <div class="overflow-hidden rounded-3xl shadow-2xl shadow-black/30 w-full max-w-2xl">
                            <div class="flex flex-col items-center justify-center gap-5 bg-[#0f0f1a] px-8 py-14">
                                <span class="inline-flex items-center gap-2 rounded-full border border-[#CB3837]/40 bg-[#CB3837]/10 px-4 py-1.5 text-[11px] font-mono font-bold text-[#CB3837] tracking-widest uppercase">
                                    <img src="https://cdn.simpleicons.org/npm/CB3837" class="h-3.5 w-3.5" alt="" />
                                    npm package
                                </span>
                                <span class="font-mono text-3xl font-bold text-white/95 tracking-tight">{pkg}</span>
                                <span class="font-mono text-sm text-emerald-400/80 bg-white/5 rounded-xl px-5 py-2.5 border border-white/5">
                                    <span class="text-white/30">$ </span>npm install {pkg}
                                </span>
                            </div>
                        </div>
                    </div>
                );
            })()}

            <!-- Automated Resource Header (Now below thumbnail) -->
            {(project.data.github || project.data.npm || project.data.paper || project.data.demo || project.data.external) && (
                <div class="not-prose p-6 rounded-2xl border border-main-border/10 bg-main-bg/5 flex flex-col md:flex-row items-center justify-between gap-6 transition-colors hover:border-main-border/20">
                    <div class="space-y-1.5 text-center md:text-left">
                        <h4 class="text-xs font-bold uppercase tracking-[0.2em] text-main/55">Resource Directory</h4>
                        <p class="text-sm text-main/70 font-medium font-serif">Technical implementation and research artifacts associated with this project.</p>
                    </div>
                    <div class="flex items-center gap-6">
                        {project.data.github && (
                            <a href={project.data.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub Repository" class="group/icon premium-tooltip relative flex h-10 w-10 items-center justify-center transition-all duration-300 hover:scale-115" data-tooltip="GitHub Repository">
                                <div class="absolute inset-0 rounded-xl bg-main/10 ring-1 ring-main/20 transition-all duration-300 group-hover/icon:scale-110 group-hover/icon:bg-main/15 group-hover/icon:ring-main/30"></div>
                                <img src="https://cdn.simpleicons.org/github" alt="" class="h-4 w-4 opacity-70 group-hover/icon:opacity-100 transition-opacity dark:hidden relative z-10" />
                                <img src="https://cdn.simpleicons.org/github/white" alt="" class="h-4 w-4 opacity-70 group-hover/icon:opacity-100 transition-opacity hidden dark:block relative z-10" />
                            </a>
                        )}
                        {project.data.npm && (
                            <a href={project.data.npm} target="_blank" rel="noopener noreferrer" aria-label="npm Package" class="group/icon premium-tooltip relative flex h-10 w-10 items-center justify-center transition-all duration-300 hover:scale-115" data-tooltip="npm Package">
                                <div class="absolute inset-0 rounded-xl bg-main/10 ring-1 ring-main/20 transition-all duration-300 group-hover/icon:scale-110 group-hover/icon:bg-main/15 group-hover/icon:ring-main/30"></div>
                                <img src="https://cdn.simpleicons.org/npm/CB3837" alt="" class="h-4 w-4 opacity-70 group-hover/icon:opacity-100 transition-opacity relative z-10" />
                            </a>
                        )}
                        {project.data.paper && (
                            <a href={project.data.paper} target="_blank" rel="noopener noreferrer" aria-label="Research Paper" class="group/icon premium-tooltip relative flex h-10 w-10 items-center justify-center transition-all duration-300 hover:scale-115" data-tooltip={project.data.paper.includes('kaggle.com') ? "Kaggle Competition" : "Research Paper"}>
                                <div class="absolute inset-0 rounded-xl bg-main/10 ring-1 ring-main/20 transition-all duration-300 group-hover/icon:scale-110 group-hover/icon:bg-main/15 group-hover/icon:ring-main/30"></div>
                                {project.data.paper.includes('kaggle.com') ? (
                                    <div class="flex items-center relative z-10 opacity-70 group-hover/icon:opacity-100 transition-opacity">
                                        <img src="https://cdn.simpleicons.org/kaggle" class="h-4 w-4 dark:hidden" alt="Kaggle" />
                                        <img src="https://cdn.simpleicons.org/kaggle/white" class="h-4 w-4 hidden dark:block" alt="Kaggle" />
                                    </div>
                                ) : (
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4 opacity-70 group-hover/icon:opacity-100 transition-opacity relative z-10"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                                )}
                            </a>
                        )}
                        {project.data.demo && (
                            <a href={project.data.demo} target="_blank" rel="noopener noreferrer" aria-label="Live Demo" class="group/icon premium-tooltip relative flex h-10 w-10 items-center justify-center transition-all duration-300 hover:scale-115" data-tooltip="Live Demo">
                                <div class="absolute inset-0 rounded-xl bg-main/10 ring-1 ring-main/20 transition-all duration-300 group-hover/icon:scale-110 group-hover/icon:bg-main/15 group-hover/icon:ring-main/30"></div>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4 opacity-70 group-hover/icon:opacity-100 transition-opacity relative z-10"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                            </a>
                        )}
                        {project.data.external && (
                            <a 
                                href={project.data.external} 
                                target="_blank" 
                                rel="noopener noreferrer" 
                                aria-label={project.data.tags.includes('n8n') ? "Official n8n Workflow" : "External Link"} 
                                class="group/icon premium-tooltip relative flex h-10 w-10 items-center justify-center transition-all duration-300 hover:scale-115"
                                data-tooltip={project.data.tags.includes('n8n') ? "Official n8n Workflow" : "External Link"}
                            >
                                <div class="absolute inset-0 rounded-xl bg-main/10 ring-1 ring-main/20 transition-all duration-300 group-hover/icon:scale-110 group-hover/icon:bg-main/15 group-hover/icon:ring-main/30"></div>
                                {project.data.tags.includes('n8n') ? (
                                    <div class="flex items-center relative z-10 opacity-70 group-hover/icon:opacity-100 transition-opacity">
                                        <img src="https://cdn.simpleicons.org/n8n" alt="" class="h-4 w-4 dark:hidden" />
                                        <img src="https://cdn.simpleicons.org/n8n/white" alt="" class="h-4 w-4 hidden dark:block" />
                                    </div>
                                ) : (
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4 opacity-70 group-hover/icon:opacity-100 transition-opacity relative z-10"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                                )}
                            </a>
                        )}
                    </div>
                </div>
            )}
        </header>

        <div class="prose sm:prose-lg max-w-none">
            <Content />
        </div>
    </article>
    {
        (prevProject || nextProject) && (
            <div class="my-16 sm:my-24">
                <h2 class="mb-12 font-serif text-xl sm:mb-16 sm:text-2xl">View Next</h2>
                {nextProject && <ProjectPreview project={nextProject} class="mb-10 sm:mb-12" headingLevel="h3" />}
                {prevProject && <ProjectPreview project={prevProject} class="mb-10 sm:mb-12" headingLevel="h3" />}
            </div>
        )
    }
</BaseLayout>
