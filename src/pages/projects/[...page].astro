---
export const prerender = true;
import type { GetStaticPathsOptions, Page } from 'astro';
import { type CollectionEntry, getCollection } from 'astro:content';
import Pagination from '../../components/Pagination.astro';
import ProjectThumbnail from '../../components/ProjectThumbnail.astro';
import ProjectPreview from '../../components/ProjectPreview.astro';
import siteConfig from '../../data/site-config';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortItemsByDateDesc } from '../../utils/data-utils';
import LayoutGrid from '../../assets/icons/layout-grid.svg';
import ListIcon from '../../assets/icons/list.svg';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const projects = (await getCollection('projects')).sort(sortItemsByDateDesc);
    return paginate(projects, { pageSize: siteConfig.projectsPerPage || 12 });
}

type Props = { page: Page<CollectionEntry<'projects'>> };

const { page } = Astro.props;
const portfolio = page.data;
const allTags = [...new Set(portfolio.flatMap(p => p.data.tags))].sort();

const spotlightColors = [
    'rgba(56, 189, 248, 0.15)', // Blue
    'rgba(139, 92, 246, 0.15)', // Purple
    'rgba(16, 185, 129, 0.15)', // Emerald
    'rgba(245, 158, 11, 0.15)', // Amber
    'rgba(236, 72, 153, 0.15)', // Pink
    'rgba(244, 63, 94, 0.15)',  // Rose
];
---

<BaseLayout title="Portfolio" description="Explore a diverse portfolio showcasing my passion and expertise">
    <div class="mb-12 flex flex-col justify-between gap-6 sm:mb-16 sm:flex-row sm:items-end">
        <div>
            <h1 class="font-serif text-2xl leading-tight sm:text-4xl text-main">Projects</h1>
            <p class="mt-2 text-sm text-main/60 max-w-md">Technical research, engineering implementations, and academic reviews.</p>
        </div>
        
        </div>
    </div>

    <!-- Premium Filter Console -->
    <div class="mb-12 space-y-4">
        <!-- Search Bar -->
        <div class="relative group">
            <input 
                type="text" 
                id="project-search" 
                placeholder="Search projects by name, tag, or technology..." 
                class="w-full bg-main-bg/10 backdrop-blur-md border border-main-border/20 rounded-xl py-3 pl-12 pr-4 text-[14px] text-main placeholder:text-main/40 focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500/30 transition-all shadow-sm"
            />
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-main/50 group-focus-within:text-blue-500 transition-colors pointer-events-none z-10"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        </div>

        <!-- Tool Row (Filters + Sort + View Switcher) -->
        <div class="flex flex-wrap items-center justify-between gap-4">
            <div class="flex flex-wrap items-center gap-3">
                <!-- Category Dropdown -->
                <div class="relative dropdown-container" id="category-dropdown">
                    <button class="dropdown-trigger flex items-center justify-between gap-3 px-4 py-2.5 min-w-[170px] bg-main-bg/10 backdrop-blur-md border border-main-border/20 rounded-xl text-[14px] font-medium text-main/60 hover:text-main transition-all shadow-sm">
                        <div class="flex items-center gap-2">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 opacity-40"><rect width="7" height="7" x="3" y="3" rx="1"></rect><rect width="7" height="7" x="14" y="3" rx="1"></rect><rect width="7" height="7" x="14" y="14" rx="1"></rect><rect width="7" height="7" x="3" y="14" rx="1"></rect></svg>
                            <span id="current-category">All Categories</span>
                        </div>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 opacity-30 chevron transition-transform"><path d="m6 9 6 6 6-6"></path></svg>
                    </button>
                    
                    <div class="dropdown-menu hidden absolute top-full left-0 mt-2 min-w-[220px] bg-main-bg/80 backdrop-blur-xl border border-main-border/10 rounded-xl py-1.5 shadow-2xl z-50 origin-top-left transition-all duration-200">
                        <button class="tag-filter-btn flex items-center gap-3 w-full px-4 py-2 text-[13px] text-main/60 hover:text-main hover:bg-main-bg/10 transition-colors" data-tag-filter="all">
                            <div class="h-1.5 w-1.5 rounded-full bg-blue-500 opacity-0 transition-opacity active-indicator"></div>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5"><circle cx="12" cy="12" r="10"></circle><path d="M12 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0"></path></svg>
                            All Projects
                        </button>
                        {allTags.map(tag => (
                            <button class="tag-filter-btn flex items-center gap-3 w-full px-4 py-2 text-[13px] text-main/60 hover:text-main hover:bg-main-bg/10 transition-colors capitalize" data-tag-filter={tag}>
                                <div class="h-1.5 w-1.5 rounded-full bg-blue-500 opacity-0 transition-opacity active-indicator"></div>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 opacity-40"><path d="M12 2l3.5 2h4l2 3.5l-2 3.5v4l-2 3.5l-4 2l-3.5-2h-4l-2-3.5l2-3.5v-4l2-3.5l4-2z"></path></svg>
                                {tag}
                            </button>
                        ))}
                    </div>
                </div>

                <!-- Sort Dropdown -->
                <div class="relative dropdown-container" id="sort-dropdown">
                    <button class="dropdown-trigger flex items-center justify-between gap-3 px-4 py-2.5 min-w-[170px] bg-main-bg/10 backdrop-blur-md border border-main-border/20 rounded-xl text-[14px] font-medium text-main/60 hover:text-main transition-all shadow-sm">
                        <div class="flex items-center gap-2">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 opacity-40"><path d="m3 16 4 4 4-4"></path><path d="M7 20V4"></path><path d="m21 8-4-4-4 4"></path><path d="M17 4v16"></path></svg>
                            <span id="current-sort">Newest First</span>
                        </div>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 opacity-30 chevron transition-transform"><path d="m6 9 6 6 6-6"></path></svg>
                    </button>
                    <div class="dropdown-menu hidden absolute top-full left-0 mt-2 min-w-[200px] bg-main-bg/80 backdrop-blur-xl border border-main-border/10 rounded-xl py-1.5 shadow-2xl z-50 origin-top-left transition-all duration-200">
                        <button class="sort-btn flex items-center gap-3 w-full px-4 py-2 text-[13px] text-main/60 hover:text-main hover:bg-main-bg/10 transition-colors" data-sort="newest">
                            <div class="h-1.5 w-1.5 rounded-full bg-blue-500 opacity-100 transition-opacity active-indicator"></div>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 opacity-40"><path d="m3 16 4 4 4-4"></path><path d="M7 20V4"></path></svg>
                            Newest First
                        </button>
                        <button class="sort-btn flex items-center gap-3 w-full px-4 py-2 text-[13px] text-main/60 hover:text-main hover:bg-main-bg/10 transition-colors" data-sort="oldest">
                            <div class="h-1.5 w-1.5 rounded-full bg-blue-500 opacity-0 transition-opacity active-indicator"></div>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 opacity-40"><path d="m3 8 4-4 4 4"></path><path d="M7 4v16"></path></svg>
                            Oldest First
                        </button>
                        <button class="sort-btn flex items-center gap-3 w-full px-4 py-2 text-[13px] text-main/60 hover:text-main hover:bg-main-bg/10 transition-colors" data-sort="az">
                            <div class="h-1.5 w-1.5 rounded-full bg-blue-500 opacity-0 transition-opacity active-indicator"></div>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 opacity-40"><path d="M11 5h10"></path><path d="M11 9h10"></path><path d="M11 13h10"></path><path d="m3 17 3 3 3-3"></path><path d="M6 18V4"></path></svg>
                            Alphabetical (A-Z)
                        </button>
                    </div>
                </div>
            </div>

            <!-- Integrated View Switcher -->
            <div class="flex items-center gap-1.5 bg-main-bg/10 backdrop-blur-md border border-main-border/20 p-1 rounded-xl shadow-sm relative view-switcher-container">
                <div class="view-highlight absolute transition-all duration-500 ease-out bg-main rounded-lg shadow-md"></div>
                <button 
                    id="view-cards"
                    class="view-mode-btn premium-tooltip flex h-8 w-8 items-center justify-center rounded-lg transition-all hover:bg-main-bg/10 text-main active-view relative z-10" 
                    data-tooltip="Grid"
                >
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
                </button>
                <button 
                    id="view-gallery"
                    class="view-mode-btn premium-tooltip flex h-8 w-8 items-center justify-center rounded-lg transition-all hover:bg-main-bg/10 text-main/40 relative z-10" 
                    data-tooltip="Gallery"
                >
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
                </button>
                <button 
                    id="view-list"
                    class="view-mode-btn premium-tooltip flex h-8 w-8 items-center justify-center rounded-lg transition-all hover:bg-main-bg/10 text-main/40 relative z-10" 
                    data-tooltip="List"
                >
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
                </button>
            </div>
        </div>
    </div>
    </div>

    <!-- Gallery View Container (Horizontal List / Visual List) -->
    <div id="gallery-container" class="hidden flex flex-col gap-6 transition-all duration-300">
        {portfolio.map((project) => (
            <div 
                class="project-card spotlight-card group relative flex flex-col sm:flex-row gap-6 p-6" 
                style={`--spotlight-color: ${spotlightColors[project.data.title.length % spotlightColors.length]};`}
                data-tags={project.data.tags.join(',')}
                data-date={project.data.publishDate.getTime()}
                data-title={project.data.title.toLowerCase()}
            >
                <div class="spotlight-glow"></div>
                <!-- Visual Column (Left) -->
                <div class="w-full sm:w-64 shrink-0">
                    <a href={`/projects/${project.id}/`} class="block aspect-video sm:aspect-square rounded-xl overflow-hidden border border-main-border/5">
                        {project.data.seo?.image ? (
                            <img 
                                src={project.data.seo.image.src.src} 
                                alt={project.data.title}
                                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                            />
                        ) : (
                            <div class="flex h-full w-full items-center justify-center bg-main-bg/10 text-main/55 text-xs">No preview</div>
                        )}
                    </a>
                </div>

                <!-- Content Section (Right) -->
                <div class="flex-grow flex flex-col justify-between py-1">
                    <div>
                        <a href={`/projects/${project.id}/`}>
                            <h3 class="font-serif text-2xl font-bold leading-tight mb-3 text-main">
                                <span class="premium-line-hover">{project.data.title}</span>
                            </h3>
                        </a>
                        <p class="text-sm text-main/60 leading-relaxed font-sans line-clamp-3">
                            {project.data.description}
                        </p>
                    </div>

                    <div class="mt-6 flex items-center justify-between">
                        <div class="flex items-center gap-1.5">
                            {project.data.github && (
                                <a 
                                    href={project.data.github} 
                                    target="_blank" 
                                    rel="noopener noreferrer" 
                                    class="group/icon premium-tooltip relative flex h-8 w-8 items-center justify-center transition-all duration-300 hover:scale-115" 
                                    data-tooltip="GitHub"
                                >
                                    <div class="absolute inset-0 rounded-xl bg-main/5 opacity-0 transition-all duration-300 group-hover/icon:opacity-100 group-hover/icon:scale-110 group-hover/icon:bg-main/10 ring-1 ring-main/10"></div>
                                    <img src="https://cdn.simpleicons.org/github" class="relative z-10 h-3.5 w-3.5 dark:hidden opacity-90" alt="GitHub" />
                                    <img src="https://cdn.simpleicons.org/github/white" class="relative z-10 h-3.5 w-3.5 hidden dark:block opacity-90" alt="GitHub" />
                                </a>
                            )}
                            {project.data.paper && (
                                <a 
                                    href={project.data.paper} 
                                    target="_blank" 
                                    rel="noopener noreferrer" 
                                    class="group/icon premium-tooltip relative flex h-8 w-8 items-center justify-center transition-all duration-300 hover:scale-115" 
                                    data-tooltip={project.data.paper.includes('kaggle.com') ? "Kaggle Competition" : "Research/Project Document"}
                                >
                                    <div class="absolute inset-0 rounded-xl bg-main/5 opacity-0 transition-all duration-300 group-hover/icon:opacity-100 group-hover/icon:scale-110 group-hover/icon:bg-main/10 ring-1 ring-main/10"></div>
                                    {project.data.paper.includes('kaggle.com') ? (
                                        <>
                                            <img src="https://cdn.simpleicons.org/kaggle" class="relative z-10 h-5 w-5 dark:hidden opacity-90" alt="Kaggle" />
                                            <img src="https://cdn.simpleicons.org/kaggle/white" class="relative z-10 h-5 w-5 hidden dark:block opacity-90" alt="Kaggle" />
                                        </>
                                    ) : (
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="relative z-10 h-3.5 w-3.5 opacity-90"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                                    )}
                                </a>
                            )}
                            {project.data.demo && (
                                <a 
                                    href={project.data.demo} 
                                    target="_blank" 
                                    rel="noopener noreferrer" 
                                    class="group/icon premium-tooltip relative flex h-8 w-8 items-center justify-center transition-all duration-300 hover:scale-115" 
                                    data-tooltip="Live Demo"
                                >
                                    <div class="absolute inset-0 rounded-xl bg-main/5 opacity-0 transition-all duration-300 group-hover/icon:opacity-100 group-hover/icon:scale-110 group-hover/icon:bg-main/10 ring-1 ring-main/10"></div>
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="relative z-10 h-3.5 w-3.5 opacity-90"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                                </a>
                            )}
                            {project.data.external && (
                                <a 
                                    href={project.data.external} 
                                    target="_blank" 
                                    rel="noopener noreferrer" 
                                    class="group/icon premium-tooltip relative flex h-8 w-8 items-center justify-center transition-all duration-300 hover:scale-115" 
                                    data-tooltip={project.data.tags.includes('n8n') ? "Technical implementation and research artifacts associated with this project." : "External Link"}
                                >
                                    <div class="absolute inset-0 rounded-xl bg-main/5 opacity-0 transition-all duration-300 group-hover/icon:opacity-100 group-hover/icon:scale-110 group-hover/icon:bg-main/10 ring-1 ring-main/10"></div>
                                    {project.data.tags.includes('n8n') ? (
                                        <>
                                            <img src="https://cdn.simpleicons.org/n8n" class="relative z-10 h-5 w-5 dark:hidden opacity-90" alt="n8n" />
                                            <img src="https://cdn.simpleicons.org/n8n/white" class="relative z-10 h-5 w-5 hidden dark:block opacity-90" alt="n8n" />
                                        </>
                                    ) : (
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="relative z-10 h-3.5 w-3.5 opacity-90"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                                    )}
                                </a>
                            )}
                        </div>
                        <span class="text-[10px] font-bold tracking-[0.15em] text-main/30 uppercase font-sans">YEAR {project.data.publishDate.getFullYear()}</span>
                    </div>
                </div>
            </div>
        ))}
    </div>

    <!-- Cards View Container (Detailed Grid) - DEFAULT -->
    <div id="cards-container" class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 transition-all duration-300">
        {portfolio.map((project) => (
            <div 
                class="project-card spotlight-card group relative flex flex-col p-4 shadow-sm" 
                style={`--spotlight-color: ${spotlightColors[project.data.title.length % spotlightColors.length]};`}
                data-tags={project.data.tags.join(',')}
                data-date={project.data.publishDate.getTime()}
                data-title={project.data.title.toLowerCase()}
            >
                <div class="spotlight-glow"></div>
                <a href={`/projects/${project.id}/`} class="flex-grow">
                    <div class="aspect-video w-full overflow-hidden rounded-xl border border-main-border/5 bg-main-bg/10 mb-4">
                        {project.data.seo?.image ? (
                            <img 
                                src={project.data.seo.image.src.src} 
                                alt={project.data.title}
                                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                            />
                        ) : (
                            <div class="flex h-full w-full items-center justify-center text-main/55 text-xs">No preview</div>
                        )}
                    </div>
                    <h3 class="font-serif text-base font-bold leading-tight line-clamp-2 py-0.5 mb-2 text-main">
                        <span class="premium-line-hover">{project.data.title}</span>
                    </h3>
                    {project.data.description && (
                        <p class="text-xs text-main/90 line-clamp-3 mb-4 leading-relaxed font-sans">{project.data.description}</p>
                    )}
                </a>
                
                <!-- Card Meta -->
                <div class="mt-auto flex items-center justify-between pt-3 border-t border-main-border/5">
                    <div class="flex items-center gap-1.5">
                        {project.data.github && (
                            <a 
                                href={project.data.github} 
                                target="_blank" 
                                rel="noopener noreferrer" 
                                class="group/icon premium-tooltip relative flex h-8 w-8 items-center justify-center transition-all duration-300 hover:scale-115" 
                                data-tooltip="GitHub"
                            >
                                <div class="absolute inset-0 rounded-xl bg-main/5 opacity-0 transition-all duration-300 group-hover/icon:opacity-100 group-hover/icon:scale-110 group-hover/icon:bg-main/10 ring-1 ring-main/10"></div>
                                <img src="https://cdn.simpleicons.org/github" class="relative z-10 h-4 w-4 dark:hidden opacity-90" alt="GitHub" />
                                <img src="https://cdn.simpleicons.org/github/white" class="relative z-10 h-4 w-4 hidden dark:block opacity-90" alt="GitHub" />
                            </a>
                        )}
                        {project.data.paper && (
                            <a 
                                href={project.data.paper} 
                                target="_blank" 
                                rel="noopener noreferrer" 
                                class="group/icon premium-tooltip relative flex h-8 w-8 items-center justify-center transition-all duration-300 hover:scale-115" 
                                data-tooltip={project.data.paper.includes('kaggle.com') ? "Kaggle Competition" : "Research/Project Document"}
                            >
                                <div class="absolute inset-0 rounded-xl bg-main/5 opacity-0 transition-all duration-300 group-hover/icon:opacity-100 group-hover/icon:scale-110 group-hover/icon:bg-main/10 ring-1 ring-main/10"></div>
                                {project.data.paper.includes('kaggle.com') ? (
                                    <>
                                        <img src="https://cdn.simpleicons.org/kaggle" class="relative z-10 h-5 w-5 dark:hidden opacity-90" alt="Kaggle" />
                                        <img src="https://cdn.simpleicons.org/kaggle/white" class="relative z-10 h-5 w-5 hidden dark:block opacity-90" alt="Kaggle" />
                                    </>
                                ) : (
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="relative z-10 h-3.5 w-3.5 opacity-90"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                                )}
                            </a>
                        )}
                        {project.data.demo && (
                            <a 
                                href={project.data.demo} 
                                target="_blank" 
                                rel="noopener noreferrer" 
                                class="group/icon premium-tooltip relative flex h-8 w-8 items-center justify-center transition-all duration-300 hover:scale-115" 
                                data-tooltip="Live Demo"
                            >
                                <div class="absolute inset-0 rounded-xl bg-main/5 opacity-0 transition-all duration-300 group-hover/icon:opacity-100 group-hover/icon:scale-110 group-hover/icon:bg-main/10 ring-1 ring-main/10"></div>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="relative z-10 h-3.5 w-3.5 opacity-90"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                            </a>
                        )}
                        {project.data.external && (
                            <a 
                                href={project.data.external} 
                                target="_blank" 
                                rel="noopener noreferrer" 
                                class="group/icon premium-tooltip relative flex h-8 w-8 items-center justify-center transition-all duration-300 hover:scale-115" 
                                data-tooltip={project.data.tags.includes('n8n') ? "n8n Workflows" : "External Link"}
                            >
                                <div class="absolute inset-0 rounded-xl bg-main/5 opacity-0 transition-all duration-300 group-hover/icon:opacity-100 group-hover/icon:scale-110 group-hover/icon:bg-main/10 ring-1 ring-main/10"></div>
                                {project.data.tags.includes('n8n') ? (
                                    <>
                                        <img src="https://cdn.simpleicons.org/n8n" class="relative z-10 h-5 w-5 dark:hidden opacity-90" alt="n8n" />
                                        <img src="https://cdn.simpleicons.org/n8n/white" class="relative z-10 h-5 w-5 hidden dark:block opacity-90" alt="n8n" />
                                    </>
                                ) : (
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="relative z-10 h-3.5 w-3.5 opacity-90"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                                )}
                            </a>
                        )}
                    </div>
                    <span class="text-[10px] font-bold tracking-[0.15em] text-main/30 uppercase font-sans">YEAR {project.data.publishDate.getFullYear()}</span>
                </div>
            </div>
        ))}
    </div>

    <div id="list-container" class="hidden flex flex-col gap-4 transition-all duration-300">
        {portfolio.map((project) => (
            <div class="project-card" data-tags={project.data.tags.join(',')}>
                <ProjectPreview project={project} />
            </div>
        ))}
    </div>

    <Pagination page={page} class="my-16 sm:my-24" />
</BaseLayout>

<style>
    @reference "../../styles/global.css";
    .active-view {
        @apply bg-main text-main-bg shadow-md scale-105;
    }
    .tag-filter-btn {
        @apply bg-main-bg/5 border-main-border/10 transition-all hover:bg-main-bg/10;
    }
    .active-tag {
        @apply bg-main text-main-bg border-main shadow-lg shadow-main/20 scale-105;
    }
    .active-tag svg {
        @apply text-main-bg opacity-100;
    }
</style>

<script>
    function initViewSwitcher() {
        const galleryBtn = document.getElementById('view-gallery');
        const cardsBtn = document.getElementById('view-cards');
        const listBtn = document.getElementById('view-list');
        
        const galleryContainer = document.getElementById('gallery-container');
        const cardsContainer = document.getElementById('cards-container');
        const listContainer = document.getElementById('list-container');

        const buttons = [galleryBtn, cardsBtn, listBtn];
        const containers = [galleryContainer, cardsContainer, listContainer];

        if (buttons.some(b => !b) || containers.some(c => !c)) return;

        // Check local storage for saved preference, default to cards
        const savedView = localStorage.getItem('projects-view') || 'cards';
        switchTo(savedView as any);

        galleryBtn?.addEventListener('click', () => switchTo('gallery'));
        cardsBtn?.addEventListener('click', () => switchTo('cards'));
        listBtn?.addEventListener('click', () => switchTo('list'));

        function switchTo(view: 'gallery' | 'cards' | 'list') {
            containers.forEach(c => c?.classList.add('hidden'));
            buttons.forEach(b => {
                if (b) {
                    b.classList.remove('active-view');
                    b.classList.add('text-main/40');
                }
            });

            const activeContainer = document.getElementById(`${view}-container`);
            const activeBtn = document.getElementById(`view-${view}`);
            const highlight = document.querySelector('.view-highlight') as HTMLElement;

            if (activeBtn && highlight) {
                const bRect = activeBtn.getBoundingClientRect();
                const cRect = highlight.parentElement!.getBoundingClientRect();
                highlight.style.width = `${bRect.width}px`;
                highlight.style.height = `${bRect.height}px`;
                highlight.style.left = `${bRect.left - cRect.left}px`;
                highlight.style.top = `${bRect.top - cRect.top}px`;
            }

            activeContainer?.classList.remove('hidden');
            if (activeBtn) {
                activeBtn.classList.remove('text-main/40');
                activeBtn.classList.add('active-view');
            }
            
            localStorage.setItem('projects-view', view);
        }
    }

    // Dropdown Handling
    const dropdowns = document.querySelectorAll('.dropdown-container');
    
    dropdowns.forEach(dropdown => {
        const trigger = dropdown.querySelector('.dropdown-trigger');
        const menu = dropdown.querySelector('.dropdown-menu');
        const chevron = dropdown.querySelector('.chevron');

        trigger?.addEventListener('click', (e) => {
            e.stopPropagation();
            const isHidden = menu?.classList.contains('hidden');
            
            // Close all
            dropdowns.forEach(other => {
                other.querySelector('.dropdown-menu')?.classList.add('hidden');
                other.querySelector('.chevron')?.classList.remove('rotate-180');
            });

            if (isHidden) {
                menu?.classList.remove('hidden');
                chevron?.classList.add('rotate-180');
            }
        });
    });

    document.addEventListener('click', () => {
        dropdowns.forEach(dropdown => {
            dropdown.querySelector('.dropdown-menu')?.classList.add('hidden');
            dropdown.querySelector('.chevron')?.classList.remove('rotate-180');
        });
    });

    // Filtering & Search Logic
    const filterButtons = document.querySelectorAll('.tag-filter-btn');
    const sortButtons = document.querySelectorAll('.sort-btn');
    const projectSearch = document.getElementById('project-search') as HTMLInputElement;
    const projectCards = document.querySelectorAll<HTMLElement>('.project-card');

    let currentCategory = 'all';
    let currentSort = 'newest';
    let searchQuery = '';

    function sortProjects() {
        const containers = [
            document.getElementById('cards-container'),
            document.getElementById('gallery-container')
        ];
        
        containers.forEach(container => {
            if (!container) return;
            
            const cardArray = Array.from(container.querySelectorAll<HTMLElement>('.project-card'));
            const sorted = cardArray.sort((a, b) => {
                if (currentSort === 'az') {
                    return (a.dataset.title || '').localeCompare(b.dataset.title || '');
                }
                const dateA = parseInt(a.dataset.date || '0');
                const dateB = parseInt(b.dataset.date || '0');
                return currentSort === 'newest' ? dateB - dateA : dateA - dateB;
            });

            sorted.forEach(p => container.appendChild(p));
        });
    }

    function applyFilters() {
        projectCards.forEach(card => {
            const tags = (card.dataset.tags || '').split(',');
            const title = card.querySelector('h3')?.textContent?.toLowerCase() || '';
            const desc = card.querySelector('p')?.textContent?.toLowerCase() || '';
            
            const matchesCategory = currentCategory === 'all' || tags.includes(currentCategory);
            const matchesSearch = title.includes(searchQuery) || desc.includes(searchQuery) || tags.some(t => t.includes(searchQuery));
            
            if (matchesCategory && matchesSearch) {
                card.classList.remove('hidden');
                card.style.display = '';
            } else {
                card.classList.add('hidden');
                card.style.display = 'none';
            }
        });
        
        sortProjects();
    }

    filterButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            currentCategory = (btn as HTMLElement).dataset.tagFilter!;
            
            // UI Updates
            filterButtons.forEach(b => {
                const indicator = b.querySelector('.active-indicator');
                b.classList.remove('text-main');
                b.classList.add('text-main/60');
                indicator?.classList.remove('opacity-100');
                indicator?.classList.add('opacity-0');
            });
            btn.classList.add('text-main');
            btn.classList.remove('text-main/60');
            btn.querySelector('.active-indicator')?.classList.remove('opacity-0');
            btn.querySelector('.active-indicator')?.classList.add('opacity-100');

            const label = document.getElementById('current-category');
            if (label) label.textContent = btn.textContent?.trim() || 'All Categories';
            applyFilters();
        });
    });

    sortButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            currentSort = (btn as HTMLElement).dataset.sort!;

            // UI Updates
            sortButtons.forEach(b => {
                const indicator = b.querySelector('.active-indicator');
                b.classList.remove('text-main');
                b.classList.add('text-main/60');
                indicator?.classList.remove('opacity-100');
                indicator?.classList.add('opacity-0');
            });
            btn.classList.add('text-main');
            btn.classList.remove('text-main/60');
            btn.querySelector('.active-indicator')?.classList.remove('opacity-0');
            btn.querySelector('.active-indicator')?.classList.add('opacity-100');

            const label = document.getElementById('current-sort');
            if (label) label.textContent = btn.textContent?.trim() || 'Newest';
            applyFilters();
        });
    });

    projectSearch?.addEventListener('input', (e) => {
        searchQuery = (e.target as HTMLInputElement).value.toLowerCase();
        applyFilters();
    });

    // Init on first load
    initViewSwitcher();
    // Re-init on page navigation
    document.addEventListener('astro:page-load', initViewSwitcher);
</script>
