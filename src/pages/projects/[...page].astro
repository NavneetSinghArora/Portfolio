---
export const prerender = true;
import type { GetStaticPathsOptions, Page } from 'astro';
import { type CollectionEntry, getCollection } from 'astro:content';
import Pagination from '../../components/Pagination.astro';
import ProjectThumbnail from '../../components/ProjectThumbnail.astro';
import ProjectPreview from '../../components/ProjectPreview.astro';
import siteConfig from '../../data/site-config';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortItemsByDateDesc } from '../../utils/data-utils';
import LayoutGrid from '../../assets/icons/layout-grid.svg';
import ListIcon from '../../assets/icons/list.svg';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const projects = (await getCollection('projects')).sort(sortItemsByDateDesc);
    return paginate(projects, { pageSize: siteConfig.projectsPerPage || 12 });
}

type Props = { page: Page<CollectionEntry<'projects'>> };

const { page } = Astro.props;
const portfolio = page.data;
const allTags = [...new Set(portfolio.flatMap(p => p.data.tags))].sort();
---

<BaseLayout title="Portfolio" description="Explore a diverse portfolio showcasing my passion and expertise">
    <div class="mb-12 flex flex-col justify-between gap-6 sm:mb-16 sm:flex-row sm:items-end">
        <div>
            <h1 class="font-serif text-2xl leading-tight sm:text-4xl text-main">Projects</h1>
            <p class="mt-2 text-sm text-main/60 max-w-md">Technical research, engineering implementations, and academic reviews.</p>
        </div>
        
        <!-- View Switcher -->
        <div class="flex items-center gap-1 self-start rounded-xl border border-main-border/10 bg-main-bg/5 p-1">
            <button 
                id="view-cards" 
                class="flex h-9 w-9 items-center justify-center rounded-lg transition-all hover:bg-main-bg/5 text-main active-view"
                title="Card View"
            >
                <div class="h-4 w-4">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-full w-full"><rect width="18" height="18" x="3" y="3" rx="2"></rect><path d="M3 9h18"></path><path d="M9 21V9"></path></svg>
                </div>
            </button>
            <button 
                id="view-gallery" 
                class="flex h-9 w-9 items-center justify-center rounded-lg transition-all hover:bg-main-bg/5 text-main/40"
                title="Gallery View"
            >
                <div class="h-4 w-4">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-full w-full"><rect width="7" height="7" x="3" y="3" rx="1"></rect><rect width="7" height="7" x="14" y="3" rx="1"></rect><rect width="7" height="7" x="14" y="14" rx="1"></rect><rect width="7" height="7" x="3" y="14" rx="1"></rect></svg>
                </div>
            </button>
            <button 
                id="view-list" 
                class="flex h-9 w-9 items-center justify-center rounded-lg transition-all hover:bg-main-bg/5 text-main/40"
                title="List View"
            >
                <div class="h-4 w-4">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-full w-full"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
                </div>
            </button>
        </div>
    </div>

    <!-- Tag Filter Bar -->
    {allTags.length > 0 && (
        <div class="mb-8 flex flex-wrap items-center gap-2">
            <button
                data-tag-filter="all"
                class="tag-filter-btn active-tag text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full border border-main-border/20 text-main/80 transition-all hover:border-main-border/60"
            >
                All
            </button>
            {allTags.map(tag => (
                <button
                    data-tag-filter={tag}
                    class="tag-filter-btn text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full border border-main-border/10 text-main/40 transition-all hover:border-main-border/40 hover:text-main/70"
                >
                    {tag}
                </button>
            ))}
        </div>
    )}

    <!-- Gallery View Container (Horizontal List / Visual List) -->
    <div id="gallery-container" class="hidden flex flex-col gap-6 transition-all duration-300">
        {portfolio.map((project) => (
            <div class="project-card group relative flex flex-col sm:flex-row gap-6 p-6 rounded-2xl border border-main-border/20 bg-main-bg/10 hover:bg-main-bg/20 transition-all backdrop-blur-md shadow-sm overflow-hidden" data-tags={project.data.tags.join(',')}>
                <!-- Visual & Meta Column (Left) -->
                <div class="w-full sm:w-48 lg:w-64 shrink-0 flex flex-col gap-4">
                    <a href={`/projects/${project.id}/`} class="block aspect-square sm:aspect-video rounded-xl overflow-hidden border border-main-border/5">
                        {project.data.seo?.image ? (
                            <img 
                                src={project.data.seo.image.src.src} 
                                alt={project.data.title}
                                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                            />
                        ) : (
                            <div class="flex h-full w-full items-center justify-center bg-main-bg/10 text-main/55 text-xs">No preview</div>
                        )}
                    </a>

                    <!-- Meta moved below image -->
                    <div class="flex items-center justify-between px-1">
                        <div class="flex items-center gap-3">
                            {project.data.github && (
                                <a href={project.data.github} target="_blank" rel="noopener noreferrer" class="opacity-40 hover:opacity-100 transition-opacity" title="GitHub Repository">
                                    <img src="https://cdn.simpleicons.org/github" class="h-3.5 w-3.5 dark:hidden" alt="GitHub" />
                                    <img src="https://cdn.simpleicons.org/github/white" class="h-3.5 w-3.5 hidden dark:block" alt="GitHub" />
                                </a>
                            )}
                            {project.data.paper && (
                                <a href={project.data.paper} target="_blank" rel="noopener noreferrer" class="opacity-40 hover:opacity-100 transition-opacity" title={project.data.paper.includes('kaggle.com') ? "Kaggle Competition" : "Research/Project Document"}>
                                    {project.data.paper.includes('kaggle.com') ? (
                                        <div class="flex items-center">
                                            <img src="https://cdn.simpleicons.org/kaggle" class="h-5 w-5 dark:hidden" alt="Kaggle" />
                                            <img src="https://cdn.simpleicons.org/kaggle/white" class="h-5 w-5 hidden dark:block" alt="Kaggle" />
                                        </div>
                                    ) : (
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                                    )}
                                </a>
                            )}
                            {project.data.demo && (
                                <a href={project.data.demo} target="_blank" rel="noopener noreferrer" class="opacity-40 hover:opacity-100 transition-opacity" title="Live Demo">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                                </a>
                            )}
                            {project.data.external && (
                                <a 
                                    href={project.data.external} 
                                    target="_blank" 
                                    rel="noopener noreferrer" 
                                    class="opacity-40 hover:opacity-100 transition-opacity" 
                                    title={project.data.tags.includes('n8n') ? "Technical implementation and research artifacts associated with this project." : "External Link"}
                                >
                                    {project.data.tags.includes('n8n') ? (
                                        <div class="flex items-center">
                                            <img src="https://cdn.simpleicons.org/n8n" class="h-3.5 w-3.5 dark:hidden" alt="n8n" />
                                            <img src="https://cdn.simpleicons.org/n8n/white" class="h-3.5 w-3.5 hidden dark:block" alt="n8n" />
                                        </div>
                                    ) : (
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                                    )}
                                </a>
                            )}
                        </div>
                        <span class="text-xs font-bold uppercase tracking-widest text-main/55">Year {project.data.publishDate.getFullYear()}</span>
                    </div>
                </div>

                <!-- Content & Action Section (Right) -->
                <div class="flex-grow flex flex-col justify-between">
                    <div>
                        <a href={`/projects/${project.id}/`}>
                            <h3 class="font-serif text-xl sm:text-2xl font-bold leading-tight mb-4 group-hover:underline group-hover:decoration-dashed decoration-main/20 text-main">{project.data.title}</h3>
                        </a>
                        <div class="space-y-4">
                            {project.data.description?.split('. ').slice(0, 4).map((point) => (
                                <p class="text-xs text-main/90 leading-relaxed font-sans text-justify">
                                    {point}{point.endsWith('.') ? '' : '.'}
                                </p>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        ))}
    </div>

    <!-- Cards View Container (Detailed Grid) - DEFAULT -->
    <div id="cards-container" class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 transition-all duration-300">
        {portfolio.map((project) => (
            <div class="project-card group relative flex flex-col rounded-2xl border border-main-border/20 bg-main-bg/10 p-4 transition-all hover:bg-main-bg/20 backdrop-blur-md shadow-sm" data-tags={project.data.tags.join(',')}>
                <a href={`/projects/${project.id}/`} class="flex-grow">
                    <div class="aspect-video w-full overflow-hidden rounded-xl border border-main-border/5 bg-main-bg/10 mb-4">
                        {project.data.seo?.image ? (
                            <img 
                                src={project.data.seo.image.src.src} 
                                alt={project.data.title}
                                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                            />
                        ) : (
                            <div class="flex h-full w-full items-center justify-center text-main/55 text-xs">No preview</div>
                        )}
                    </div>
                    <h3 class="font-serif text-base font-bold leading-tight line-clamp-2 mb-2 group-hover:underline group-hover:decoration-dashed text-main">{project.data.title}</h3>
                    {project.data.description && (
                        <p class="text-xs text-main/90 line-clamp-3 mb-4 leading-relaxed font-sans">{project.data.description}</p>
                    )}
                </a>
                
                <!-- Card Meta -->
                <div class="mt-auto flex items-center justify-between pt-3 border-t border-main-border/5">
                    <div class="flex items-center gap-2">
                        {project.data.github && (
                            <a href={project.data.github} target="_blank" rel="noopener noreferrer" class="opacity-40 hover:opacity-100 transition-opacity" title="GitHub Repository">
                                <img src="https://cdn.simpleicons.org/github" class="h-3.5 w-3.5 dark:hidden" alt="GitHub" />
                                <img src="https://cdn.simpleicons.org/github/white" class="h-3.5 w-3.5 hidden dark:block" alt="GitHub" />
                            </a>
                        )}
                        {project.data.paper && (
                            <a href={project.data.paper} target="_blank" rel="noopener noreferrer" class="opacity-40 hover:opacity-100 transition-opacity" title={project.data.paper.includes('kaggle.com') ? "Kaggle Competition" : "Research/Project Document"}>
                                {project.data.paper.includes('kaggle.com') ? (
                                    <div class="flex items-center">
                                        <img src="https://cdn.simpleicons.org/kaggle" class="h-4.5 w-4.5 dark:hidden scale-110" alt="Kaggle" />
                                        <img src="https://cdn.simpleicons.org/kaggle/white" class="h-4.5 w-4.5 hidden dark:block scale-110" alt="Kaggle" />
                                    </div>
                                ) : (
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                                )}
                            </a>
                        )}
                        {project.data.demo && (
                            <a href={project.data.demo} target="_blank" rel="noopener noreferrer" class="opacity-40 hover:opacity-100 transition-opacity" title="Live Demo">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                            </a>
                        )}
                        {project.data.external && (
                            <a 
                                href={project.data.external} 
                                target="_blank" 
                                rel="noopener noreferrer" 
                                class="opacity-40 hover:opacity-100 transition-opacity" 
                                title={project.data.tags.includes('n8n') ? "Technical implementation and research artifacts associated with this project." : "External Link"}
                            >
                                {project.data.tags.includes('n8n') ? (
                                    <div class="flex items-center">
                                        <img src="https://cdn.simpleicons.org/n8n" class="h-3.5 w-3.5 dark:hidden" alt="n8n" />
                                        <img src="https://cdn.simpleicons.org/n8n/white" class="h-3.5 w-3.5 hidden dark:block" alt="n8n" />
                                    </div>
                                ) : (
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                                )}
                            </a>
                        )}
                    </div>
                    <span class="text-xs font-bold uppercase tracking-widest text-main/55">{project.data.publishDate.getFullYear()}</span>
                </div>
            </div>
        ))}
    </div>

    <div id="list-container" class="hidden flex flex-col gap-8 transition-all duration-300">
        {portfolio.map((project) => (
            <div class="project-card" data-tags={project.data.tags.join(',')}>
                <ProjectPreview project={project} />
            </div>
        ))}
    </div>

    <Pagination page={page} class="my-16 sm:my-24" />
</BaseLayout>

<style>
    @reference "../../styles/global.css";
    .active-view {
        @apply bg-main-bg/10 text-main shadow-sm;
    }
    .active-tag {
        @apply border-main-border/60 text-main bg-main-bg/10;
    }
</style>

<script>
    function initViewSwitcher() {
        const galleryBtn = document.getElementById('view-gallery');
        const cardsBtn = document.getElementById('view-cards');
        const listBtn = document.getElementById('view-list');
        
        const galleryContainer = document.getElementById('gallery-container');
        const cardsContainer = document.getElementById('cards-container');
        const listContainer = document.getElementById('list-container');

        const buttons = [galleryBtn, cardsBtn, listBtn];
        const containers = [galleryContainer, cardsContainer, listContainer];

        if (buttons.some(b => !b) || containers.some(c => !c)) return;

        // Check local storage for saved preference, default to cards
        const savedView = localStorage.getItem('projects-view') || 'cards';
        switchTo(savedView as any);

        galleryBtn?.addEventListener('click', () => switchTo('gallery'));
        cardsBtn?.addEventListener('click', () => switchTo('cards'));
        listBtn?.addEventListener('click', () => switchTo('list'));

        function switchTo(view: 'gallery' | 'cards' | 'list') {
            containers.forEach(c => c?.classList.add('hidden'));
            buttons.forEach(b => {
                b?.classList.remove('active-view');
                b?.classList.add('text-main/40');
            });

            const activeContainer = document.getElementById(`${view}-container`);
            const activeBtn = document.getElementById(`view-${view}`);

            activeContainer?.classList.remove('hidden');
            activeBtn?.classList.remove('text-main/40');
            activeBtn?.classList.add('active-view');
            
            localStorage.setItem('projects-view', view);
        }
    }

    // --- Tag Filter ---
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('.tag-filter-btn');
    const projectCards = document.querySelectorAll<HTMLElement>('.project-card');

    filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const tag = btn.dataset.tagFilter!;
            filterBtns.forEach(b => b.classList.remove('active-tag'));
            btn.classList.add('active-tag');
            projectCards.forEach(card => {
                if (tag === 'all') {
                    card.style.display = '';
                } else {
                    const cardTags = (card.dataset.tags || '').split(',');
                    card.style.display = cardTags.includes(tag) ? '' : 'none';
                }
            });
        });
    });

    // Init on first load
    initViewSwitcher();
    // Re-init on page navigation
    document.addEventListener('astro:page-load', initViewSwitcher);
</script>
