---
export const prerender = true;
import type { GetStaticPathsOptions, Page } from 'astro';
import { type CollectionEntry, getCollection } from 'astro:content';
import Pagination from '../../components/Pagination.astro';
import ProjectThumbnail from '../../components/ProjectThumbnail.astro';
import ProjectPreview from '../../components/ProjectPreview.astro';
import siteConfig from '../../data/site-config';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortItemsByDateDesc } from '../../utils/data-utils';
import LayoutGrid from '../../assets/icons/layout-grid.svg';
import ListIcon from '../../assets/icons/list.svg';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const projects = (await getCollection('projects')).sort(sortItemsByDateDesc);
    return paginate(projects, { pageSize: siteConfig.projectsPerPage || 12 });
}

type Props = { page: Page<CollectionEntry<'projects'>> };

const { page } = Astro.props;
const portfolio = page.data;
const allTags = [...new Set(portfolio.flatMap(p => p.data.tags))].sort();
---

<BaseLayout title="Portfolio" description="Explore a diverse portfolio showcasing my passion and expertise">
    <div class="mb-12 flex flex-col justify-between gap-6 sm:mb-16 sm:flex-row sm:items-end">
        <div>
            <h1 class="font-serif text-2xl leading-tight sm:text-4xl text-main">Projects</h1>
            <p class="mt-2 text-sm text-main/60 max-w-md">Technical research, engineering implementations, and academic reviews.</p>
        </div>
        
        <!-- View Switcher -->
        <div class="flex items-center gap-1 self-start rounded-xl border border-main-border/10 bg-main-bg/5 p-1">
            <button 
                id="view-cards" 
                class="flex h-9 w-9 items-center justify-center rounded-lg transition-all hover:bg-main-bg/5 text-main active-view"
                title="Card View"
            >
                <div class="h-4 w-4">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-full w-full"><rect width="18" height="18" x="3" y="3" rx="2"></rect><path d="M3 9h18"></path><path d="M9 21V9"></path></svg>
                </div>
            </button>
            <button 
                id="view-gallery" 
                class="flex h-9 w-9 items-center justify-center rounded-lg transition-all hover:bg-main-bg/5 text-main/40"
                title="Gallery View"
            >
                <div class="h-4 w-4">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-full w-full"><rect width="7" height="7" x="3" y="3" rx="1"></rect><rect width="7" height="7" x="14" y="3" rx="1"></rect><rect width="7" height="7" x="14" y="14" rx="1"></rect><rect width="7" height="7" x="3" y="14" rx="1"></rect></svg>
                </div>
            </button>
            <button 
                id="view-list" 
                class="flex h-9 w-9 items-center justify-center rounded-lg transition-all hover:bg-main-bg/5 text-main/40"
                title="List View"
            >
                <div class="h-4 w-4">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-full w-full"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
                </div>
            </button>
        </div>
    </div>

    <!-- Premium Filter Console -->
    <div class="mb-12 space-y-4">
        <!-- Search Bar -->
        <div class="relative group">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-main/40 group-focus-within:text-blue-500 transition-colors"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
            <input 
                type="text" 
                id="project-search" 
                placeholder="Search projects by name, tag, or technology..." 
                class="w-full bg-main-bg/5 hover:bg-main-bg/10 border border-main-border/10 rounded-xl py-3 pl-12 pr-4 text-[14px] text-main placeholder:text-main/40 focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500/30 transition-all shadow-sm"
            />
        </div>

        <!-- Dropdowns Row -->
        <div class="flex flex-wrap items-center gap-3">
            <!-- Category Dropdown -->
            <div class="relative dropdown-container" id="category-dropdown">
                <button class="dropdown-trigger flex items-center justify-between gap-3 px-4 py-2.5 min-w-[160px] bg-main-bg/5 hover:bg-main-bg/10 border border-main-border/10 rounded-xl text-[14px] font-medium text-main/60 hover:text-main transition-all shadow-sm">
                    <div class="flex items-center gap-2">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 opacity-40"><rect width="7" height="7" x="3" y="3" rx="1"></rect><rect width="7" height="7" x="14" y="3" rx="1"></rect><rect width="7" height="7" x="14" y="14" rx="1"></rect><rect width="7" height="7" x="3" y="14" rx="1"></rect></svg>
                        <span id="current-category">All Categories</span>
                    </div>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 opacity-30 chevron transition-transform"><path d="m6 9 6 6 6-6"></path></svg>
                </button>
                
                <div class="dropdown-menu hidden absolute top-full left-0 mt-2 w-64 bg-main-card/95 backdrop-blur-xl border border-main-border/10 rounded-xl shadow-2xl p-2 z-50 animate-in fade-in slide-in-from-top-2 duration-200">
                    <button data-tag-filter="all" class="tag-filter-btn flex items-center gap-3 w-full px-3 py-2 rounded-lg text-[13px] text-main/60 hover:text-main hover:bg-main-bg/10 transition-all text-left">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 opacity-40"><rect width="18" height="18" x="3" y="3" rx="2"></rect><path d="M3 9h18"></path><path d="M9 21V9"></path></svg>
                        All Projects
                    </button>
                    <div class="my-1 border-t border-main-border/5"></div>
                    {allTags.map(tag => (
                        <button data-tag-filter={tag} class="tag-filter-btn flex items-center gap-3 w-full px-3 py-2 rounded-lg text-[13px] text-main/60 hover:text-main hover:bg-main-bg/10 transition-all text-left">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 opacity-40"><path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"></path><path d="M7 7h.01"></path></svg>
                            {tag}
                        </button>
                    ))}
                </div>
            </div>

            <!-- Sort Dropdown -->
            <div class="relative dropdown-container" id="sort-dropdown">
                <button class="dropdown-trigger flex items-center justify-between gap-3 px-5 py-2.5 min-w-[140px] bg-main-bg/5 hover:bg-main-bg/10 border border-main-border/5 rounded-xl text-[14px] font-medium text-main/60 hover:text-main transition-all shadow-sm">
                    <div class="flex items-center gap-2">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 opacity-40"><path d="m21 16-4 4-4-4"></path><path d="M17 20V4"></path><path d="m3 8 4-4 4 4"></path><path d="M7 4v16"></path></svg>
                        <span id="current-sort">Newest</span>
                    </div>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 opacity-30 chevron transition-transform"><path d="m6 9 6 6 6-6"></path></svg>
                </button>
                
                <div class="dropdown-menu hidden absolute top-full left-0 mt-2 w-48 bg-main-card/95 backdrop-blur-xl border border-main-border/10 rounded-xl shadow-2xl p-2 z-50 animate-in fade-in slide-in-from-top-2 duration-200">
                    <button class="sort-btn flex items-center gap-3 w-full px-3 py-2 rounded-lg text-[13px] text-main/60 hover:text-main hover:bg-main-bg/10 transition-all text-left active-sort" data-sort="newest">
                        Newest First
                    </button>
                    <button class="sort-btn flex items-center gap-3 w-full px-3 py-2 rounded-lg text-[13px] text-main/60 hover:text-main hover:bg-main-bg/10 transition-all text-left" data-sort="oldest">
                        Oldest First
                    </button>
                    <button class="sort-btn flex items-center gap-3 w-full px-3 py-2 rounded-lg text-[13px] text-main/60 hover:text-main hover:bg-main-bg/10 transition-all text-left" data-sort="az">
                        Alphabetical (A-Z)
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Gallery View Container (Horizontal List / Visual List) -->
    <div id="gallery-container" class="hidden flex flex-col gap-6 transition-all duration-300">
        {portfolio.map((project) => (
            <div 
                class="project-card group relative flex flex-col sm:flex-row gap-6 p-6 rounded-2xl border border-main-border/20 bg-main-bg/10 transition-all hover:bg-main-bg/20 backdrop-blur-md shadow-sm" 
                data-tags={project.data.tags.join(',')}
                data-date={project.data.publishDate.getTime()}
                data-title={project.data.title.toLowerCase()}
            >
                <!-- Visual & Meta Column (Left) -->
                <div class="w-full sm:w-48 lg:w-64 shrink-0 flex flex-col gap-4">
                    <a href={`/projects/${project.id}/`} class="block aspect-square sm:aspect-video rounded-xl overflow-hidden border border-main-border/5">
                        {project.data.seo?.image ? (
                            <img 
                                src={project.data.seo.image.src.src} 
                                alt={project.data.title}
                                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                            />
                        ) : (
                            <div class="flex h-full w-full items-center justify-center bg-main-bg/10 text-main/55 text-xs">No preview</div>
                        )}
                    </a>

                    <!-- Meta moved below image -->
                    <div class="flex items-center justify-between px-1">
                        <div class="flex items-center gap-3">
                            {project.data.github && (
                                <a href={project.data.github} target="_blank" rel="noopener noreferrer" class="opacity-40 hover:opacity-100 transition-opacity" title="GitHub Repository">
                                    <img src="https://cdn.simpleicons.org/github" class="h-3.5 w-3.5 dark:hidden" alt="GitHub" />
                                    <img src="https://cdn.simpleicons.org/github/white" class="h-3.5 w-3.5 hidden dark:block" alt="GitHub" />
                                </a>
                            )}
                            {project.data.paper && (
                                <a href={project.data.paper} target="_blank" rel="noopener noreferrer" class="opacity-40 hover:opacity-100 transition-opacity" title={project.data.paper.includes('kaggle.com') ? "Kaggle Competition" : "Research/Project Document"}>
                                    {project.data.paper.includes('kaggle.com') ? (
                                        <div class="flex items-center">
                                            <img src="https://cdn.simpleicons.org/kaggle" class="h-5 w-5 dark:hidden" alt="Kaggle" />
                                            <img src="https://cdn.simpleicons.org/kaggle/white" class="h-5 w-5 hidden dark:block" alt="Kaggle" />
                                        </div>
                                    ) : (
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                                    )}
                                </a>
                            )}
                            {project.data.demo && (
                                <a href={project.data.demo} target="_blank" rel="noopener noreferrer" class="opacity-40 hover:opacity-100 transition-opacity" title="Live Demo">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                                </a>
                            )}
                            {project.data.external && (
                                <a 
                                    href={project.data.external} 
                                    target="_blank" 
                                    rel="noopener noreferrer" 
                                    class="opacity-40 hover:opacity-100 transition-opacity" 
                                    title={project.data.tags.includes('n8n') ? "Technical implementation and research artifacts associated with this project." : "External Link"}
                                >
                                    {project.data.tags.includes('n8n') ? (
                                        <div class="flex items-center">
                                            <img src="https://cdn.simpleicons.org/n8n" class="h-3.5 w-3.5 dark:hidden" alt="n8n" />
                                            <img src="https://cdn.simpleicons.org/n8n/white" class="h-3.5 w-3.5 hidden dark:block" alt="n8n" />
                                        </div>
                                    ) : (
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                                    )}
                                </a>
                            )}
                        </div>
                        <span class="text-xs font-bold uppercase tracking-widest text-main/55">Year {project.data.publishDate.getFullYear()}</span>
                    </div>
                </div>

                <!-- Content & Action Section (Right) -->
                <div class="flex-grow flex flex-col justify-between">
                    <div>
                        <a href={`/projects/${project.id}/`}>
                            <h3 class="font-serif text-xl sm:text-2xl font-bold leading-tight mb-4 group-hover:underline group-hover:decoration-dashed decoration-main/20 text-main">{project.data.title}</h3>
                        </a>
                        <div class="space-y-4">
                            {project.data.description?.split('. ').slice(0, 4).map((point) => (
                                <p class="text-xs text-main/90 leading-relaxed font-sans text-justify">
                                    {point}{point.endsWith('.') ? '' : '.'}
                                </p>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        ))}
    </div>

    <!-- Cards View Container (Detailed Grid) - DEFAULT -->
    <div id="cards-container" class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 transition-all duration-300">
        {portfolio.map((project) => (
            <div 
                class="project-card group relative flex flex-col rounded-2xl border border-main-border/20 bg-main-bg/10 p-4 transition-all hover:bg-main-bg/20 backdrop-blur-md shadow-sm" 
                data-tags={project.data.tags.join(',')}
                data-date={project.data.publishDate.getTime()}
                data-title={project.data.title.toLowerCase()}
            >
                <a href={`/projects/${project.id}/`} class="flex-grow">
                    <div class="aspect-video w-full overflow-hidden rounded-xl border border-main-border/5 bg-main-bg/10 mb-4">
                        {project.data.seo?.image ? (
                            <img 
                                src={project.data.seo.image.src.src} 
                                alt={project.data.title}
                                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                            />
                        ) : (
                            <div class="flex h-full w-full items-center justify-center text-main/55 text-xs">No preview</div>
                        )}
                    </div>
                    <h3 class="font-serif text-base font-bold leading-tight line-clamp-2 mb-2 group-hover:underline group-hover:decoration-dashed text-main">{project.data.title}</h3>
                    {project.data.description && (
                        <p class="text-xs text-main/90 line-clamp-3 mb-4 leading-relaxed font-sans">{project.data.description}</p>
                    )}
                </a>
                
                <!-- Card Meta -->
                <div class="mt-auto flex items-center justify-between pt-3 border-t border-main-border/5">
                    <div class="flex items-center gap-2">
                        {project.data.github && (
                            <a href={project.data.github} target="_blank" rel="noopener noreferrer" class="opacity-40 hover:opacity-100 transition-opacity" title="GitHub Repository">
                                <img src="https://cdn.simpleicons.org/github" class="h-3.5 w-3.5 dark:hidden" alt="GitHub" />
                                <img src="https://cdn.simpleicons.org/github/white" class="h-3.5 w-3.5 hidden dark:block" alt="GitHub" />
                            </a>
                        )}
                        {project.data.paper && (
                            <a href={project.data.paper} target="_blank" rel="noopener noreferrer" class="opacity-40 hover:opacity-100 transition-opacity" title={project.data.paper.includes('kaggle.com') ? "Kaggle Competition" : "Research/Project Document"}>
                                {project.data.paper.includes('kaggle.com') ? (
                                    <div class="flex items-center">
                                        <img src="https://cdn.simpleicons.org/kaggle" class="h-4.5 w-4.5 dark:hidden scale-110" alt="Kaggle" />
                                        <img src="https://cdn.simpleicons.org/kaggle/white" class="h-4.5 w-4.5 hidden dark:block scale-110" alt="Kaggle" />
                                    </div>
                                ) : (
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                                )}
                            </a>
                        )}
                        {project.data.demo && (
                            <a href={project.data.demo} target="_blank" rel="noopener noreferrer" class="opacity-40 hover:opacity-100 transition-opacity" title="Live Demo">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                            </a>
                        )}
                        {project.data.external && (
                            <a 
                                href={project.data.external} 
                                target="_blank" 
                                rel="noopener noreferrer" 
                                class="opacity-40 hover:opacity-100 transition-opacity" 
                                title={project.data.tags.includes('n8n') ? "Technical implementation and research artifacts associated with this project." : "External Link"}
                            >
                                {project.data.tags.includes('n8n') ? (
                                    <div class="flex items-center">
                                        <img src="https://cdn.simpleicons.org/n8n" class="h-3.5 w-3.5 dark:hidden" alt="n8n" />
                                        <img src="https://cdn.simpleicons.org/n8n/white" class="h-3.5 w-3.5 hidden dark:block" alt="n8n" />
                                    </div>
                                ) : (
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                                )}
                            </a>
                        )}
                    </div>
                    <span class="text-xs font-bold uppercase tracking-widest text-main/55">{project.data.publishDate.getFullYear()}</span>
                </div>
            </div>
        ))}
    </div>

    <div id="list-container" class="hidden flex flex-col gap-8 transition-all duration-300">
        {portfolio.map((project) => (
            <div class="project-card" data-tags={project.data.tags.join(',')}>
                <ProjectPreview project={project} />
            </div>
        ))}
    </div>

    <Pagination page={page} class="my-16 sm:my-24" />
</BaseLayout>

<style>
    @reference "../../styles/global.css";
    .active-view {
        @apply bg-main-bg/10 text-main shadow-sm;
    }
    .tag-filter-btn {
        @apply bg-main-bg/5 border-main-border/10;
    }
    .active-tag {
        @apply bg-blue-500/10 border-blue-500 text-blue-500 shadow-lg shadow-blue-500/10 ring-2 ring-blue-500/20 scale-105;
    }
    .active-tag svg {
        @apply text-blue-500 opacity-100;
    }
</style>

<script>
    function initViewSwitcher() {
        const galleryBtn = document.getElementById('view-gallery');
        const cardsBtn = document.getElementById('view-cards');
        const listBtn = document.getElementById('view-list');
        
        const galleryContainer = document.getElementById('gallery-container');
        const cardsContainer = document.getElementById('cards-container');
        const listContainer = document.getElementById('list-container');

        const buttons = [galleryBtn, cardsBtn, listBtn];
        const containers = [galleryContainer, cardsContainer, listContainer];

        if (buttons.some(b => !b) || containers.some(c => !c)) return;

        // Check local storage for saved preference, default to cards
        const savedView = localStorage.getItem('projects-view') || 'cards';
        switchTo(savedView as any);

        galleryBtn?.addEventListener('click', () => switchTo('gallery'));
        cardsBtn?.addEventListener('click', () => switchTo('cards'));
        listBtn?.addEventListener('click', () => switchTo('list'));

        function switchTo(view: 'gallery' | 'cards' | 'list') {
            containers.forEach(c => c?.classList.add('hidden'));
            buttons.forEach(b => {
                b?.classList.remove('active-view');
                b?.classList.add('text-main/40');
            });

            const activeContainer = document.getElementById(`${view}-container`);
            const activeBtn = document.getElementById(`view-${view}`);

            activeContainer?.classList.remove('hidden');
            activeBtn?.classList.remove('text-main/40');
            activeBtn?.classList.add('active-view');
            
localStorage.setItem('projects-view', view);
        }
    }

    // Dropdown Handling
    const dropdowns = document.querySelectorAll('.dropdown-container');
    
    dropdowns.forEach(dropdown => {
        const trigger = dropdown.querySelector('.dropdown-trigger');
        const menu = dropdown.querySelector('.dropdown-menu');
        const chevron = dropdown.querySelector('.chevron');

        trigger?.addEventListener('click', (e) => {
            e.stopPropagation();
            const isHidden = menu?.classList.contains('hidden');
            
            // Close all
            dropdowns.forEach(other => {
                other.querySelector('.dropdown-menu')?.classList.add('hidden');
                other.querySelector('.chevron')?.classList.remove('rotate-180');
            });

            if (isHidden) {
                menu?.classList.remove('hidden');
                chevron?.classList.add('rotate-180');
            }
        });
    });

    document.addEventListener('click', () => {
        dropdowns.forEach(dropdown => {
            dropdown.querySelector('.dropdown-menu')?.classList.add('hidden');
            dropdown.querySelector('.chevron')?.classList.remove('rotate-180');
        });
    });

    // Filtering & Search Logic
    const filterButtons = document.querySelectorAll('.tag-filter-btn');
    const sortButtons = document.querySelectorAll('.sort-btn');
    const projectSearch = document.getElementById('project-search') as HTMLInputElement;
    const projectCards = document.querySelectorAll<HTMLElement>('.project-card');

    let currentCategory = 'all';
    let currentSort = 'newest';
    let searchQuery = '';

    function sortProjects() {
        const containers = [
            document.getElementById('cards-container'),
            document.getElementById('gallery-container')
        ];
        
        containers.forEach(container => {
            if (!container) return;
            
            const cardArray = Array.from(container.querySelectorAll<HTMLElement>('.project-card'));
            const sorted = cardArray.sort((a, b) => {
                if (currentSort === 'az') {
                    return (a.dataset.title || '').localeCompare(b.dataset.title || '');
                }
                const dateA = parseInt(a.dataset.date || '0');
                const dateB = parseInt(b.dataset.date || '0');
                return currentSort === 'newest' ? dateB - dateA : dateA - dateB;
            });

            sorted.forEach(p => container.appendChild(p));
        });
    }

    function applyFilters() {
        projectCards.forEach(card => {
            const tags = (card.dataset.tags || '').split(',');
            const title = card.querySelector('h3')?.textContent?.toLowerCase() || '';
            const desc = card.querySelector('p')?.textContent?.toLowerCase() || '';
            
            const matchesCategory = currentCategory === 'all' || tags.includes(currentCategory);
            const matchesSearch = title.includes(searchQuery) || desc.includes(searchQuery) || tags.some(t => t.includes(searchQuery));
            
            if (matchesCategory && matchesSearch) {
                card.classList.remove('hidden');
                card.style.display = '';
            } else {
                card.classList.add('hidden');
                card.style.display = 'none';
            }
        });
        
        sortProjects();
    }

    filterButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            currentCategory = (btn as HTMLElement).dataset.tagFilter!;
            const label = document.getElementById('current-category');
            if (label) label.textContent = btn.textContent?.trim() || 'All Categories';
            applyFilters();
        });
    });

    sortButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            currentSort = (btn as HTMLElement).dataset.sort!;
            const label = document.getElementById('current-sort');
            if (label) label.textContent = btn.textContent?.trim() || 'Newest';
            applyFilters();
        });
    });

    projectSearch?.addEventListener('input', (e) => {
        searchQuery = (e.target as HTMLInputElement).value.toLowerCase();
        applyFilters();
    });

    // Init on first load
    initViewSwitcher();
    // Re-init on page navigation
    document.addEventListener('astro:page-load', initViewSwitcher);
</script>
