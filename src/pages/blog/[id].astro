---
import { getEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import IconButton from '../../components/IconButton.astro';
import SocialIcon from '../../components/SocialIcon.astro';
import Button from '../../components/Button.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import PostPreview from '../../components/PostPreview.astro';
import { sortItemsByDateDesc } from '../../utils/data-utils';
import { slugify } from '../../utils/common-utils';

export async function getStaticPaths() {
    const posts = await getCollection('blog');
    return posts.map((post) => ({
        params: { id: post.id },
        props: { post }
    }));
}

const { post } = Astro.props;

if (!post) {
    return Astro.redirect('/404');
}

const posts = (await getCollection('blog')).sort(sortItemsByDateDesc);
const postIndex = posts.findIndex((p) => p.id === post.id);
const prevPost = postIndex + 1 !== posts.length ? posts[postIndex + 1] : null;
const nextPost = postIndex !== 0 ? posts[postIndex - 1] : null;

const { href } = Astro.url;
const { title, publishDate, updatedDate, excerpt, tags = [], seo, medium, banner } = post.data;
const { Content } = await render(post);
---

<BaseLayout title={seo?.title ?? title} description={seo?.description ?? excerpt} image={seo?.image} publishDate={publishDate}>
    <article class="mb-16 sm:mb-24">
        <header class="mb-8">
            <h1 class="font-serif text-3xl leading-tight font-medium sm:text-5xl sm:leading-tight">{title}</h1>
            <div class="mt-4 text-sm">
                <FormattedDate date={publishDate} />
                {
                    updatedDate && (
                        <>
                            {' '}
                            <span>
                                (Updated on <FormattedDate date={updatedDate} />)
                            </span>
                        </>
                    )
                }
            </div>
        </header>

        <!-- Banner Image -->
        {banner && (
            <div class="w-full flex justify-center mb-12">
                <div class="overflow-hidden rounded-3xl bg-main-bg/5 shadow-2xl shadow-main-bg/20">
                    <img
                        src={banner}
                        alt={title}
                        class="max-w-full h-auto max-h-[70vh] object-contain block"
                    />
                </div>
            </div>
        )}

        <!-- Resource Directory Banner (rendered from frontmatter) -->
        {medium && (
            <div class="not-prose mb-12 p-6 rounded-2xl border border-main-border/10 bg-main-bg/5 flex flex-col md:flex-row items-center justify-between gap-6 transition-colors hover:border-main-border/20">
                <div class="space-y-1.5 text-center md:text-left">
                    <h4 class="text-xs font-bold uppercase tracking-[0.2em] text-main/55">Resource Directory</h4>
                    <p class="text-sm text-main/70 font-medium font-serif">This is a summary. <br />Read the full article on Medium — and if you find it helpful, a clap or follow is always appreciated.</p>
                </div>
                <div class="flex items-center gap-3">
                    {medium && (
                        <IconButton href={medium} target="_blank" rel="noopener noreferrer" size="lg" tooltip="Read on Medium">
                            <SocialIcon name="medium" size="md" />
                        </IconButton>
                    )}
                </div>
            </div>
        )}

        <div class="prose sm:prose-lg max-w-none prose-p:leading-relaxed prose-p:text-main/90 [&>*]:max-w-[72ch]">
            <Content />
        </div>
        <div class="mt-8 flex flex-wrap items-center justify-between gap-6 text-sm sm:mt-12 sm:text-base">
            {
                tags.length > 0 && (
                    <div class="flex flex-wrap gap-x-5 gap-y-1 text-sm">
                        {tags.map((tag) => (
                            <a class="text-main" href={`/tags/${slugify(tag)}`}>
                                <span class="premium-line-hover font-medium">#{tag}</span>
                            </a>
                        ))}
                    </div>
                )
            }
            <Button class="copy-url-button" aria-label="Copy link" data-url={href} data-tooltip-default="Copy link" data-tooltip-success="Copied">Share</Button>
        </div>
    </article>
    {
        (prevPost || nextPost) && (
            <>
                <hr class="border-t border-main-border/10 my-16 sm:my-24" />
                <div>
                    <h2 class="mb-12 font-serif text-xl sm:mb-16 sm:text-2xl">Read Next</h2>
                    {nextPost && <PostPreview post={nextPost} class="mb-10 sm:mb-12" headingLevel="h3" />}
                    {prevPost && <PostPreview post={prevPost} class="mb-10 sm:mb-12" headingLevel="h3" />}
                </div>
            </>
        )
    }
</BaseLayout>

<script>
    document.addEventListener('astro:page-load', () => {
        const copyUrlButton = document.querySelector('.copy-url-button') as HTMLButtonElement;
        copyUrlButton?.addEventListener('click', async () => {
            await copyUrl(copyUrlButton);
        });

        async function copyUrl(button: HTMLButtonElement) {
            let url = button.getAttribute('data-url') || '';
            let label = button.innerText;

            await navigator.clipboard.writeText(url);

            button.innerText = 'Copied';

            setTimeout(() => {
                button.innerText = label;
            }, 2500);
        }
    });
</script>
