---
export const prerender = true;
import type { GetStaticPathsOptions, Page } from 'astro';
import { type CollectionEntry, getCollection } from 'astro:content';
import Pagination from '../../components/Pagination.astro';
import PostPreview from '../../components/PostPreview.astro';
import Subscribe from '../../components/Subscribe.astro';
import siteConfig from '../../data/site-config';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortItemsByDateDesc } from '../../utils/data-utils';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const posts = (await getCollection('blog')).sort(sortItemsByDateDesc);
    return paginate(posts, { pageSize: siteConfig.postsPerPage || 4 });
}

type Props = { page: Page<CollectionEntry<'blog'>> };

const { page } = Astro.props;
const blog = page.data;
---

<BaseLayout title="Blog" description="Embark on a journey of personal insights and experiences through my blog" showHeader={false}>
    <div class="mb-12 flex flex-col justify-between gap-6 sm:mb-16 sm:flex-row sm:items-end">
        <div>
            <h1 class="font-serif text-2xl leading-tight italic sm:text-4xl text-main">Blog Archive</h1>
            <p class="mt-2 text-sm text-main/60 max-w-md">Reflections on engineering, research, and technical explorations.</p>
        </div>
        
        <!-- View Switcher -->
        <div class="flex items-center gap-1 self-start rounded-xl border border-main-border/10 bg-main-bg/5 p-1">
            <button 
                id="view-cards" 
                class="flex h-9 w-9 items-center justify-center rounded-lg transition-all hover:bg-main-bg/5 text-main active-view"
                title="Card View"
            >
                <div class="h-4 w-4">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-full w-full"><rect width="18" height="18" x="3" y="3" rx="2"></rect><path d="M3 9h18"></path><path d="M9 21V9"></path></svg>
                </div>
            </button>
            <button 
                id="view-gallery" 
                class="flex h-9 w-9 items-center justify-center rounded-lg transition-all hover:bg-main-bg/5 text-main/40"
                title="Gallery View"
            >
                <div class="h-4 w-4">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-full w-full"><rect width="7" height="7" x="3" y="3" rx="1"></rect><rect width="7" height="7" x="14" y="3" rx="1"></rect><rect width="7" height="7" x="14" y="14" rx="1"></rect><rect width="7" height="7" x="3" y="14" rx="1"></rect></svg>
                </div>
            </button>
            <button 
                id="view-list" 
                class="flex h-9 w-9 items-center justify-center rounded-lg transition-all hover:bg-main-bg/5 text-main/40"
                title="List View"
            >
                <div class="h-4 w-4">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-full w-full"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
                </div>
            </button>
        </div>
    </div>

    <!-- Gallery View Container (Horizontal Visual List) -->
    <div id="gallery-container" class="hidden flex flex-col gap-6 transition-all duration-300">
        {blog.map((post) => (
            <div class="group relative flex flex-col sm:flex-row gap-6 p-6 rounded-2xl border border-main-border/10 bg-main-bg/5 hover:bg-main-bg/10 transition-all hover:border-main-border/20 overflow-hidden">
                <div class="w-full sm:w-48 lg:w-64 shrink-0 flex flex-col gap-4">
                    <a href={`/blog/${post.id}/`} class="block aspect-square sm:aspect-video rounded-xl overflow-hidden border border-main-border/5">
                        {post.data.seo?.image ? (
                            <img 
                                src={post.data.seo.image.src.src} 
                                alt={post.data.title}
                                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                            />
                        ) : (
                            <div class="flex h-full w-full items-center justify-center bg-main-bg/10 text-main/40 italic text-xs">No preview</div>
                        )}
                    </a>
                    <div class="flex items-center justify-between px-1">
                        <div class="flex items-center gap-2">
                             {post.data.tags.slice(0, 2).map(tag => (
                                <span class="text-[9px] uppercase tracking-wider text-main/40 px-1.5 py-0.5 rounded border border-main-border/5">{tag}</span>
                             ))}
                        </div>
                        <span class="text-[10px] font-bold uppercase tracking-widest text-main/40 italic">
                            {post.data.publishDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
                        </span>
                    </div>
                </div>

                <div class="flex-grow flex flex-col justify-between">
                    <div>
                        <a href={`/blog/${post.id}/`}>
                            <h3 class="font-serif text-xl sm:text-2xl font-bold leading-tight mb-4 group-hover:underline group-hover:decoration-dashed decoration-main/20 text-main">{post.data.title}</h3>
                        </a>
                        <div class="space-y-4">
                            {post.data.excerpt && (
                                <p class="text-xs text-main/80 leading-relaxed font-sans text-justify italic">
                                    {post.data.excerpt}
                                </p>
                            )}
                        </div>
                    </div>
                </div>
            </div>
        ))}
    </div>

    <!-- Cards View Container (Default Grid) -->
    <div id="cards-container" class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 transition-all duration-300">
        {blog.map((post) => (
            <div class="group relative flex flex-col rounded-2xl border border-main-border/10 bg-main-bg/5 p-4 transition-all hover:border-main-border/20 hover:bg-main-bg/10">
                <a href={`/blog/${post.id}/`} class="flex-grow">
                    <div class="aspect-video w-full overflow-hidden rounded-xl border border-main-border/5 bg-main-bg/10 mb-4">
                        {post.data.seo?.image ? (
                            <img 
                                src={post.data.seo.image.src.src} 
                                alt={post.data.title}
                                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                            />
                        ) : (
                            <div class="flex h-full w-full items-center justify-center text-main/40 italic text-xs">No preview</div>
                        )}
                    </div>
                    <h3 class="font-serif text-base font-bold leading-tight line-clamp-2 mb-2 group-hover:underline group-hover:decoration-dashed text-main">{post.data.title}</h3>
                    {post.data.excerpt && (
                       <p class="text-[11px] text-main/80 line-clamp-3 mb-4 leading-relaxed font-sans">{post.data.excerpt}</p>
                    )}
                </a>
                
                <div class="mt-auto flex items-center justify-between pt-3 border-t border-main-border/5">
                    <div class="flex items-center gap-1.5 overflow-hidden">
                        {post.data.tags.slice(0, 2).map(tag => (
                            <span class="text-[8px] uppercase tracking-tighter text-main/40 whitespace-nowrap">{tag}</span>
                        ))}
                    </div>
                    <span class="text-[9px] font-bold uppercase tracking-widest text-main/40 italic whitespace-nowrap">
                        {post.data.publishDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
                    </span>
                </div>
            </div>
        ))}
    </div>

    <!-- List View Container (Text Only) -->
    <div id="list-container" class="hidden flex-col gap-8 transition-all duration-300">
        {blog.map((post) => (
            <div class="pb-8 border-b border-main-border/5 last:border-0 last:pb-0">
                <PostPreview post={post} />
            </div>
        ))}
    </div>

    <Pagination page={page} class="my-16 sm:my-24" />
    <Subscribe class="my-16 sm:my-24" />
</BaseLayout>

<style>
    @reference "../../styles/global.css";
    .active-view {
        @apply bg-main-bg/10 text-main shadow-sm;
    }
</style>

<script>
    function initViewSwitcher() {
        const galleryBtn = document.getElementById('view-gallery');
        const cardsBtn = document.getElementById('view-cards');
        const listBtn = document.getElementById('view-list');
        
        const galleryContainer = document.getElementById('gallery-container');
        const cardsContainer = document.getElementById('cards-container');
        const listContainer = document.getElementById('list-container');
 
        const buttons = [galleryBtn, cardsBtn, listBtn];
        const containers = [galleryContainer, cardsContainer, listContainer];
 
        if (buttons.some(b => !b) || containers.some(c => !c)) return;
 
        const savedView = localStorage.getItem('blog-view') || 'cards';
        switchTo(savedView as any);
 
        galleryBtn?.addEventListener('click', () => switchTo('gallery'));
        cardsBtn?.addEventListener('click', () => switchTo('cards'));
        listBtn?.addEventListener('click', () => switchTo('list'));
 
        function switchTo(view: 'gallery' | 'cards' | 'list') {
            containers.forEach(c => c?.classList.add('hidden'));
            buttons.forEach(b => {
                b?.classList.remove('active-view');
                b?.classList.add('text-main/40');
            });
 
            const activeContainer = document.getElementById(`${view}-container`);
            const activeBtn = document.getElementById(`view-${view}`);
 
            activeContainer?.classList.remove('hidden');
            activeBtn?.classList.remove('text-main/40');
            activeBtn?.classList.add('active-view');
            
            localStorage.setItem('blog-view', view);
        }
    }
 
    initViewSwitcher();
    document.addEventListener('astro:after-swap', initViewSwitcher);
</script>
