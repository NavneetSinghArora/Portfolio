---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Demo — Step 5 Wow Factor" showHeader={false} noindex={true}>
    <div class="max-w-3xl mx-auto py-12 space-y-20">

        <div>
            <a href="/" class="text-sm text-main/50 hover:text-main transition-colors font-mono">← Back home</a>
            <h1 class="mt-6 font-serif text-3xl font-bold mb-3">Step 5 — Wow Factor</h1>
            <p class="text-main/60 text-sm leading-relaxed max-w-xl">Two polarising options. Both are unique across thousands of portfolios. Pick one — or neither.</p>
        </div>

        <!-- ─── Option A: GLSL Fluid Shader ────────────────────── -->
        <div>
            <div class="mb-4 flex items-center gap-3">
                <span class="flex h-6 w-6 items-center justify-center rounded-md bg-blue-500/10 text-blue-500 text-[11px] font-bold font-mono">A</span>
                <h2 class="font-serif text-xl font-bold">GLSL Fluid Neural Shader</h2>
            </div>
            <p class="text-sm text-main/55 mb-6 leading-relaxed max-w-xl">
                Replaces the current CSS aurora background with a GPU-rendered GLSL shader — smooth, organic fluid motion with a neural-network-themed colour palette. Runs at 60fps via WebGL. Seen on <strong class="text-main/70">p5aholic.me</strong> (three.js + GLSL).
            </p>

            <!-- Live WebGL demo -->
            <div class="relative rounded-2xl overflow-hidden border border-main-border/15 shadow-2xl" style="height: 340px;">
                <canvas id="glsl-canvas" class="absolute inset-0 w-full h-full"></canvas>
                <div class="absolute inset-0 flex flex-col items-center justify-center text-center z-10 pointer-events-none">
                    <p class="text-white/80 font-serif text-2xl font-bold drop-shadow-lg">Live GLSL Preview</p>
                    <p class="text-white/40 text-sm mt-2 font-mono">Running on your GPU right now</p>
                </div>
                <div class="absolute bottom-4 right-4 px-2 py-1 rounded-md bg-black/40 backdrop-blur text-[10px] font-mono text-white/40">WebGL · GLSL</div>
            </div>

            <div class="mt-3 flex flex-wrap gap-2 text-[11px] font-mono text-main/40">
                <span class="px-2 py-0.5 rounded border border-main-border/20 bg-main-bg/10">GPU-rendered · 60fps</span>
                <span class="px-2 py-0.5 rounded border border-main-border/20 bg-main-bg/10">Replaces aurora background</span>
                <span class="px-2 py-0.5 rounded border border-main-border/20 bg-main-bg/10">Very subtle — stays behind all content</span>
                <span class="px-2 py-0.5 rounded border border-main-border/20 bg-main-bg/10">~100 lines · no dependencies</span>
            </div>
        </div>

        <!-- ─── Option B: BIOS Boot Sequence ─────────────────────── -->
        <div>
            <div class="mb-4 flex items-center gap-3">
                <span class="flex h-6 w-6 items-center justify-center rounded-md bg-emerald-500/10 text-emerald-500 text-[11px] font-bold font-mono">B</span>
                <h2 class="font-serif text-xl font-bold">BIOS Boot Sequence Intro</h2>
            </div>
            <p class="text-sm text-main/55 mb-6 leading-relaxed max-w-xl">
                A full-screen retro terminal intro that plays once on the first visit, then fades into the normal portfolio. Inspired by <strong class="text-main/70">adpandey.com</strong>. Extremely memorable — visitors will screenshot it.
            </p>

            <!-- BIOS preview -->
            <div class="relative rounded-2xl overflow-hidden border border-emerald-500/20 shadow-2xl bg-black" style="height: 380px; font-family: 'Courier New', monospace;">
                <div class="absolute inset-0 p-6 text-[13px] leading-[1.8] overflow-hidden" id="bios-container">
                    <!-- Lines injected by JS -->
                </div>
                <div class="absolute bottom-4 right-4 px-2 py-1 rounded-md bg-black/60 border border-emerald-500/20 text-[10px] font-mono text-emerald-400/50">
                    One-time intro · localStorage gated
                </div>
            </div>

            <!-- Replay button -->
            <button id="replay-bios" class="mt-3 px-4 py-2 rounded-xl border border-main-border/20 text-sm font-medium text-main/60 hover:text-main hover:border-main-border/40 transition-all bg-main-bg/10">
                ↺ Replay animation
            </button>

            <div class="mt-3 flex flex-wrap gap-2 text-[11px] font-mono text-main/40">
                <span class="px-2 py-0.5 rounded border border-main-border/20 bg-main-bg/10">localStorage gated — shows once</span>
                <span class="px-2 py-0.5 rounded border border-main-border/20 bg-main-bg/10">Skip button for returning users</span>
                <span class="px-2 py-0.5 rounded border border-main-border/20 bg-main-bg/10">Very polarising — love it or hate it</span>
                <span class="px-2 py-0.5 rounded border border-main-border/20 bg-main-bg/10">~80 lines · no dependencies</span>
            </div>
        </div>

    </div>
</BaseLayout>

<!-- ── GLSL WebGL Shader ─────────────────────────────────────────────── -->
<script>
    const canvas = document.getElementById('glsl-canvas') as HTMLCanvasElement | null;
    if (canvas) {
        const gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl') as WebGLRenderingContext | null;

        if (gl) {
            const resize = () => {
                const rect = canvas.parentElement!.getBoundingClientRect();
                canvas.width  = rect.width  * devicePixelRatio;
                canvas.height = rect.height * devicePixelRatio;
                (gl as WebGLRenderingContext).viewport(0, 0, canvas.width, canvas.height);
            };
            resize();
            window.addEventListener('resize', resize);

            const vert = `
                attribute vec2 a_pos;
                void main() { gl_Position = vec4(a_pos, 0.0, 1.0); }
            `;

            const frag = `
                precision highp float;
                uniform float u_time;
                uniform vec2  u_res;

                float hash(vec2 p) {
                    return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453123);
                }

                float noise(vec2 p) {
                    vec2 i = floor(p);
                    vec2 f = fract(p);
                    vec2 u = f * f * (3.0 - 2.0 * f);
                    return mix(
                        mix(hash(i), hash(i + vec2(1,0)), u.x),
                        mix(hash(i + vec2(0,1)), hash(i + vec2(1,1)), u.x),
                        u.y
                    );
                }

                void main() {
                    vec2 uv = gl_FragCoord.xy / u_res;
                    float t  = u_time * 0.18;

                    // Layered fluid noise
                    float n  = 0.0;
                    n += 0.500 * noise(uv * 3.0 + vec2(t * 0.7, t * 0.5));
                    n += 0.250 * noise(uv * 6.0 + vec2(t * 1.3, t * 0.9));
                    n += 0.125 * noise(uv * 12.0 + vec2(t * 0.4, t * 1.7));
                    n += 0.062 * noise(uv * 24.0 + vec2(t * 2.1, t * 0.3));

                    // Neural synapse pulses (bright streaks)
                    float pulse = 0.0;
                    for (int i = 0; i < 4; i++) {
                        float fi = float(i);
                        vec2 origin = vec2(
                            0.2 + fi * 0.2 + sin(t * 0.6 + fi) * 0.1,
                            0.3 + cos(t * 0.4 + fi * 1.3) * 0.2
                        );
                        float d = length(uv - origin);
                        pulse += exp(-d * 9.0) * (sin(t * 2.0 + fi * 1.7) * 0.5 + 0.5);
                    }

                    // Neural colour palette — deep navy → blue → violet
                    vec3 col = mix(
                        vec3(0.01, 0.03, 0.12),
                        vec3(0.05, 0.10, 0.35),
                        smoothstep(0.3, 0.7, n)
                    );
                    col = mix(col, vec3(0.20, 0.08, 0.50), smoothstep(0.55, 0.85, n) * 0.7);
                    col += vec3(0.10, 0.55, 1.00) * pulse * 0.35;
                    col += vec3(0.60, 0.20, 1.00) * smoothstep(0.7, 1.0, n) * 0.25;

                    // Keep it subtle — this is a background
                    col = clamp(col * 0.85, 0.0, 1.0);

                    gl_FragColor = vec4(col, 1.0);
                }
            `;

            function compile(type: number, src: string) {
                const s = (gl as WebGLRenderingContext).createShader(type)!;
                (gl as WebGLRenderingContext).shaderSource(s, src);
                (gl as WebGLRenderingContext).compileShader(s);
                return s;
            }

            const prog = (gl as WebGLRenderingContext).createProgram()!;
            (gl as WebGLRenderingContext).attachShader(prog, compile((gl as WebGLRenderingContext).VERTEX_SHADER, vert));
            (gl as WebGLRenderingContext).attachShader(prog, compile((gl as WebGLRenderingContext).FRAGMENT_SHADER, frag));
            (gl as WebGLRenderingContext).linkProgram(prog);
            (gl as WebGLRenderingContext).useProgram(prog);

            const buf = (gl as WebGLRenderingContext).createBuffer();
            (gl as WebGLRenderingContext).bindBuffer((gl as WebGLRenderingContext).ARRAY_BUFFER, buf);
            (gl as WebGLRenderingContext).bufferData((gl as WebGLRenderingContext).ARRAY_BUFFER, new Float32Array([-1,-1, 1,-1, -1,1, 1,1]), (gl as WebGLRenderingContext).STATIC_DRAW);

            const aPos = (gl as WebGLRenderingContext).getAttribLocation(prog, 'a_pos');
            (gl as WebGLRenderingContext).enableVertexAttribArray(aPos);
            (gl as WebGLRenderingContext).vertexAttribPointer(aPos, 2, (gl as WebGLRenderingContext).FLOAT, false, 0, 0);

            const uTime = (gl as WebGLRenderingContext).getUniformLocation(prog, 'u_time');
            const uRes  = (gl as WebGLRenderingContext).getUniformLocation(prog, 'u_res');

            let start = performance.now();
            function frame() {
                (gl as WebGLRenderingContext).uniform1f(uTime, (performance.now() - start) / 1000);
                (gl as WebGLRenderingContext).uniform2f(uRes, canvas!.width, canvas!.height);
                (gl as WebGLRenderingContext).drawArrays((gl as WebGLRenderingContext).TRIANGLE_STRIP, 0, 4);
                requestAnimationFrame(frame);
            }
            requestAnimationFrame(frame);
        }
    }
</script>

<!-- ── BIOS Terminal Animation ────────────────────────────────────────── -->
<script>
    const biosLines = [
        { text: 'NAVNEET.OS v2.0.26 — Neural Edition', color: '#22d3ee', delay: 0 },
        { text: '(C) 2026 Navneet Singh Arora, Hamburg', color: '#6ee7b7', delay: 120 },
        { text: '', color: '', delay: 200 },
        { text: 'CPU  : Apple M-Series @ 3.5GHz ..... [OK]', color: '#86efac', delay: 320 },
        { text: 'RAM  : 32768MB detected ............. [OK]', color: '#86efac', delay: 440 },
        { text: 'DISK : 2TB SSD ....................... [OK]', color: '#86efac', delay: 560 },
        { text: '', color: '', delay: 680 },
        { text: 'Loading AI subsystems...', color: '#a3e635', delay: 820 },
        { text: '  > LangChain ................ ONLINE', color: '#4ade80', delay: 980 },
        { text: '  > FastMCP .................. ONLINE', color: '#4ade80', delay: 1100 },
        { text: '  > Google Vertex AI ......... ONLINE', color: '#4ade80', delay: 1220 },
        { text: '  > n8n Automation ........... ONLINE', color: '#4ade80', delay: 1340 },
        { text: '  > Neural Networks .......... LOADED', color: '#4ade80', delay: 1460 },
        { text: '', color: '', delay: 1580 },
        { text: 'Experience   : 8+ years ........... [VERIFIED]', color: '#86efac', delay: 1700 },
        { text: 'Projects     : 50+ shipped ......... [VERIFIED]', color: '#86efac', delay: 1820 },
        { text: 'n8n Workflows: 1+ published ....... [VERIFIED]', color: '#86efac', delay: 1940 },
        { text: '', color: '', delay: 2060 },
        { text: '> STATUS: Open to opportunities', color: '#fbbf24', delay: 2200 },
        { text: '', color: '', delay: 2320 },
        { text: 'Press any key to explore portfolio...', color: '#22d3ee', delay: 2500 },
        { text: '█', color: '#22d3ee', delay: 2700, blink: true },
    ];

    function runBios() {
        const container = document.getElementById('bios-container');
        if (!container) return;
        container.innerHTML = '';

        biosLines.forEach(line => {
            setTimeout(() => {
                const p = document.createElement('p');
                p.style.color = line.color || '#334155';
                p.style.minHeight = '1.3em';
                if ((line as any).blink) {
                    p.style.animation = 'biosBlinkAnim 0.9s step-end infinite';
                }
                p.textContent = line.text;
                container.appendChild(p);
                container.scrollTop = container.scrollHeight;
            }, line.delay);
        });
    }

    runBios();

    document.getElementById('replay-bios')?.addEventListener('click', runBios);
</script>

<style>
    @keyframes biosBlinkAnim {
        0%, 100% { opacity: 1; }
        50%       { opacity: 0; }
    }
</style>
