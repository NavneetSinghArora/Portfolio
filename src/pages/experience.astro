---
import siteConfig from '../data/site-config';
import BaseLayout from '../layouts/BaseLayout.astro';

import repathImg from '../assets/images/repath.jpeg';
import omdenaImg from '../assets/images/omdena.png';
import uhhImg from '../assets/images/uhh.jpeg';
import niceImg from '../assets/images/nice.jpeg';
import cognizantImg from '../assets/images/cognizant.png';

const experiences = [
    {
        company: 'Repath',
        linkedin: 'https://www.linkedin.com/company/repathnow/posts/?feedView=all',
        period: 'Dec 2021 — Present',
        roles: [
            {
                title: 'Machine Learning & Full Stack Engineer',
                period: 'Dec 2021 — Present',
                location: 'Hamburg, Germany',
                description: 'Leading the AI initiative and architecting AI-powered Climate Resilience solutions using FastMCP, LangChain, and GCP. Project Lead for CI/CD pipelines, integrating ML algorithms, and managing data integration infrastructure.'
            }
        ],
        icon: `<img src="${repathImg.src}" alt="Repath" class="h-full w-full rounded-2xl object-cover" />`
    },
    {
        company: 'Omdena',
        linkedin: 'https://www.linkedin.com/company/omdena/posts/?feedView=all',
        period: 'Jun 2021 — Present',
        roles: [
            {
                title: 'Chapter Lead',
                period: 'Jun 2021 — Present',
                location: 'Remote',
                description: 'Community Leader for the Hamburg Chapter, hosting open-source AI projects for knowledge sharing and social impact among global tech community members.'
            }
        ],
        icon: `<img src="${omdenaImg.src}" alt="Omdena" class="h-full w-full rounded-2xl object-cover" />`
    },
    {
        company: 'Universität Hamburg',
        linkedin: 'https://www.linkedin.com/school/unihamburg/posts/?feedView=all',
        period: 'Oct 2021 — Mar 2022',
        roles: [
            {
                title: 'Student Tutor',
                period: 'Oct 2021 — Mar 2022',
                location: 'Hamburg, Germany',
                description: 'Conducted practical labs and Q&A sessions for Computer Vision students. Managed course administration and student assignment tracking.'
            }
        ],
        icon: `<img src="${uhhImg.src}" alt="Universität Hamburg" class="h-full w-full rounded-2xl object-cover" />`
    },
    {
        company: 'alloffice.space',
        period: 'May 2020 — Feb 2021',
        roles: [
            {
                title: 'Full Stack Engineer - Freelance',
                period: 'May 2020 — Feb 2021',
                location: 'Remote',
                description: 'Developed backend applications using Python and Selenium. Built internal platform UI leveraging Tkinter to accelerate team workflows.'
            }
        ],
        icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="M10 4v4"/><path d="M2 8h20"/><path d="M6 4v4"/></svg>'
    },
    {
        company: 'NICE Ltd.',
        linkedin: 'https://www.linkedin.com/company/nice-systems/posts/?feedView=all',
        period: 'Jan 2018 — Oct 2020',
        roles: [
            {
                title: 'Tech Lead',
                period: 'Oct 2019 — Oct 2020',
                location: 'Pune, India',
                description: 'Moving up the ladder, I was given the role of Technical Scrum Master along with being a Full Stack Developer. Extensive work on Client-Side as well as Server-Side code to build new features and integrate legacy code. Also worked as a QA on various fronts.'
            },
            {
                title: 'Software Engineer',
                period: 'Jan 2018 — Oct 2019',
                location: 'Pune, India',
                description: 'I started working as a Tableau Developer, creating Dashboards along with Data Sources. Joined a new team to upgrade the product platform and develop multiple features from scratch. I was also given the responsibility of Scrum Master.'
            }
        ],
        icon: `<img src="${niceImg.src}" alt="NICE Ltd." class="h-full w-full rounded-2xl object-cover" />`
    },
    {
        company: 'Cognizant',
        linkedin: 'https://www.linkedin.com/company/cognizant/posts/?feedView=all',
        period: 'Jul 2015 — Jan 2018',
        roles: [
            {
                title: 'Program Analyst',
                period: 'Dec 2015 — Jan 2018',
                location: 'Pune, India',
                description: 'Joined Credit Suisse as a Software Developer. I was part of 4 projects extensively using Java and Shell Script. Named Innovation Lead for the team, saving costs for the project and awarded Kudos Award for significant contributions.'
            },
            {
                title: 'Program Analyst Trainee',
                period: 'Jul 2015 — Nov 2015',
                location: 'Pune, India',
                description: 'Started my stint in IT as a Trainee. Went through comprehensive training in Java, SQL, and various basic modules including communications and soft skills.'
            }
        ],
        icon: `<img src="${cognizantImg.src}" alt="Cognizant" class="h-full w-full rounded-2xl object-cover" />`
    }
];

// Extract unique locations for filtering
const allLocations = [...new Set(experiences.flatMap(exp => exp.roles.map(role => role.location.split(', ').pop())))];

const spotlightColors = [
    'rgba(56, 189, 248, 0.15)', // Blue
    'rgba(139, 92, 246, 0.15)', // Purple
    'rgba(16, 185, 129, 0.15)', // Emerald
    'rgba(245, 158, 11, 0.15)', // Amber
    'rgba(236, 72, 153, 0.15)', // Pink
    'rgba(244, 63, 94, 0.15)',  // Rose
];
---

<BaseLayout title={`Experience - ${siteConfig.title}`} description="Professional experience and career journey.">
    <div class="mb-12">
        <h1 class="font-serif text-3xl leading-tight font-medium sm:text-4xl mb-4 text-main">Experience</h1>
        <p class="text-main/70">My professional journey and industry impact.</p>
    </div>

    <!-- Premium Filter Console -->
    <div class="mb-12 space-y-4">
        <!-- Search Bar -->
        <div class="relative group">
            <input 
                type="text" 
                id="experience-search" 
                placeholder="Search by company, role, or technology..." 
                class="w-full bg-main-bg/10 backdrop-blur-md border border-main-border/20 rounded-xl py-3 pl-12 pr-4 text-[14px] text-main placeholder:text-main/40 focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500/30 transition-all shadow-sm"
            />
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-main/50 group-focus-within:text-blue-500 transition-colors pointer-events-none z-10"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        </div>

        <!-- Tool Row (Filters + Sort) -->
        <div class="flex flex-wrap items-center justify-between gap-4">
            <div class="flex flex-wrap items-center gap-3">
                <!-- Location Dropdown -->
                <div class="relative dropdown-container" id="location-dropdown">
                    <button class="dropdown-trigger flex items-center justify-between gap-3 px-4 py-2.5 min-w-[160px] bg-main-bg/10 backdrop-blur-md border border-main-border/20 rounded-xl text-[14px] font-medium text-main/60 hover:text-main transition-all shadow-sm">
                        <div class="flex items-center gap-2">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 opacity-40"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
                            <span id="current-location">All Locations</span>
                        </div>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 opacity-30 chevron transition-transform"><path d="m6 9 6 6 6-6"></path></svg>
                    </button>
                    
                    <div class="dropdown-menu hidden absolute top-full left-0 mt-2 min-w-[200px] bg-main-bg/80 backdrop-blur-xl border border-main-border/10 rounded-xl py-1.5 shadow-2xl z-50 origin-top-left transition-all duration-200">
                        <button class="filter-btn flex items-center gap-3 w-full px-4 py-2 text-[13px] text-main/60 hover:text-main hover:bg-main-bg/10 transition-colors" data-filter="all">
                            <div class="h-1.5 w-1.5 rounded-full bg-blue-500 opacity-100 transition-opacity active-indicator"></div>
                            All Places
                        </button>
                        {allLocations.sort().map(loc => (
                            <button class="filter-btn flex items-center gap-3 w-full px-4 py-2 text-[13px] text-main/60 hover:text-main hover:bg-main-bg/10 transition-colors" data-filter={loc}>
                                <div class="h-1.5 w-1.5 rounded-full bg-blue-500 opacity-0 transition-opacity active-indicator"></div>
                                {loc}
                            </button>
                        ))}
                    </div>
                </div>

                <!-- Sort Dropdown -->
                <div class="relative dropdown-container" id="sort-dropdown">
                    <button class="dropdown-trigger flex items-center justify-between gap-3 px-4 py-2.5 min-w-[160px] bg-main-bg/10 backdrop-blur-md border border-main-border/20 rounded-xl text-[14px] font-medium text-main/60 hover:text-main transition-all shadow-sm">
                        <div class="flex items-center gap-2">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 opacity-40"><path d="m3 16 4 4 4-4"></path><path d="M7 20V4"></path><path d="m21 8-4-4-4 4"></path><path d="M17 4v16"></path></svg>
                            <span id="current-sort">Newest First</span>
                        </div>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 opacity-30 chevron transition-transform"><path d="m6 9 6 6 6-6"></path></svg>
                    </button>
                    
                    <div class="dropdown-menu hidden absolute top-full left-0 mt-2 min-w-[200px] bg-main-bg/80 backdrop-blur-xl border border-main-border/10 rounded-xl py-1.5 shadow-2xl z-50 origin-top-left transition-all duration-200">
                        <button class="sort-btn flex items-center gap-3 w-full px-4 py-2 text-[13px] text-main/60 hover:text-main hover:bg-main-bg/10 transition-colors" data-sort="newest">
                            <div class="h-1.5 w-1.5 rounded-full bg-blue-500 opacity-100 transition-opacity active-indicator"></div>
                            Newest First
                        </button>
                        <button class="sort-btn flex items-center gap-3 w-full px-4 py-2 text-[13px] text-main/60 hover:text-main hover:bg-main-bg/10 transition-colors" data-sort="oldest">
                            <div class="h-1.5 w-1.5 rounded-full bg-blue-500 opacity-0 transition-opacity active-indicator"></div>
                            Oldest First
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-10" id="experience-container">
        {experiences.length > 0 ? (
            experiences.map((item, index) => (
                <div 
                    class="experience-card spotlight-card group relative flex flex-col gap-6 sm:flex-row sm:items-start sm:gap-8 p-6"
                    style={`--spotlight-color: ${spotlightColors[index % spotlightColors.length]};`}
                    data-company={item.company.toLowerCase()}
                    data-location={item.roles[0].location.split(', ').pop()}
                    data-date={index}
                    data-search={`${item.company} ${item.roles.map(r => r.title + ' ' + r.description).join(' ')}`.toLowerCase()}
                >
                    <div class="spotlight-glow"></div>
                    
                    {/* SVG Icon Container */}
                    <div class="flex-shrink-0">
                        <div class="flex h-16 w-16 items-center justify-center rounded-2xl border border-main-border/20 bg-main-bg/10 text-main/70 shadow-sm transition-colors group-hover:border-main-border/30 group-hover:text-main overflow-hidden p-0" set:html={item.icon} />
                    </div>
                    
                    {/* Content */}
                    <div class="flex-1 space-y-6">
                        <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 sm:gap-4">
                            <h2 class="font-serif text-xl sm:text-2xl font-bold flex items-center gap-2 text-main">
                                {item.company}
                                {item.linkedin && (
                                    <a 
                                        href={item.linkedin} 
                                        target="_blank" 
                                        rel="noopener noreferrer" 
                                        class="group/social premium-tooltip relative flex h-8 w-8 items-center justify-center transition-all duration-300 hover:scale-115 mt-1" 
                                        data-tooltip="LinkedIn"
                                    >
                                        <div class="absolute inset-0 rounded-xl bg-main/5 opacity-0 transition-all duration-300 group-hover/social:opacity-100 group-hover/social:scale-110 group-hover/social:bg-main/10 ring-1 ring-main/10"></div>
                                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="relative z-10 text-main/50 group-hover/social:text-main transition-all duration-300 group-hover/social:scale-110">
                                            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                                        </svg>
                                    </a>
                                )}
                            </h2>
                            <span class="text-xs font-bold uppercase tracking-widest text-main/60">{item.period}</span>
                        </div>
                        
                        <div class="space-y-6 relative before:absolute before:inset-y-1 before:-left-[24px] before:w-[1px] before:bg-main-border/20 ml-6 sm:ml-0">
                            {item.roles.map(role => (
                                <div class="relative">
                                    <span class="absolute top-1.5 -left-[27.5px] h-2 w-2 rounded-full bg-blue-500 ring-4 ring-blue-500/10 backdrop-blur-md"></span>
                                    <h3 class="text-base font-semibold text-main/90">{role.title}</h3>
                                    
                                    <div class="flex items-center gap-3 text-xs font-medium text-main/60 mt-1 mb-3">
                                        <span>{role.period}</span>
                                        {role.location && (
                                            <>
                                                <span class="h-1 w-1 rounded-full bg-main/30"></span>
                                                <span>{role.location}</span>
                                            </>
                                        )}
                                    </div>
                                    
                                    <p class="text-sm leading-relaxed text-main/80 max-w-2xl font-serif">
                                        {role.description}
                                    </p>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            ))
        ) : (
            <p class="text-main/60 font-serif">Experience details will be updated soon.</p>
        )}
    </div>

    <script>
        function initExperienceDiscovery() {
            const searchInput = document.getElementById('experience-search') as HTMLInputElement;
            const container = document.getElementById('experience-container');
            const cards = Array.from(document.querySelectorAll('.experience-card')) as HTMLElement[];
            const filterBtns = document.querySelectorAll('.filter-btn');
            const sortBtns = document.querySelectorAll('.sort-btn');
            
            let currentFilter = 'all';
            let currentSort = 'newest';
            let searchQuery = '';

            function updateUI() {
                cards.forEach(card => {
                    const matchesSearch = card.dataset.search?.includes(searchQuery);
                    const matchesFilter = currentFilter === 'all' || card.dataset.location === currentFilter;
                    
                    if (matchesSearch && matchesFilter) {
                        card.style.display = 'flex';
                        card.style.opacity = '1';
                        card.style.transform = 'translateY(0)';
                    } else {
                        card.style.display = 'none';
                        card.style.opacity = '0';
                        card.style.transform = 'translateY(10px)';
                    }
                });

                // Apply Sort
                const visibleCards = cards.filter(c => c.style.display !== 'none');
                visibleCards.sort((a, b) => {
                    const valA = parseInt(a.dataset.date || '0');
                    const valB = parseInt(b.dataset.date || '0');
                    return currentSort === 'newest' ? valA - valB : valB - valA;
                });

                visibleCards.forEach((card, index) => {
                    card.style.order = index.toString();
                });
            }

            // Search
            searchInput?.addEventListener('input', (e) => {
                searchQuery = (e.target as HTMLInputElement).value.toLowerCase();
                updateUI();
            });

            // Filter
            filterBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    currentFilter = (btn as HTMLElement).dataset.filter || 'all';
                    const label = document.getElementById('current-location');
                    if (label) label.textContent = currentFilter === 'all' ? 'All Locations' : currentFilter;
                    
                    // Update active state
                    filterBtns.forEach(b => {
                        const indicator = b.querySelector('.active-indicator');
                        if (indicator) {
                            indicator.classList.remove('opacity-100');
                            indicator.classList.add('opacity-0');
                        }
                    });
                    const currentIndicator = btn.querySelector('.active-indicator');
                    if (currentIndicator) {
                        currentIndicator.classList.remove('opacity-0');
                        currentIndicator.classList.add('opacity-100');
                    }
                    
                    updateUI();
                });
            });

            // Sort
            sortBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    currentSort = (btn as HTMLElement).dataset.sort || 'newest';
                    const label = document.getElementById('current-sort');
                    if (label) label.textContent = currentSort === 'newest' ? 'Recent First' : 'Oldest First';

                    // Update active state
                    sortBtns.forEach(b => {
                        const indicator = b.querySelector('.active-indicator');
                        if (indicator) {
                            indicator.classList.remove('opacity-100');
                            indicator.classList.add('opacity-0');
                        }
                    });
                    const currentIndicator = btn.querySelector('.active-indicator');
                    if (currentIndicator) {
                        currentIndicator.classList.remove('opacity-0');
                        currentIndicator.classList.add('opacity-100');
                    }

                    updateUI();
                });
            });

            // Dropdown Logic
            const triggers = document.querySelectorAll('.dropdown-trigger');
            triggers.forEach(trigger => {
                trigger.addEventListener('click', (e) => {
                    e.stopPropagation();
                    const menu = trigger.nextElementSibling;
                    const chevron = trigger.querySelector('.chevron');
                    
                    document.querySelectorAll('.dropdown-menu').forEach(m => {
                        if (m !== menu) m.classList.add('hidden');
                    });
                    document.querySelectorAll('.chevron').forEach(c => {
                        if (c !== chevron) c.classList.remove('rotate-180');
                    });

                    menu?.classList.toggle('hidden');
                    chevron?.classList.toggle('rotate-180');
                });
            });

            document.addEventListener('click', () => {
                document.querySelectorAll('.dropdown-menu').forEach(m => m.classList.add('hidden'));
                document.querySelectorAll('.chevron').forEach(c => c.classList.remove('rotate-180'));
            });
        }

        initExperienceDiscovery();
        document.addEventListener('astro:after-swap', initExperienceDiscovery);
    </script>

    <style>
        .experience-card {
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .rotate-180 { transform: rotate(180deg); }
    </style>
</BaseLayout>
